# Variables de entorno — Giralabs Booking System
# Copia este fichero como ".env" en la raíz del proyecto y rellena los valores.
# NUNCA subas el fichero .env real a un repositorio público.

# ─────────────────────────────────────────────────────────────────
# GMAIL SMTP (para enviar correos de confirmación)
# ─────────────────────────────────────────────────────────────────
# El email de Giralabs que envía los correos
GMAIL_USER=giralabs.contact@gmail.com

# Contraseña de aplicación de Gmail (NO la contraseña normal):
#   Google Account → Seguridad → Verificación en 2 pasos → Contraseñas de aplicación
#   Crea una nueva app "Giralabs Web" y pega las 16 letras aquí (sin espacios)
GMAIL_APP_PASSWORD=xxxx_xxxx_xxxx_xxxx

# ─────────────────────────────────────────────────────────────────
# GOOGLE CALENDAR API (para crear eventos reales de Google Meet)
# ─────────────────────────────────────────────────────────────────
# Crea un proyecto en https://console.cloud.google.com/
# Activa "Google Calendar API"
# Ve a Credenciales → Crear credencial → ID de cliente OAuth 2.0 (Aplicación web)
# URI de redirección autorizado: https://developers.google.com/oauthplayground
# Luego en https://developers.google.com/oauthplayground:
#   - Activa "Use your own OAuth credentials" e ingresa Client ID y Secret
#   - Autoriza el scope: https://www.googleapis.com/auth/calendar
#   - Intercambia el código por tokens y copia el Refresh Token

GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_client_secret
GOOGLE_REFRESH_TOKEN=1//your_refresh_token_here

# ─────────────────────────────────────────────────────────────────
# UPSTASH REDIS (para persistir reservas en Vercel / producción)
# ─────────────────────────────────────────────────────────────────
# Crea una base de datos gratuita en https://upstash.com
# Ve a tu base de datos → REST API → copia URL y Token
# En Vercel, añádelas en Settings → Environment Variables
# (o vincula la integración de Upstash desde el marketplace de Vercel)
#
# Sin estas vars → se usa data/bookings.json (sólo para desarrollo local)

UPSTASH_REDIS_REST_URL=https://your-database.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token_here

# ─────────────────────────────────────────────────────────────────
# SITE URL (para el logo en los correos)
# ─────────────────────────────────────────────────────────────────
# URL pública de tu sitio (sin barra final). En Vercel es tu dominio o la URL de preview.
# Sin esto, el logo no aparece en los correos (se usa texto "Giralabs" como fallback).
PUBLIC_SITE_URL=https://tu-proyecto.vercel.app

