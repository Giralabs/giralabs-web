---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { translations } from '../i18n/translations';
import CTAContact from '../components/CTAContact.astro';
import Footer from '../components/Footer.astro';

const acceptLang = Astro.request.headers.get('accept-language');
const langParam = Astro.url.searchParams.get('lang');
let lang = 'es';

if (langParam === 'es' || langParam === 'en') {
  lang = langParam;
} else if (acceptLang && !acceptLang.toLowerCase().startsWith('es')) {
  lang = 'en';
}

const T = translations[lang];
---

<Layout
  title={`${T.meta_title} | ${T.about_meta_title}`}
  description={T.about_meta_description}
  lang={lang}
>
  <!-- Global dot-grid background -->
  <div class="grid-bg" aria-hidden="true"></div>
  
  <!-- Ambient glowing blobs -->
  <div class="ambient-glow glow-top" aria-hidden="true"></div>
  <div class="ambient-glow glow-bottom" aria-hidden="true"></div>

  <!-- Navbar -->
  <Navbar lang={lang} />

  <!-- ==================== HERO HEADER ==================== -->
  <header class="about-hero reveal">
    <div class="hero-inner">
      <span class="hero-eyebrow" data-i18n="about_hero_eyebrow">{T.about_hero_eyebrow}</span>
      <h1 class="hero-title" data-i18n="about_page_title">{T.about_page_title}</h1>
      <p class="hero-subtitle" data-i18n="about_page_subtitle">{T.about_page_subtitle}</p>
    </div>
  </header>

  <main class="about-container">
    <!-- ==================== INTRODUCTION ==================== -->
    <section class="about-intro-section reveal">
      <div class="about-glass-panel">
        <div class="panel-border"></div>
        <div class="panel-inner">
          <div class="intro-grid">
            <div class="intro-left">
              <h2 class="section-title" data-i18n="how_title">Un proceso claro,<br/>resultados concretos.</h2>
            </div>
            <div class="intro-right">
              <p class="intro-p lead-p" data-i18n="about_intro_p1">{T.about_intro_p1}</p>
              <p class="intro-p" data-i18n="about_intro_p2">{T.about_intro_p2}</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== VALUES SECTION ==================== -->
    <section class="values-section">
      <div class="section-header reveal">
        <span class="section-eyebrow">CÓMO PENSAMOS</span>
        <h2 class="section-heading">Nuestros pilares fundamentales</h2>
      </div>
      
      <div class="values-grid reveal-stagger">
        <!-- VALUE 1: Engineering -->
        <div class="value-card" id="value-card-1">
          <div class="card-effects">
            <div class="card-spotlight"></div>
            <div class="card-sweep"></div>
          </div>
          <div class="card-border"></div>
          <div class="card-info">
            <div class="card-visual">
              <div class="value-widget engineering-widget">
                <div class="widget-terminal">
                  <div class="term-line">> giralabs build --prod</div>
                  <div class="term-line success">> optimized (99.9% performance)</div>
                  <div class="term-line success">> zero debt. code clean</div>
                </div>
              </div>
            </div>
            <h3 class="value-title" data-i18n="about_value_1_title">{T.about_value_1_title}</h3>
            <p class="value-desc" data-i18n="about_value_1_desc">{T.about_value_1_desc}</p>
          </div>
        </div>

        <!-- VALUE 2: Design -->
        <div class="value-card" id="value-card-2">
          <div class="card-effects">
            <div class="card-spotlight"></div>
            <div class="card-sweep"></div>
          </div>
          <div class="card-border"></div>
          <div class="card-info">
            <div class="card-visual">
              <div class="value-widget design-widget">
                <div class="design-canvas">
                  <div class="design-circle-pulsing"></div>
                  <div class="design-connector-line"></div>
                  <div class="design-box"></div>
                </div>
              </div>
            </div>
            <h3 class="value-title" data-i18n="about_value_2_title">{T.about_value_2_title}</h3>
            <p class="value-desc" data-i18n="about_value_2_desc">{T.about_value_2_desc}</p>
          </div>
        </div>

        <!-- VALUE 3: Transparency -->
        <div class="value-card" id="value-card-3">
          <div class="card-effects">
            <div class="card-spotlight"></div>
            <div class="card-sweep"></div>
          </div>
          <div class="card-border"></div>
          <div class="card-info">
            <div class="card-visual">
              <div class="value-widget transparency-widget">
                <div class="transparency-visual">
                  <svg viewBox="0 0 100 60" width="80" height="50" fill="none" stroke="currentColor" stroke-width="2">
                    <rect x="10" y="10" width="80" height="40" rx="8" stroke="rgba(0,0,0,0.1)"></rect>
                    <line x1="25" y1="30" x2="75" y2="30" stroke="rgba(0,0,0,0.15)" stroke-dasharray="3,3"></line>
                    <circle cx="50" cy="30" r="10" fill="#F0EFEA" stroke="currentColor" stroke-width="2" class="glowing-node"></circle>
                  </svg>
                </div>
              </div>
            </div>
            <h3 class="value-title" data-i18n="about_value_3_title">{T.about_value_3_title}</h3>
            <p class="value-desc" data-i18n="about_value_3_desc">{T.about_value_3_desc}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ==================== TEAM SECTION (Commented out temporarily) ==================== -->
    <!--
    <section class="team-section">
      <div class="section-header reveal">
        <span class="section-eyebrow" data-i18n="about_team_title">{T.about_team_title}</span>
        <h2 class="section-heading" data-i18n="about_team_subtitle">{T.about_team_subtitle}</h2>
      </div>

      <div class="team-grid reveal-stagger">
        <div class="team-card">
          <div class="card-effects">
            <div class="card-spotlight"></div>
          </div>
          <div class="card-border"></div>
          <div class="team-inner">
            <div class="avatar-container">
              <div class="avatar-gradient avatar-eng">
                <span class="avatar-initials">JM</span>
              </div>
            </div>
            <div class="team-info">
              <h3 class="team-name" data-i18n="team_member_1_name">{T.team_member_1_name}</h3>
              <span class="team-role" data-i18n="team_member_1_role">{T.team_member_1_role}</span>
              <p class="team-bio" data-i18n="team_member_1_bio">{T.team_member_1_bio}</p>
              <div class="team-skills">
                <span class="skill-tag">Flutter</span>
                <span class="skill-tag">Go</span>
                <span class="skill-tag">Kubernetes</span>
                <span class="skill-tag">System Arch</span>
              </div>
            </div>
          </div>
        </div>

        <div class="team-card">
          <div class="card-effects">
            <div class="card-spotlight"></div>
          </div>
          <div class="card-border"></div>
          <div class="team-inner">
            <div class="avatar-container">
              <div class="avatar-gradient avatar-design">
                <span class="avatar-initials">LG</span>
              </div>
            </div>
            <div class="team-info">
              <h3 class="team-name" data-i18n="team_member_2_name">{T.team_member_2_name}</h3>
              <span class="team-role" data-i18n="team_member_2_role">{T.team_member_2_role}</span>
              <p class="team-bio" data-i18n="team_member_2_bio">{T.team_member_2_bio}</p>
              <div class="team-skills">
                <span class="skill-tag">Figma</span>
                <span class="skill-tag">UX Research</span>
                <span class="skill-tag">Design Systems</span>
                <span class="skill-tag">Motion</span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
    -->


  </main>

  <CTAContact lang={lang} />

  <Footer lang={lang} />

  <!-- ==================== I18N + INTERACTION SCRIPTS ==================== -->
  <script define:vars={{ translations: { es: translations['es'], en: translations['en'] } }}>
    let currentLang = document.documentElement.lang || 'es';

    function applyLang(lang) {
      currentLang = lang;
      const T = translations[lang];
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        if (T[key] !== undefined) {
          if (key === 'how_title' || key === 'sd_title') {
            el.innerHTML = T[key].replace(/\n/g, '<br/>');
          } else if (T[key].includes('<') || key === 'hero_tagline') {
            el.innerHTML = T[key];
          } else {
            el.textContent = T[key];
          }
        }
      });
      document.documentElement.lang = lang;
      document.title = T.meta_title + " | " + T.about_meta_title;
    }

    // Detect and apply saved language on load, or browser settings if not saved
    let initialLang = 'es';
    const savedLang = localStorage.getItem('giralabs-lang');
    if (savedLang && (savedLang === 'es' || savedLang === 'en')) {
      initialLang = savedLang;
    } else {
      const browserLang = navigator.language || navigator.userLanguage;
      if (browserLang && !browserLang.toLowerCase().startsWith('es')) {
        initialLang = 'en';
      }
    }
    applyLang(initialLang);

    // Listen to navbar's language changes
    document.addEventListener('giralabs:lang', (e) => {
      applyLang(e.detail.lang);
    });

    // Spotlight mouse tracking for advanced glass cards
    document.querySelectorAll('.value-card, .team-card').forEach(card => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        card.style.setProperty('--mx', x + 'px');
        card.style.setProperty('--my', y + 'px');
      });
    });

    // Trigger visual scroll animations
    const revealEls = document.querySelectorAll('.reveal, .reveal-stagger');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          if (entry.target.classList.contains('reveal-stagger')) {
            entry.target.querySelectorAll('.value-card, .team-card').forEach(block => {
              block.classList.add('is-active');
            });
          }
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    revealEls.forEach(el => observer.observe(el));
  </script>
</Layout>

<style>
  /* ========================================
     GLOBAL VARIABLES & STYLES
     ======================================== */
  :root {
    --accent-color-1: #000000;
    --accent-rgb-1: 0, 0, 0;
    --accent-color-2: #888888;
    --accent-rgb-2: 136, 136, 136;
  }

  .grid-bg {
    position: fixed;
    inset: 0;
    background-image: radial-gradient(rgba(0,0,0,0.05) 1.2px, transparent 1.2px);
    background-size: 32px 32px;
    pointer-events: none;
    z-index: 0;
    opacity: 0.65;
  }

  /* Ambient glowing blobs */
  .ambient-glow {
    position: fixed;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    filter: blur(120px);
    pointer-events: none;
    z-index: 0;
    opacity: 0.07;
  }

  .glow-top {
    top: -200px;
    right: -100px;
    background: radial-gradient(circle, rgba(255, 180, 100, 0.15) 0%, transparent 65%);
  }

  .glow-bottom {
    bottom: -250px;
    left: -150px;
    background: radial-gradient(circle, rgba(0, 200, 255, 0.1) 0%, transparent 70%);
  }

  /* ========================================
     HERO SEGMENT
     ======================================== */
  .about-hero {
    position: relative;
    padding: 10rem 2rem 4rem;
    z-index: 1;
    text-align: center;
  }

  .hero-inner {
    max-width: 800px;
    margin: 0 auto;
  }

  .hero-eyebrow {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.25em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.4);
    display: inline-block;
    margin-bottom: 1rem;
  }

  .hero-title {
    font-size: clamp(2.2rem, 6vw, 3.6rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: #000;
    margin: 0 0 1.2rem;
    line-height: 1.15;
  }

  .hero-subtitle {
    font-size: clamp(1.05rem, 3vw, 1.25rem);
    color: rgba(0,0,0,0.6);
    line-height: 1.6;
    margin: 0;
  }

  /* ========================================
     CONTAINER LAYOUT
     ======================================== */
  .about-container {
    position: relative;
    z-index: 2;
    padding: 0 2rem 6rem;
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 7rem;
  }

  /* ========================================
     INTRO SECTION (Large Glass Panel)
     ======================================== */
  .about-intro-section {
    width: 100%;
  }

  .about-glass-panel {
    position: relative;
    border-radius: 32px;
    overflow: hidden;
    background: rgba(255, 255, 255, 0.35);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    box-shadow: 
      0 12px 40px rgba(0,0,0,0.03),
      0 0 0 0.5px rgba(0,0,0,0.02) inset,
      0 1px 0 rgba(255,255,255,0.7) inset;
  }

  .panel-border {
    position: absolute;
    inset: 0;
    pointer-events: none;
    border-radius: 32px;
    border: 1px solid rgba(255, 255, 255, 0.65);
    z-index: 2;
  }

  .panel-inner {
    padding: 4.5rem 4rem;
  }

  .intro-grid {
    display: grid;
    grid-template-columns: 1fr 1.3fr;
    gap: 3.5rem;
    align-items: start;
  }

  .intro-left .section-title {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 800;
    line-height: 1.2;
    letter-spacing: -0.03em;
    color: #000;
    margin: 0;
  }

  .intro-right {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .intro-p {
    font-size: 1.02rem;
    color: rgba(0,0,0,0.65);
    line-height: 1.7;
    margin: 0;
  }

  .lead-p {
    font-size: 1.15rem;
    color: #000;
    font-weight: 500;
  }

  /* ========================================
     VALUES SECTION (Glass Grid)
     ======================================== */
  .section-header {
    text-align: center;
    margin-bottom: 3.5rem;
  }

  .section-eyebrow {
    font-size: 0.68rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: rgba(0,0,0,0.4);
    text-transform: uppercase;
    display: inline-block;
    margin-bottom: 0.6rem;
  }

  .section-heading {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #000;
    margin: 0;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.2rem;
  }

  .value-card {
    position: relative;
    border-radius: 24px;
    background: rgba(255, 255, 255, 0.3);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    overflow: hidden;
    box-shadow: 
      0 8px 32px rgba(0,0,0,0.02),
      0 0 0 0.5px rgba(0,0,0,0.02) inset,
      0 1px 0 rgba(255,255,255,0.7) inset;
    transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.3s ease;
  }

  .value-card:hover {
    transform: translateY(-4px);
    box-shadow: 
      0 16px 40px rgba(0,0,0,0.05),
      0 0 0 0.5px rgba(0,0,0,0.01) inset,
      0 1px 0 rgba(255,255,255,0.9) inset;
  }

  .card-border {
    position: absolute;
    inset: 0;
    pointer-events: none;
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.5);
    z-index: 2;
  }

  .card-effects {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
    border-radius: 24px;
  }

  .card-spotlight {
    position: absolute;
    inset: 0;
    opacity: 0;
    background: radial-gradient(300px circle at var(--mx, 0px) var(--my, 0px), rgba(0,0,0,0.04) 0%, rgba(255,255,255,0.2) 60%, transparent 100%);
    transition: opacity 0.4s ease;
  }

  .value-card:hover .card-spotlight {
    opacity: 1;
  }

  .card-sweep {
    position: absolute;
    top: 0;
    left: -150%;
    width: 50%;
    height: 100%;
    background: linear-gradient(
      to right,
      rgba(255, 255, 255, 0) 0%,
      rgba(255, 255, 255, 0.25) 50%,
      rgba(255, 255, 255, 0) 100%
    );
    transform: skewX(-25deg);
    pointer-events: none;
    transition: none;
    z-index: 1;
  }

  .value-card:hover .card-sweep,
  .team-card:hover .card-sweep {
    animation: shine 1.2s cubic-bezier(0.25, 1, 0.5, 1);
  }

  @keyframes shine {
    100% {
      left: 150%;
    }
  }

  .card-info {
    position: relative;
    z-index: 2;
    padding: 2.2rem;
  }

  .value-title {
    font-size: 1.25rem;
    font-weight: 700;
    color: #000;
    margin: 0 0 0.75rem;
    letter-spacing: -0.02em;
  }

  .value-desc {
    font-size: 0.88rem;
    color: rgba(0,0,0,0.6);
    line-height: 1.6;
    margin: 0;
  }

  /* Widgets nested in value cards */
  .card-visual {
    height: 110px;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 14px;
    background: rgba(255, 255, 255, 0.35);
    border: 1px solid rgba(0, 0, 0, 0.03);
    overflow: hidden;
  }

  .value-widget {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Engineering Mini-Terminal */
  .engineering-widget .widget-terminal {
    font-family: monospace;
    font-size: 0.65rem;
    color: rgba(0,0,0,0.5);
    width: 85%;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    text-align: left;
  }

  .widget-terminal .success {
    color: #2b7a4b;
  }

  /* Design Canvas Mockup */
  .design-widget .design-canvas {
    position: relative;
    width: 80px;
    height: 50px;
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 6px;
    background: rgba(255,255,255,0.4);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .design-circle-pulsing {
    position: absolute;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: rgba(0,0,0,0.15);
    left: 14px;
    top: 18px;
    animation: pulse 2s infinite ease-in-out;
  }

  .design-box {
    position: absolute;
    width: 16px;
    height: 16px;
    background: rgba(0,0,0,0.06);
    border: 1.5px stroke rgba(0,0,0,0.2);
    right: 14px;
    top: 16px;
  }

  .design-connector-line {
    position: absolute;
    width: 25px;
    height: 1px;
    background: rgba(0,0,0,0.1);
    left: 28px;
    top: 25px;
  }

  @keyframes pulse {
    0%, 100% { transform: scale(1); opacity: 0.8; }
    50% { transform: scale(1.25); opacity: 0.4; }
  }

  /* Transparency node styling */
  .glowing-node {
    animation: glowAnimation 3s infinite ease-in-out;
  }

  @keyframes glowAnimation {
    0%, 100% { stroke: rgba(0,0,0,0.8); fill: #F0EFEA; }
    50% { stroke: rgba(0,0,0,0.2); fill: rgba(255,255,255,0.9); }
  }

  /* ========================================
     TEAM SECTION
     ======================================== */
  .team-section {
    position: relative;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 3rem;
  }

  .team-card {
    position: relative;
    border-radius: 28px;
    background: rgba(255, 255, 255, 0.32);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    overflow: hidden;
    box-shadow: 
      0 10px 35px rgba(0,0,0,0.03),
      0 0 0 0.5px rgba(0,0,0,0.02) inset,
      0 1px 0 rgba(255,255,255,0.7) inset;
    transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.3s ease;
  }

  .team-card:hover {
    transform: translateY(-4px);
    box-shadow: 
      0 18px 45px rgba(0,0,0,0.06),
      0 0 0 0.5px rgba(0,0,0,0.01) inset,
      0 1px 0 rgba(255,255,255,0.85) inset;
  }

  .team-card:hover .card-spotlight {
    opacity: 1;
  }

  .team-inner {
    position: relative;
    z-index: 2;
    padding: 3rem;
    display: flex;
    gap: 2.2rem;
    align-items: center;
  }

  .avatar-container {
    flex-shrink: 0;
  }

  .avatar-gradient {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    position: relative;
    border: 1px solid rgba(255, 255, 255, 0.8);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.05);
  }

  .avatar-eng {
    background: linear-gradient(135deg, #FFB74D 0%, #FF8A65 100%);
  }

  .avatar-design {
    background: linear-gradient(135deg, #a1a1a1 0%, #e0e0e0 100%);
  }

  .avatar-initials {
    font-size: 1.6rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    color: #fff;
    text-shadow: 0 1px 2px rgba(0,0,0,0.08);
  }

  .team-info {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .team-name {
    font-size: 1.35rem;
    font-weight: 800;
    color: #000;
    margin: 0;
    letter-spacing: -0.03em;
  }

  .team-role {
    font-size: 0.82rem;
    font-weight: 600;
    color: rgba(0, 0, 0, 0.4);
    letter-spacing: 0.02em;
    text-transform: uppercase;
  }

  .team-bio {
