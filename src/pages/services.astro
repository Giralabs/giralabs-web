  <!-- ==================== I18N + INTERACTION SCRIPTS ==================== -->
  <script define:vars={{ translations: { es: translations['es'], en: translations['en'] } }}>
    let currentLang = document.documentElement.lang || 'es';

    function applyLang(lang) {
      currentLang = lang;
      const T = translations[lang];
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        if (T[key] !== undefined) {
          if (key === 'how_title' || key === 'sd_title') {
            el.innerHTML = T[key].replace(/\n/g, '<br/>');
          } else if (T[key].includes('<') || key === 'hero_tagline') {
            el.innerHTML = T[key];
          } else {
            el.textContent = T[key];
          }
        }
      });
      document.documentElement.lang = lang;
      document.title = T.meta_title + " | " + T.services_meta_title;
    }

    // Detect and apply saved language on load, or browser settings if not saved
    let initialLang = 'es';
    const savedLang = localStorage.getItem('giralabs-lang');
    if (savedLang && (savedLang === 'es' || savedLang === 'en')) {
      initialLang = savedLang;
    } else {
      const browserLang = navigator.language || navigator.userLanguage;
      if (browserLang && !browserLang.toLowerCase().startsWith('es')) {
        initialLang = 'en';
      }
    }
    applyLang(initialLang);

    // Listen to navbar's language changes
    document.addEventListener('giralabs:lang', (e) => {
      applyLang(e.detail.lang);
    });

    // Spotlight mouse tracking for advanced glass cards
    document.querySelectorAll('.service-glass-card').forEach(card => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        card.style.setProperty('--mx', x + 'px');
        card.style.setProperty('--my', y + 'px');
      });
    });

    // Handle hash scrolling on page load
    window.addEventListener('load', () => {
      if (window.location.hash) {
        const target = document.querySelector(window.location.hash);
        if (target) {
          setTimeout(() => {
            target.scrollIntoView({ behavior: 'smooth', block: 'center' });
          }, 300);
        }
      }
    });

    // Trigger visual scroll animations
    const revealEls = document.querySelectorAll('.reveal, .reveal-stagger');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          // Add active class to cards inside stagger container to fire widget loops
          if (entry.target.classList.contains('reveal-stagger')) {
            entry.target.querySelectorAll('.service-block').forEach(block => {
              block.classList.add('is-active');
            });
          }
        }
      });
    }, { threshold: 0.01, rootMargin: '0px 0px -40px 0px' });
    revealEls.forEach(el => observer.observe(el));
  </script>

