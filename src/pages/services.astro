  .timeline-step {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    padding: 0.65rem 0.8rem;
    border-radius: 12px;
    min-width: 74px;
    box-shadow: 0 2px 8px rgba(0,0,0,0.02);
  }

  .step-num {
    font-size: 0.68rem;
    font-weight: 700;
