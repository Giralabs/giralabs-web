    font-size: 0.62rem;
    color: rgba(0, 0, 0, 0.75);
    font-weight: 500;
  }

  .timeline-connector {
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 100%;
    height: 10px;
    z-index: 1;
  }

  .connector-progress {
    stroke-dasharray: 140;
    stroke-dashoffset: 140;
  }

  .service-block.is-active .timeline-step.step-1 { animation: step1Pulse 4s infinite ease-in-out; }
  .service-block.is-active .timeline-step.step-2 { animation: step2Pulse 4s infinite ease-in-out; }
  .service-block.is-active .timeline-step.step-3 { animation: step3Pulse 4s infinite ease-in-out; }
  .service-block.is-active .connector-progress { animation: lineProgress 4s infinite ease-in-out; }

  @keyframes step1Pulse {
    0%, 100% { border-color: rgba(0, 0, 0, 0.08); transform: translateY(0); }
    12%, 40% { border-color: rgba(0, 0, 0, 0.25); transform: translateY(-4px); }
