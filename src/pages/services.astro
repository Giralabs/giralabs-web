  @keyframes step2Pulse {
    0%, 12%, 100% { border-color: rgba(0, 0, 0, 0.08); transform: translateY(0); }
    24%, 52% { border-color: rgba(0, 0, 0, 0.25); transform: translateY(-4px); }
  }

  @keyframes step3Pulse {
    0%, 24%, 100% {
      border-color: rgba(0, 0, 0, 0.08);
      transform: translateY(0);
      box-shadow: none;
      background: #fff;
    }
