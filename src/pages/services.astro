---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { translations } from '../i18n/translations';
import CTAContact from '../components/CTAContact.astro';
import Footer from '../components/Footer.astro';

const langParam = Astro.url.searchParams.get('lang');
let lang = 'es';

if (langParam === 'es' || langParam === 'en') {
  lang = langParam;
}

const T = translations[lang];
---

<Layout
  title={`${T.meta_title} | ${T.services_meta_title}`}
  description={T.services_meta_description}
  lang={lang}
>
  <!-- Global dot-grid background -->
  <div class="grid-bg" aria-hidden="true"></div>
  
  <!-- Ambient glowing blobs specific to services -->
  <div class="ambient-glow glow-top" aria-hidden="true"></div>
  <div class="ambient-glow glow-bottom" aria-hidden="true"></div>

  <!-- Navbar -->
  <Navbar lang={lang} />

  <!-- ==================== HERO HEADER ==================== -->
  <header class="services-hero reveal">
    <div class="hero-inner">
      <span class="hero-eyebrow" data-i18n="sd_eyebrow">{T.sd_eyebrow}</span>
      <h1 class="hero-title" data-i18n="services_page_title">{T.services_page_title}</h1>
      <p class="hero-subtitle" data-i18n="services_page_subtitle">{T.services_page_subtitle}</p>
    </div>
  </header>

  <!-- ==================== SERVICES LIST ==================== -->
  <main class="services-container">
    <div class="services-flow reveal-stagger">

      <!-- SERVICE 01: Creación de aplicaciones móviles -->
      <section class="service-block" id="service-block-1">
        <div class="service-glass-card">
          <div class="service-card-effects">
            <div class="service-spotlight"></div>
            <div class="service-sweep"></div>
            <div class="service-card-glow service-card-glow-1"></div>
            <div class="service-card-glow service-card-glow-2"></div>
          </div>
          <div class="service-card-border"></div>
          <div class="service-card-shadow"></div>
          <div class="service-card-info">
            <div class="service-header">
              <span class="service-tag tag-discovery" data-i18n="service_1_tag">{T.service_1_tag}</span>
            </div>
            <h2 class="service-title" data-i18n="service_1_title">{T.service_1_title}</h2>
            <p class="service-desc" data-i18n="service_1_desc">{T.service_1_desc}</p>
            
            <div class="service-includes-panel">
              <h4 class="includes-title" data-i18n="services_included">{T.services_included}</h4>
              <ul class="includes-list">
                <li>
                  <svg class="check-icon" viewBox="0 0 24 24" width="16" height="16" stroke="var(--discovery-color-1)" stroke-width="2.5" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                  <span data-i18n="service_1_feature_1">{T.service_1_feature_1}</span>
                </li>
                <li>
                  <svg class="check-icon" viewBox="0 0 24 24" width="16" height="16" stroke="var(--discovery-color-1)" stroke-width="2.5" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                  <span data-i18n="service_1_feature_2">{T.service_1_feature_2}</span>
                </li>
                <li>
                  <svg class="check-icon" viewBox="0 0 24 24" width="16" height="16" stroke="var(--discovery-color-1)" stroke-width="2.5" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                  <span data-i18n="service_1_feature_3">{T.service_1_feature_3}</span>
                </li>
              </ul>
            </div>
            <div class="service-actions">
              <a href="/contact" class="service-btn btn-discovery" data-i18n="services_page_cta">{T.services_page_cta}</a>
              <a href="/service/mobile-apps" class="service-details-link">
                <span data-i18n="service_details_title">{T.service_details_title}</span>
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
            </div>
          </div>

          <div class="service-card-visual">
            <!-- Widget: App Mockup -->
            <div class="app-mockup">
              <div class="mockup-screen">
                <div class="mockup-header">
                  <div class="mockup-avatar">
                    <span class="notif-ping"></span>
                  </div>
                  <div class="mockup-title-bar"></div>
                </div>
                <div class="mockup-card active-card">
                  <div class="mockup-card-img"></div>
                  <div class="mockup-card-text"></div>
                </div>
                <div class="mockup-card">
                  <div class="mockup-card-text-short"></div>
                </div>
              </div>
              <div class="floating-badge">99%</div>
            </div>
          </div>
        </div>
      </section>

      <!-- SERVICE 02: Creación de páginas web -->
      <section class="service-block service-reverse" id="service-block-2">
        <div class="service-glass-card">
          <div class="service-card-effects">
            <div class="service-spotlight"></div>
            <div class="service-sweep"></div>
            <div class="service-card-glow service-card-glow-1"></div>
            <div class="service-card-glow service-card-glow-2"></div>
          </div>
          <div class="service-card-border"></div>
          <div class="service-card-shadow"></div>
          <div class="service-card-info">
            <div class="service-header">
              <span class="service-tag tag-design" data-i18n="service_2_tag">{T.service_2_tag}</span>
            </div>
            <h2 class="service-title" data-i18n="service_2_title">{T.service_2_title}</h2>
            <p class="service-desc" data-i18n="service_2_desc">{T.service_2_desc}</p>
            
            <div class="service-includes-panel">
              <h4 class="includes-title" data-i18n="services_included">{T.services_included}</h4>
              <ul class="includes-list">
                <li>
                  <svg class="check-icon" viewBox="0 0 24 24" width="16" height="16" stroke="var(--design-color-1)" stroke-width="2.5" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                  <span data-i18n="service_2_feature_1">{T.service_2_feature_1}</span>
                </li>
                <li>
                  <svg class="check-icon" viewBox="0 0 24 24" width="16" height="16" stroke="var(--design-color-1)" stroke-width="2.5" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                  <span data-i18n="service_2_feature_2">{T.service_2_feature_2}</span>
                </li>
                <li>
                  <svg class="check-icon" viewBox="0 0 24 24" width="16" height="16" stroke="var(--design-color-1)" stroke-width="2.5" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                  <span data-i18n="service_2_feature_3">{T.service_2_feature_3}</span>
                </li>
              </ul>
            </div>
            <div class="service-actions">
              <a href="/contact" class="service-btn btn-design" data-i18n="services_page_cta">{T.services_page_cta}</a>
              <a href="/service/web-development" class="service-details-link">
                <span data-i18n="service_details_title">{T.service_details_title}</span>
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
            </div>
          </div>

          <div class="service-card-visual">
            <!-- Widget: Viewport Resizer -->
            <div class="viewport-resizer">
              <div class="resizer-browser">
                <div class="browser-header">
                  <span class="browser-dot"></span>
                  <span class="browser-dot"></span>
                  <span class="browser-dot"></span>
                </div>
                <div class="browser-body">
                  <div class="browser-hero"></div>
                  <div class="browser-grid">
                    <div class="grid-box"></div>
                    <div class="grid-box"></div>
                    <div class="grid-box"></div>
                  </div>
                </div>
              </div>
              <div class="resizer-handle">
                <svg viewBox="0 0 24 24" width="8" height="8" fill="currentColor">
                  <path d="M8 5h2v14H8V5zm6 0h2v14h-2V5z"/>
                </svg>
              </div>
              <div class="resizer-cursor">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="currentColor">
                  <path d="M4.5 3v15.2l4.2-4.2 3.1 7.3 2.6-1.1-3.1-7.3 5.7-.4L4.5 3z"/>
                </svg>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- SERVICE 03: Digitalización de empresas y software a medida -->
      <section class="service-block" id="service-block-3">
        <div class="service-glass-card">
          <div class="service-card-effects">
            <div class="service-spotlight"></div>
            <div class="service-sweep"></div>
            <div class="service-card-glow service-card-glow-1"></div>
            <div class="service-card-glow service-card-glow-2"></div>
          </div>
          <div class="service-card-border"></div>
          <div class="service-card-shadow"></div>
          <div class="service-card-info">
            <div class="service-header">
              <span class="service-tag tag-engineering" data-i18n="service_3_tag">{T.service_3_tag}</span>
            </div>
            <h2 class="service-title" data-i18n="service_3_title">{T.service_3_title}</h2>
            <p class="service-desc" data-i18n="service_3_desc">{T.service_3_desc}</p>
            
            <div class="service-includes-panel">
              <h4 class="includes-title" data-i18n="services_included">{T.services_included}</h4>
              <ul class="includes-list">
                <li>
                  <svg class="check-icon" viewBox="0 0 24 24" width="16" height="16" stroke="var(--engineering-color-1)" stroke-width="2.5" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                  <span data-i18n="service_3_feature_1">{T.service_3_feature_1}</span>
                </li>
                <li>
                  <svg class="check-icon" viewBox="0 0 24 24" width="16" height="16" stroke="var(--engineering-color-1)" stroke-width="2.5" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                  <span data-i18n="service_3_feature_2">{T.service_3_feature_2}</span>
                </li>
                <li>
                  <svg class="check-icon" viewBox="0 0 24 24" width="16" height="16" stroke="var(--engineering-color-1)" stroke-width="2.5" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                  <span data-i18n="service_3_feature_3">{T.service_3_feature_3}</span>
                </li>
              </ul>
            </div>
            <div class="service-actions">
              <a href="/contact" class="service-btn btn-engineering" data-i18n="services_page_cta">{T.services_page_cta}</a>
              <a href="/service/business-digitalization" class="service-details-link">
                <span data-i18n="service_details_title">{T.service_details_title}</span>
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
            </div>
          </div>

          <div class="service-card-visual">
            <!-- Widget: Data Pipeline -->
            <div class="data-pipeline">
              <div class="pipeline-source">
                <span class="pipeline-file">CSV</span>
                <span class="pipeline-file">XLS</span>
              </div>
              <div class="pipeline-flow">
                <div class="flow-path-line"></div>
                <div class="flow-dot"></div>
                <div class="flow-dot"></div>
                <div class="flow-dot"></div>
              </div>
              <div class="pipeline-target">
                <div class="dashboard-bar bar-1"></div>
                <div class="dashboard-bar bar-2"></div>
                <div class="dashboard-bar bar-3"></div>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- SERVICE 04: Creación de tiendas online -->
      <section class="service-block service-reverse" id="service-block-4">
        <div class="service-glass-card">
          <div class="service-card-effects">
            <div class="service-spotlight"></div>
            <div class="service-sweep"></div>
            <div class="service-card-glow service-card-glow-1"></div>
            <div class="service-card-glow service-card-glow-2"></div>
          </div>
          <div class="service-card-border"></div>
          <div class="service-card-shadow"></div>
          <div class="service-card-info">
            <div class="service-header">
              <span class="service-tag tag-growth" data-i18n="service_4_tag">{T.service_4_tag}</span>
            </div>
            <h2 class="service-title" data-i18n="service_4_title">{T.service_4_title}</h2>
            <p class="service-desc" data-i18n="service_4_desc">{T.service_4_desc}</p>
            
            <div class="service-includes-panel">
              <h4 class="includes-title" data-i18n="services_included">{T.services_included}</h4>
              <ul class="includes-list">
                <li>
                  <svg class="check-icon" viewBox="0 0 24 24" width="16" height="16" stroke="var(--growth-color-1)" stroke-width="2.5" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                  <span data-i18n="service_4_feature_1">{T.service_4_feature_1}</span>
                </li>
                <li>
                  <svg class="check-icon" viewBox="0 0 24 24" width="16" height="16" stroke="var(--growth-color-1)" stroke-width="2.5" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                  <span data-i18n="service_4_feature_2">{T.service_4_feature_2}</span>
                </li>
                <li>
                  <svg class="check-icon" viewBox="0 0 24 24" width="16" height="16" stroke="var(--growth-color-1)" stroke-width="2.5" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                  <span data-i18n="service_4_feature_3">{T.service_4_feature_3}</span>
                </li>
              </ul>
            </div>
            <div class="service-actions">
              <a href="/contact" class="service-btn btn-growth" data-i18n="services_page_cta">{T.services_page_cta}</a>
              <a href="/service/online-stores" class="service-details-link">
                <span data-i18n="service_details_title">{T.service_details_title}</span>
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
            </div>
          </div>

          <div class="service-card-visual">
            <!-- Widget: Store Checkout -->
            <div class="store-checkout">
              <div class="product-card-preview">
                <div class="product-img"></div>
                <div class="product-info">
                  <div class="product-price">€49</div>
                  <div class="add-to-cart-btn">
                    <span class="btn-icon">+</span>
                    <span class="plus-one">+1</span>
                  </div>
                </div>
              </div>
              <div class="cart-pill">
                <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="9" cy="21" r="1"></circle>
                  <circle cx="20" cy="21" r="1"></circle>
                  <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                </svg>
                <span class="cart-count">
                  <span class="count-zero">0</span>
                  <span class="count-one">1</span>
                </span>
              </div>
            </div>
          </div>
        </div>
      </section>

      <!-- SERVICE 05: Creación de software personalizado -->
      <section class="service-block" id="service-block-5">
        <div class="service-glass-card">
            <div class="service-card-effects">
              <div class="service-spotlight"></div>
              <div class="service-sweep"></div>
              <div class="service-card-glow service-card-glow-1"></div>
              <div class="service-card-glow service-card-glow-2"></div>
            </div>
            <div class="service-card-border"></div>
            <div class="service-card-shadow"></div>
            <div class="service-card-info">
              <div class="service-header">
                <span class="service-tag tag-ai" data-i18n="service_5_tag">{T.service_5_tag}</span>
              </div>
              <h2 class="service-title" data-i18n="service_5_title">{T.service_5_title}</h2>
              <p class="service-desc" data-i18n="service_5_desc">{T.service_5_desc}</p>
              
              <div class="service-includes-panel">
                <h4 class="includes-title" data-i18n="services_included">{T.services_included}</h4>
                <ul class="includes-list">
                  <li>
                    <svg class="check-icon" viewBox="0 0 24 24" width="16" height="16" stroke="var(--ai-color-1)" stroke-width="2.5" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                    <span data-i18n="service_5_feature_1">{T.service_5_feature_1}</span>
                  </li>
                  <li>
                    <svg class="check-icon" viewBox="0 0 24 24" width="16" height="16" stroke="var(--ai-color-1)" stroke-width="2.5" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                    <span data-i18n="service_5_feature_2">{T.service_5_feature_2}</span>
                  </li>
                  <li>
                    <svg class="check-icon" viewBox="0 0 24 24" width="16" height="16" stroke="var(--ai-color-1)" stroke-width="2.5" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                    <span data-i18n="service_5_feature_3">{T.service_5_feature_3}</span>
                  </li>
                </ul>
              </div>
              <div class="service-actions">
                <a href="/contact" class="service-btn btn-ai" data-i18n="services_page_cta">{T.services_page_cta}</a>
                <a href="/service/custom-software" class="service-details-link">
                  <span data-i18n="service_details_title">{T.service_details_title}</span>
                  <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="5" y1="12" x2="19" y2="12"></line>
                    <polyline points="12 5 19 12 12 19"></polyline>
                  </svg>
                </a>
              </div>
            </div>

            <div class="service-card-visual">
              <!-- Widget: API Blocks -->
              <div class="api-blocks">
                <div class="api-card">
                  <div class="api-window-header">
                    <span class="api-window-dot win-r"></span>
                    <span class="api-window-dot win-y"></span>
                    <span class="api-window-dot win-g"></span>
                  </div>
                  <div class="api-header">
                    <span class="api-method">GET</span>
                    <span class="api-path">/v1/users</span>
                  </div>
                  <div class="api-payload">{`{ "active": true }`}</div>
                </div>
                <div class="api-logs">
                  <span class="log-line">200 OK - 12ms</span>
                  <span class="log-line">200 OK - 8ms</span>
                </div>
              </div>
            </div>
        </div>
      </section>

      <!-- SERVICE 06: Implementación de IA en las aplicaciones -->
      <section class="service-block service-reverse" id="service-block-6">
        <div class="service-glass-card">
          <div class="service-card-effects">
            <div class="service-spotlight"></div>
            <div class="service-sweep"></div>
            <div class="service-card-glow service-card-glow-1"></div>
            <div class="service-card-glow service-card-glow-2"></div>
          </div>
          <div class="service-card-border"></div>
          <div class="service-card-shadow"></div>
          <div class="service-card-info">
            <div class="service-header">
              <span class="service-tag tag-team" data-i18n="service_6_tag">{T.service_6_tag}</span>
            </div>
            <h2 class="service-title" data-i18n="service_6_title">{T.service_6_title}</h2>
            <p class="service-desc" data-i18n="service_6_desc">{T.service_6_desc}</p>
            
            <div class="service-includes-panel">
              <h4 class="includes-title" data-i18n="services_included">{T.services_included}</h4>
              <ul class="includes-list">
                <li>
                  <svg class="check-icon" viewBox="0 0 24 24" width="16" height="16" stroke="var(--team-color-1)" stroke-width="2.5" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                  <span data-i18n="service_6_feature_1">{T.service_6_feature_1}</span>
                </li>
                <li>
                  <svg class="check-icon" viewBox="0 0 24 24" width="16" height="16" stroke="var(--team-color-1)" stroke-width="2.5" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                  <span data-i18n="service_6_feature_2">{T.service_6_feature_2}</span>
                </li>
                <li>
                  <svg class="check-icon" viewBox="0 0 24 24" width="16" height="16" stroke="var(--team-color-1)" stroke-width="2.5" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                  <span data-i18n="service_6_feature_3">{T.service_6_feature_3}</span>
                </li>
              </ul>
            </div>
            <div class="service-actions">
              <a href="/contact" class="service-btn btn-team" data-i18n="services_page_cta">{T.services_page_cta}</a>
              <a href="/service/ai-integration" class="service-details-link">
                <span data-i18n="service_details_title">{T.service_details_title}</span>
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                  <line x1="5" y1="12" x2="19" y2="12"></line>
                  <polyline points="12 5 19 12 12 19"></polyline>
                </svg>
              </a>
            </div>
          </div>

          <div class="service-card-visual">
            <!-- Widget: Neural Net -->
            <div class="neural-net">
              <svg viewBox="0 0 140 100" class="neural-svg">
                <!-- Layer 1 -->
                <circle cx="20" cy="30" r="4" class="node input-node"></circle>
                <circle cx="20" cy="50" r="4" class="node input-node"></circle>
                <circle cx="20" cy="70" r="4" class="node input-node"></circle>
                
                <!-- Layer 2 -->
                <circle cx="70" cy="20" r="4" class="node hidden-node"></circle>
                <circle cx="70" cy="40" r="4" class="node hidden-node"></circle>
                <circle cx="70" cy="60" r="4" class="node hidden-node"></circle>
                <circle cx="70" cy="80" r="4" class="node hidden-node"></circle>
                
                <!-- Layer 3 -->
                <circle cx="120" cy="40" r="4" class="node output-node"></circle>
                <circle cx="120" cy="60" r="4" class="node output-node"></circle>
                
                <!-- Connections -->
                <path d="M 20 30 L 70 20 M 20 30 L 70 40 M 20 30 L 70 60" class="conn-line"></path>
                <path d="M 20 50 L 70 20 M 20 50 L 70 40 M 20 50 L 70 60 M 20 50 L 70 80" class="conn-line"></path>
                <path d="M 20 70 L 70 40 M 20 70 L 70 60 M 20 70 L 70 80" class="conn-line"></path>
                <path d="M 70 20 L 120 40 M 70 20 L 120 60" class="conn-line"></path>
                <path d="M 70 40 L 120 40 M 70 40 L 120 60" class="conn-line"></path>
                <path d="M 70 60 L 120 40 M 70 60 L 120 60" class="conn-line"></path>
                <path d="M 70 80 L 120 40 M 70 80 L 120 60" class="conn-line"></path>

                <!-- Multiple signal paths -->
                <path d="M 20 50 L 70 40 L 120 40" class="signal-line signal-line-1"></path>
                <path d="M 20 70 L 70 60 L 120 60" class="signal-line signal-line-2"></path>
