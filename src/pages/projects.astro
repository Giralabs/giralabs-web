---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { translations } from '../i18n/translations';
import CTAContact from '../components/CTAContact.astro';
import Footer from '../components/Footer.astro';
import gipsiImg from '../assets/projects/gipsi_barber.webp';
import nexusImg from '../assets/projects/nexus.png';
import rewindtvImg from '../assets/projects/rewindtv.webp';
import auramoviesImg from '../assets/projects/auramovies.webp';

const acceptLang = Astro.request.headers.get('accept-language');
const langParam = Astro.url.searchParams.get('lang');
let lang = 'es';

if (langParam === 'es' || langParam === 'en') {
  lang = langParam;
} else if (acceptLang && !acceptLang.toLowerCase().startsWith('es')) {
  lang = 'en';
}

const T = translations[lang];

const projects = [
  {
    slug: 'nexus',
    image: nexusImg.src,
    tag: 'E-commerce',
    title: 'Nexus',
    desc: 'Marketplace moderno de comercio electrónico y ofertas en tiempo real',
    year: '2024',
    platform: 'Web · iOS · Android',
    tech: ['Flutter', 'MongoDB', 'Go'],
    accentRgb: '20,20,20',
    class: 'proj-wide',
  },
  {
    slug: 'gipsi',
    image: gipsiImg.src,
    tag: 'App móvil',
    title: 'Gipsi',
    desc: 'Gestión inteligente de citas y reservas para barberías',
    year: '2025',
    platform: 'iOS · Android',
    tech: ['Flutter', 'Go', 'Supabase'],
    accentRgb: '0,0,0',
    class: 'proj-narrow',
  },
  {
    slug: 'auramovies',
    image: auramoviesImg.src,
    tag: 'Red Social',
    title: 'AuraMovies',
    desc: 'La red social definitiva para amantes del cine y series',
    year: '2025',
    platform: 'iOS · Android',
    tech: ['Flutter', 'Go', 'MongoDB'],
    accentRgb: '10,10,10',
    class: 'proj-narrow',
    bgScale: '115%',
  },
  {
    slug: 'rewind-tv',
    image: rewindtvImg.src,
    tag: 'Entretenimiento',
    title: 'Rewind TV',
    desc: 'Backlog inteligente de películas y series para organizar tu colección',
    year: '2026',
    platform: 'iOS · Android',
    tech: ['Flutter', 'Supabase', 'Swift'],
    accentRgb: '0,0,0',
    class: 'proj-wide',
  },
];
---

<Layout
  title={`${T.meta_title} | ${T.projects_meta_title}`}
  description={T.projects_meta_description}
  lang={lang}
>
  <!-- Dot grid background -->
  <div class="grid-bg" aria-hidden="true"></div>
  <!-- Ambient blobs -->
  <div class="ambient-glow glow-top" aria-hidden="true"></div>
  <div class="ambient-glow glow-bottom" aria-hidden="true"></div>

  <Navbar lang={lang} />

  <!-- ==================== HERO ==================== -->
  <header class="projects-hero reveal">
    <div class="hero-inner">
      <span class="hero-eyebrow" data-i18n="projects_eyebrow">{T.projects_eyebrow}</span>
      <h1 class="hero-title" data-i18n="projects_title">
        {lang === 'en' ? (
          <>Projects that<br/><em>speak for themselves.</em></>
        ) : (
          <>Proyectos que<br/><em>hablan por sí solos.</em></>
        )}
      </h1>
      <p class="hero-sub" data-i18n="projects_sub">{T.projects_sub}</p>
    </div>
  </header>

  <!-- ==================== PROJECT GRID ==================== -->
  <main class="projects-main">
    <div class="projects-grid reveal-stagger">
      {projects.map((proj, i) => {
        let keyNum = '1';
        if (proj.slug === 'nexus') keyNum = '2';
        else if (proj.slug === 'gipsi') keyNum = '1';
        else if (proj.slug === 'rewind-tv') keyNum = '3';
        else if (proj.slug === 'auramovies') keyNum = '4';

        const tagKey = `project_${keyNum}_tag` as const;
        const descKey = `project_${keyNum}_desc` as const;
        const titleKey = `project_${keyNum}_title` as const;

        return (
          <a
            href={`/project/${proj.slug}`}
            class={`proj-card ${proj.class}`}
            style={`--img: url('${proj.image}'); --accent-rgb: ${proj.accentRgb};${proj.bgScale ? ` --bg-scale: ${proj.bgScale};` : ''}${proj.bgPos ? ` --bg-pos: ${proj.bgPos};` : ''}`}
            id={`proj-card-${i + 1}`}
            aria-label={lang === 'en' ? `View project ${T[titleKey]}` : `Ver proyecto ${T[titleKey]}`}
          >
            <!-- glass shimmer -->
            <div class="proj-shimmer" aria-hidden="true"></div>

            <!-- Media Showcase -->
            <div class="proj-media" aria-hidden="true">
              <div class="proj-media-inner"></div>
            </div>

            <!-- Info Details -->
            <div class="proj-info">
              <div class="proj-top">
                <div class="proj-tags-wrap">
                  <span class="proj-tag" data-i18n={tagKey}>{T[tagKey]}</span>
                  <span class="proj-year">{proj.year}</span>
                </div>
                <div class="proj-arrow-btn" aria-hidden="true">
                  <svg viewBox="0 0 14 14" fill="none" width="14" height="14">
                    <path d="M2 12L12 2M12 2H5M12 2v7" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                </div>
              </div>

              <div class="proj-bottom">
                <h2 class="proj-title" data-i18n={titleKey}>{T[titleKey]}</h2>
                <p class="proj-desc" data-i18n={descKey}>{T[descKey]}</p>
                <div class="proj-meta">
                  <span class="proj-platform">{proj.platform}</span>
                  <div class="proj-tech-chips">
                    {proj.tech.map(t => (
                      <span class="proj-chip">{t}</span>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </a>
        );
      })}
    </div>
  </main>

  <CTAContact lang={lang} />
  <Footer lang={lang} />

  <!-- ==================== SCRIPTS ==================== -->
  <script define:vars={{ translations: { es: translations['es'], en: translations['en'] } }}>
    // Reveal observer
    const revealEls = document.querySelectorAll('.reveal, .reveal-stagger');
    const obs = new IntersectionObserver((entries) => {
      entries.forEach(e => {
        if (e.isIntersecting) e.target.classList.add('visible');
      });
    }, { threshold: 0.08, rootMargin: '0px 0px -40px 0px' });
    revealEls.forEach(el => obs.observe(el));

    // Mouse-parallax effect on cards
    document.querySelectorAll('.proj-card').forEach(card => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = ((e.clientX - rect.left) / rect.width - 0.5) * 10;
        const y = ((e.clientY - rect.top) / rect.height - 0.5) * 10;
        card.style.setProperty('--rx', `${y}deg`);
        card.style.setProperty('--ry', `${-x}deg`);
        card.style.setProperty('--mx', `${e.clientX - rect.left}px`);
        card.style.setProperty('--my', `${e.clientY - rect.top}px`);
      });
      card.addEventListener('mouseleave', () => {
        card.style.setProperty('--rx', '0deg');
        card.style.setProperty('--ry', '0deg');
      });
    });

    let currentLang = document.documentElement.lang || 'es';

    function applyLang(lang) {
      currentLang = lang;
      const T = translations[lang];
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        if (T[key] !== undefined) {
          if (key === 'projects_title') {
            el.innerHTML = lang === 'en' ? 'Projects that<br/><em>speak for themselves.</em>' : 'Proyectos que<br/><em>hablan por sí solos.</em>';
          } else {
            el.textContent = T[key];
          }
        }
      });
      document.documentElement.lang = lang;
      document.title = T.meta_title + " | " + T.projects_meta_title;
    }

    // Detect and apply saved language on load, or browser settings if not saved
    let initialLang = 'es';
    const savedLang = localStorage.getItem('giralabs-lang');
    if (savedLang && (savedLang === 'es' || savedLang === 'en')) {
      initialLang = savedLang;
    } else {
      const browserLang = navigator.language || navigator.userLanguage;
      if (browserLang && !browserLang.toLowerCase().startsWith('es')) {
        initialLang = 'en';
      }
    }
    applyLang(initialLang);

    // Listen to navbar's language changes
    document.addEventListener('giralabs:lang', (e) => {
      applyLang(e.detail.lang);
    });
  </script>
</Layout>

<style>
  /* ---- BACKGROUND ---- */
  .grid-bg {
    position: fixed;
    inset: 0;
    background-image: radial-gradient(rgba(0,0,0,0.05) 1.2px, transparent 1.2px);
    background-size: 32px 32px;
    pointer-events: none;
    z-index: 0;
    opacity: 0.65;
  }

  .ambient-glow {
    position: fixed;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    filter: blur(120px);
    pointer-events: none;
    z-index: 0;
  }

  .glow-top {
    top: -200px;
    right: -100px;
    background: radial-gradient(circle, rgba(255,210,150,0.15) 0%, transparent 65%);
    opacity: 0.06;
  }

  .glow-bottom {
    bottom: -250px;
    left: -150px;
    background: radial-gradient(circle, rgba(0,240,255,0.1) 0%, transparent 70%);
    opacity: 0.05;
  }

  /* ---- HERO ---- */
  .projects-hero {
    position: relative;
    z-index: 1;
    padding: 10rem 2rem 3rem;
    text-align: center;
  }

  .hero-inner {
    max-width: 780px;
    margin: 0 auto;
  }

  .hero-eyebrow {
    display: inline-block;
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(0,0,0,0.38);
    margin-bottom: 1.4rem;
  }

  .hero-title {
    font-size: clamp(2.4rem, 6.5vw, 4.2rem);
    font-weight: 800;
    letter-spacing: -0.05em;
    line-height: 1.1;
    color: #000;
    margin: 0 0 1.4rem;
  }

  .hero-title em {
    font-style: italic;
    font-weight: 300;
    color: rgba(0,0,0,0.55);
  }

  .hero-sub {
    font-size: clamp(0.95rem, 2.2vw, 1.1rem);
    color: rgba(0,0,0,0.55);
    line-height: 1.65;
    margin: 0;
    max-width: 560px;
    margin-inline: auto;
  }

  /* ---- PROJECTS MAIN ---- */
  .projects-main {
    position: relative;
    z-index: 1;
    padding: 0 2rem 8rem;
  }

  /* ---- PROJECTS GRID ---- */
  .projects-grid {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    grid-auto-rows: 520px;
    gap: 24px;
  }

  .proj-wide  { grid-column: span 7; }
  .proj-narrow { grid-column: span 5; }

  /* ---- PROJECT CARD ---- */
  .proj-card {
    position: relative;
    border-radius: 28px;
    overflow: hidden;
    display: flex;
    background: rgba(255, 255, 255, 0.45);
    backdrop-filter: blur(20px) saturate(160%);
    -webkit-backdrop-filter: blur(20px) saturate(160%);
    border: 1px solid rgba(255, 255, 255, 0.75);
    box-shadow: 
      0 4px 30px rgba(0, 0, 0, 0.015), 
      0 1px 0 rgba(255, 255, 255, 0.8) inset;
    cursor: pointer;
    text-decoration: none;
    transform-style: preserve-3d;
    transform: perspective(1000px) rotateX(var(--rx,0deg)) rotateY(var(--ry,0deg));
    transition:
      transform 0.6s cubic-bezier(0.25, 1, 0.5, 1),
      box-shadow 0.6s cubic-bezier(0.25, 1, 0.5, 1),
      background-color 0.6s cubic-bezier(0.25, 1, 0.5, 1),
      border-color 0.6s cubic-bezier(0.25, 1, 0.5, 1);
    will-change: transform;
  }

  .proj-card:hover {
    background: rgba(255, 255, 255, 0.7);
    border-color: rgba(255, 255, 255, 0.95);
    box-shadow: 
      0 30px 60px rgba(0, 0, 0, 0.06), 
      0 8px 20px rgba(0, 0, 0, 0.02),
      0 1px 0 rgba(255, 255, 255, 0.9) inset;
  }

  /* Wide card layout */
  .proj-wide {
    flex-direction: row;
  }

  .proj-wide .proj-info {
    width: 48%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 2.5rem;
    box-sizing: border-box;
    height: 100%;
  }

  .proj-wide .proj-media {
    width: 52%;
    height: 100%;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
  }

  .proj-wide .proj-media-inner {
    position: absolute;
    bottom: -25px;
    right: -10px;
    width: 105%;
    height: 85%;
    border-radius: 20px 0 0 0;
    background-image: var(--img);
    background-size: var(--bg-scale, cover);
    background-position: var(--bg-pos, center);
    box-shadow: -15px -10px 40px rgba(0, 0, 0, 0.06);
    border-top: 1.5px solid rgba(255, 255, 255, 0.85);
    border-left: 1.5px solid rgba(255, 255, 255, 0.85);
    transform: rotate(-2.5deg) translate(5px, 5px);
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.6s ease;
  }

  .proj-wide:hover .proj-media-inner {
    transform: rotate(-0.5deg) translate(0, 0) scale(1.02);
    box-shadow: -20px -15px 50px rgba(0, 0, 0, 0.09);
  }

  /* Narrow card layout */
  .proj-narrow {
    flex-direction: column;
  }

  .proj-narrow .proj-media {
    width: 100%;
    height: 48%;
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .proj-narrow .proj-media-inner {
    position: absolute;
    bottom: -20px;
    width: 86%;
    height: 100%;
    border-radius: 16px 16px 0 0;
    background-image: var(--img);
    background-size: var(--bg-scale, cover);
    background-position: var(--bg-pos, top center);
    box-shadow: 0 -10px 30px rgba(0, 0, 0, 0.05);
    border-top: 1.5px solid rgba(255, 255, 255, 0.85);
    border-left: 1.5px solid rgba(255, 255, 255, 0.85);
    border-right: 1.5px solid rgba(255, 255, 255, 0.85);
    transform: translateY(8px);
    transition: transform 0.6s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.6s ease;
  }

  .proj-narrow:hover .proj-media-inner {
    transform: translateY(0) scale(1.025);
    box-shadow: 0 -15px 40px rgba(0, 0, 0, 0.08);
  }

  .proj-narrow .proj-info {
    width: 100%;
    height: 52%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 2rem;
    box-sizing: border-box;
  }

  /* Shimmer effect for light glass */
  .proj-shimmer {
    position: absolute;
    inset: 0;
    opacity: 0;
    z-index: 2;
    border-radius: 28px;
    background: radial-gradient(280px circle at var(--mx, 50%) var(--my, 50%), rgba(255,255,255,0.45) 0%, transparent 70%);
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .proj-card:hover .proj-shimmer {
    opacity: 1;
  }

  /* Info elements */
  .proj-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
  }

  .proj-tags-wrap {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }

  .proj-tag {
    display: inline-flex;
    align-items: center;
    padding: 0.35rem 0.85rem;
    border-radius: 100px;
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: rgba(0, 0, 0, 0.8);
    background: rgba(0, 0, 0, 0.04);
    border: 1px solid rgba(0, 0, 0, 0.06);
  }

  .proj-year {
    font-size: 0.72rem;
    font-weight: 600;
    color: rgba(0, 0, 0, 0.35);
    letter-spacing: 0.06em;
  }

  .proj-bottom {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .proj-title {
    font-size: clamp(1.5rem, 2.5vw, 2.1rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: #000;
    margin: 0;
    line-height: 1.15;
  }

  .proj-desc {
    font-size: 0.88rem;
    color: rgba(0,0,0,0.55);
    line-height: 1.5;
    margin: 0;
    max-width: 90%;
  }

  .proj-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.8rem;
    margin-top: 0.4rem;
    flex-wrap: wrap;
  }

  .proj-platform {
    font-size: 0.68rem;
    font-weight: 600;
    color: rgba(0,0,0,0.38);
    letter-spacing: 0.04em;
  }

  .proj-tech-chips {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .proj-chip {
    font-size: 0.6rem;
    font-weight: 600;
    padding: 0.2rem 0.55rem;
    border-radius: 100px;
    background: rgba(0,0,0,0.03);
    border: 1px solid rgba(0,0,0,0.05);
    color: rgba(0,0,0,0.55);
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .proj-arrow-btn {
    width: 36px;
    height: 36px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(0, 0, 0, 0.03);
    border: 1px solid rgba(0, 0, 0, 0.06);
    color: rgba(0, 0, 0, 0.5);
    transition: color 0.3s ease, background 0.3s ease, transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .proj-card:hover .proj-arrow-btn {
    color: #000;
    background: rgba(0, 0, 0, 0.07);
    transform: rotate(45deg) scale(1.08);
  }

  /* ---- RESPONSIVE ---- */
  @media (max-width: 960px) {
    .projects-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: auto;
      gap: 24px;
    }

    .proj-wide,
    .proj-narrow {
      grid-column: span 1;
      flex-direction: column;
      height: auto;
      min-height: 480px;
    }

    .proj-wide .proj-info,
    .proj-narrow .proj-info {
      width: 100%;
      height: auto;
      padding: 2rem;
    }

    .proj-wide .proj-media,
    .proj-narrow .proj-media {
      width: 100%;
      height: 240px;
    }

    .proj-wide .proj-media-inner,
    .proj-narrow .proj-media-inner {
      position: absolute;
      bottom: -15px;
      left: 50%;
      right: auto;
      transform: translateX(-50%) translateY(5px);
      width: 90%;
      height: 100%;
      border-radius: 16px 16px 0 0;
      border-right: 1.5px solid rgba(255, 255, 255, 0.85);
    }
    
    .proj-wide:hover .proj-media-inner,
    .proj-narrow:hover .proj-media-inner {
      transform: translateX(-50%) translateY(0) scale(1.025);
    }
  }

  @media (max-width: 600px) {
    .projects-hero { padding: 8rem 1.5rem 2.5rem; }
    .projects-main { padding: 0 1.2rem 5rem; }
    .proj-card { border-radius: 20px; }
    .proj-wide .proj-info,
    .proj-narrow .proj-info { padding: 1.5rem; }
    .proj-wide .proj-media,
    .proj-narrow .proj-media { height: 200px; }
  }
</style>
