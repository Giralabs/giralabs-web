  <!-- Interaction / Tab Switcher Client Script -->
  <script define:vars={{ translations: { es: translations['es'], en: translations['en'] }, index, nextIndex }}>
    let currentLang = document.documentElement.lang || 'es';
    let currentPhase = 1;

    function updatePhaseText(lang, phaseNum) {
      const T = translations[lang];
      const prefix = `service_${index}_phase_${phaseNum}`;
      
      const tagDisplay = document.getElementById('phase-tag-display');
      const titleDisplay = document.getElementById('phase-title-display');
      const descDisplay = document.getElementById('phase-desc-display');
      const detailsDisplay = document.getElementById('phase-details-display');
      const f1Display = document.getElementById('phase-feature-1-display');
      const f2Display = document.getElementById('phase-feature-2-display');
      const f3Display = document.getElementById('phase-feature-3-display');

      if (tagDisplay) { tagDisplay.textContent = T[`${prefix}_tag`] || ''; tagDisplay.setAttribute('data-i18n', `${prefix}_tag`); }
      if (titleDisplay) { titleDisplay.textContent = T[`${prefix}_title`] || ''; titleDisplay.setAttribute('data-i18n', `${prefix}_title`); }
      if (descDisplay) { descDisplay.textContent = T[`${prefix}_desc`] || ''; descDisplay.setAttribute('data-i18n', `${prefix}_desc`); }
      if (detailsDisplay) { detailsDisplay.textContent = T[`${prefix}_details`] || ''; detailsDisplay.setAttribute('data-i18n', `${prefix}_details`); }
      if (f1Display) { f1Display.textContent = T[`${prefix}_feature_1`] || ''; f1Display.setAttribute('data-i18n', `${prefix}_feature_1`); }
      if (f2Display) { f2Display.textContent = T[`${prefix}_feature_2`] || ''; f2Display.setAttribute('data-i18n', `${prefix}_feature_2`); }
      if (f3Display) { f3Display.textContent = T[`${prefix}_feature_3`] || ''; f3Display.setAttribute('data-i18n', `${prefix}_feature_3`); }
      
      const numDisplay = document.getElementById('phase-num-display');
      if (numDisplay) numDisplay.textContent = `0${phaseNum}`;
    }

    function applyLang(lang) {
      currentLang = lang;
      const T = translations[lang];
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        if (T[key] !== undefined) {
          if (key === 'how_title' || key === 'sd_title') {
            el.innerHTML = T[key].replace(/\n/g, '<br/>');
          } else if (T[key].includes('<') || key === 'hero_tagline') {
            el.innerHTML = T[key];
          } else {
            el.textContent = T[key];
          }
        }
      });
      document.documentElement.lang = lang;
      
      const titleKey = `service_${index}_title`;
      document.title = T.meta_title + " | " + T[titleKey];

      updatePhaseText(lang, currentPhase);
    }

    // Tab switcher events
    const tabButtons = document.querySelectorAll('.tab-btn');
    const infoPanel = document.querySelector('.details-info-panel');
    const widgets = document.querySelectorAll('.phase-widget');

    tabButtons.forEach(btn => {
      btn.addEventListener('click', () => {
        const targetPhase = parseInt(btn.getAttribute('data-phase'), 10);
        if (targetPhase === currentPhase) return;

        if (infoPanel) infoPanel.classList.add('fade-out');

        widgets.forEach(w => w.classList.remove('active'));
        const activeWidget = document.querySelector(`.phase-widget.widget-p${targetPhase}`);
        if (activeWidget) activeWidget.classList.add('active');

        tabButtons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');

        currentPhase = targetPhase;

        setTimeout(() => {
          updatePhaseText(currentLang, currentPhase);
          if (infoPanel) infoPanel.classList.remove('fade-out');
        }, 220);
      });
    });

    let initialLang = 'es';
    const savedLang = localStorage.getItem('giralabs-lang');
    if (savedLang && (savedLang === 'es' || savedLang === 'en')) {
      initialLang = savedLang;
    } else {
      const browserLang = navigator.language || navigator.userLanguage;
      if (browserLang && !browserLang.toLowerCase().startsWith('es')) {
        initialLang = 'en';
      }
    }
    applyLang(initialLang);

    document.addEventListener('giralabs:lang', (e) => applyLang(e.detail.lang));

    document.querySelectorAll('.service-glass-card').forEach(card => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        card.style.setProperty('--mx', (e.clientX - rect.left) + 'px');
        card.style.setProperty('--my', (e.clientY - rect.top) + 'px');
      });
    });

    const revealEls = document.querySelectorAll('.reveal');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
          if (entry.target.classList.contains('details-grid')) {
            entry.target.classList.add('is-active');
          }
        }
      });
    }, { threshold: 0.05 });
    revealEls.forEach(el => observer.observe(el));
  </script>
</Layout>

