---
import Layout from '../../layouts/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import { translations } from '../../i18n/translations';
import Footer from '../../components/Footer.astro';

export const prerender = true;

export async function getStaticPaths() {
  return [
    { params: { slug: 'mobile-apps' }, props: { index: 1, nextSlug: 'web-development', nextIndex: 2 } },
    { params: { slug: 'web-development' }, props: { index: 2, nextSlug: 'business-digitalization', nextIndex: 3 } },
    { params: { slug: 'business-digitalization' }, props: { index: 3, nextSlug: 'online-stores', nextIndex: 4 } },
    { params: { slug: 'online-stores' }, props: { index: 4, nextSlug: 'custom-software', nextIndex: 5 } },
    { params: { slug: 'custom-software' }, props: { index: 5, nextSlug: 'ai-integration', nextIndex: 6 } },
    { params: { slug: 'ai-integration' }, props: { index: 6, nextSlug: 'mobile-apps', nextIndex: 1 } },
  ];
}

const { slug } = Astro.params;
const { index, nextSlug, nextIndex } = Astro.props;

const defaultLang = 'es';
const T = translations[defaultLang];

const tagKey = `service_${index}_tag` as const;
const titleKey = `service_${index}_title` as const;
const detailsKey = `service_${index}_details` as const;

const p1TitleKey = `service_${index}_phase_1_title` as const;
const p1TagKey = `service_${index}_phase_1_tag` as const;
const p1DescKey = `service_${index}_phase_1_desc` as const;
const p1DetailsKey = `service_${index}_phase_1_details` as const;
const p1F1Key = `service_${index}_phase_1_feature_1` as const;
const p1F2Key = `service_${index}_phase_1_feature_2` as const;
const p1F3Key = `service_${index}_phase_1_feature_3` as const;

const nextTitleKey = `service_${nextIndex}_title` as const;
---

<Layout
  title={`${T.meta_title} | ${T[titleKey]}`}
  description={T.meta_description}
  lang={defaultLang}
>
  <div class="grid-bg" aria-hidden="true"></div>
  <div class="ambient-glow glow-top" aria-hidden="true"></div>
  <div class="ambient-glow glow-bottom" aria-hidden="true"></div>

  <Navbar lang={defaultLang} />

  <!-- Breadcrumb -->
  <nav class="details-breadcrumb reveal">
    <div class="breadcrumb-inner">
      <a href="/services" class="breadcrumb-back">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="19" y1="12" x2="5" y2="12"></line>
          <polyline points="12 19 5 12 12 5"></polyline>
        </svg>
        <span data-i18n="service_back_list">{T.service_back_list}</span>
      </a>
    </div>
  </nav>

  <!-- Main Details Page Container -->
  <main class="details-container">
    <header class="details-hero reveal">
      <div class="hero-inner">
        <span class="hero-eyebrow" data-i18n={tagKey}>{T[tagKey]}</span>
        <h1 class="hero-title" data-i18n={titleKey}>{T[titleKey]}</h1>
        <p class="hero-subtitle" data-i18n={detailsKey}>{T[detailsKey]}</p>
      </div>
    </header>

    <!-- Dashboard Widget Section -->
    <div class="dashboard-section reveal">
      
      <!-- Phase tabs selector -->
      <div class="dashboard-tabs">
        {[1, 2, 3, 4, 5].map((num) => {
          const tabTagKey = `service_${index}_phase_${num}_tag` as keyof typeof T;
          return (
            <button class={`tab-btn ${num === 1 ? 'active' : ''}`} data-phase={num} type="button">
              <span class="tab-num">0{num}</span>
              <span class="tab-label" data-i18n={`service_${index}_phase_${num}_tag`}>{T[tabTagKey]}</span>
            </button>
          );
        })}
      </div>

      <!-- Content Grid -->
      <div class="details-grid reveal is-active" id={`service-block-${index}`}>
        
        <!-- Info Column -->
        <section class="details-info-panel fade-transition">
          <div class="details-header">
            <span class="details-num" id="phase-num-display">01</span>
            <span class="details-tag" id="phase-tag-display" data-i18n={p1TagKey}>{T[p1TagKey]}</span>
          </div>
          <h2 class="details-title" id="phase-title-display" data-i18n={p1TitleKey}>{T[p1TitleKey]}</h2>
          <p class="details-desc" id="phase-desc-display" data-i18n={p1DescKey}>{T[p1DescKey]}</p>
          <p class="details-subdesc" id="phase-details-display" data-i18n={p1DetailsKey}>{T[p1DetailsKey]}</p>

          <div class="details-includes-panel">
            <h4 class="includes-title" data-i18n="services_included">{T.services_included}</h4>
            <ul class="includes-list">
              <li>
                <svg class="check-icon" viewBox="0 0 24 24" width="16" height="16" stroke="var(--accent-color-1)" stroke-width="2.5" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                <span id="phase-feature-1-display" data-i18n={p1F1Key}>{T[p1F1Key]}</span>
              </li>
              <li>
                <svg class="check-icon" viewBox="0 0 24 24" width="16" height="16" stroke="var(--accent-color-1)" stroke-width="2.5" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                <span id="phase-feature-2-display" data-i18n={p1F2Key}>{T[p1F2Key]}</span>
              </li>
              <li>
                <svg class="check-icon" viewBox="0 0 24 24" width="16" height="16" stroke="var(--accent-color-1)" stroke-width="2.5" fill="none"><polyline points="20 6 9 17 4 12"/></svg>
                <span id="phase-feature-3-display" data-i18n={p1F3Key}>{T[p1F3Key]}</span>
              </li>
            </ul>
          </div>

          <a href="/contact" class="details-btn" data-i18n="services_page_cta">{T.services_page_cta}</a>
        </section>

        <!-- Premium Visual Glass Card Column -->
        <section class="details-visual-panel">
          <div class="service-glass-card">
            <div class="service-card-effects">
              <div class="service-spotlight"></div>
              <div class="service-card-glow service-card-glow-1"></div>
              <div class="service-card-glow service-card-glow-2"></div>
            </div>
            <div class="service-card-border"></div>
            <div class="service-card-shadow"></div>

            <div class="widget-wrapper">
              <!-- S1 (Mobile App) animations -->
              {index === 1 && (
                <>
                  <div class="phase-widget widget-p1 active">
                    <div class="discovery-timeline">
                      <div class="timeline-step step-1"><span class="step-num">W1</span><span class="step-lbl">Scope</span></div>
                      <div class="timeline-step step-2"><span class="step-num">W2</span><span class="step-lbl">Proto</span></div>
                      <div class="timeline-step step-3"><span class="step-num">MVP</span><span class="step-lbl">€ Fixed</span></div>
                      <svg class="timeline-connector" viewBox="0 0 160 10" preserveAspectRatio="none">
                        <path d="M 10 5 L 115 5" stroke="rgba(0,0,0,0.05)" stroke-width="2" stroke-dasharray="3,3" />
                        <path d="M 10 5 L 115 5" stroke="var(--discovery-color-1)" stroke-width="2" class="connector-progress" />
                      </svg>
                    </div>
                  </div>

                  <div class="phase-widget widget-p2">
                    <div class="design-workspace">
                      <div class="grid-overlay"></div>
                      <div class="mock-device">
                        <div class="mock-button"><span class="btn-glow"></span><span class="btn-text">Interact</span></div>
                        <div class="mock-elements"><div class="mock-el el-1"></div><div class="mock-el el-2"></div></div>
                      </div>
                      <div class="design-cursor">
                        <svg viewBox="0 0 24 24" width="16" height="16" fill="black"><path d="M4.5 3v15.2l4.2-4.2 3.1 7.3 2.6-1.1-3.1-7.3 5.7-.4L4.5 3z"/></svg>
                      </div>
                    </div>
                  </div>

                  <div class="phase-widget widget-p3">
                    <div class="engineering-console">
                      <div class="speed-dial">
                        <svg viewBox="0 0 100 100" width="80" height="80">
                          <circle cx="50" cy="50" r="40" stroke="rgba(0,0,0,0.04)" stroke-width="5" fill="none" />
                          <circle cx="50" cy="50" r="40" stroke="var(--engineering-color-1)" stroke-width="5" fill="none" stroke-dasharray="251.2" stroke-dashoffset="251.2" class="dial-progress" />
                        </svg>
                        <div class="dial-label"><span class="dial-val">16w</span><span class="dial-sub">Deploy</span></div>
                      </div>
                      <div class="console-terminal">
                        <div class="terminal-dots"><span class="t-dot t-dot-r"></span><span class="t-dot t-dot-y"></span><span class="t-dot t-dot-g"></span></div>
                        <div class="terminal-lines">
                          <span class="term-l l-1">> init flutter app...</span>
                          <span class="term-l l-2">> backend: go on gke</span>
                          <span class="term-l l-3">> status: active 99.9%</span>
                        </div>
                      </div>
                    </div>
                  </div>

                  <div class="phase-widget widget-p4">
                    <div class="growth-chart">
                      <div class="chart-bg-grid"></div>
                      <svg viewBox="0 0 180 90" class="chart-svg">
                        <path d="M 10 80 Q 55 68 95 48 T 170 15 L 170 80 Z" fill="rgba(0,0,0,0.05)" class="chart-area" />
                        <path d="M 10 80 Q 55 68 95 48 T 170 15" fill="none" stroke="var(--growth-color-1)" stroke-width="2.5" stroke-linecap="round" class="chart-line" />
                        <circle cx="170" cy="15" r="4" fill="#fff" stroke="var(--growth-color-1)" stroke-width="2" class="chart-dot" />
                      </svg>
                      <div class="chart-labels"><span>Día 1</span><span>1M+ Users</span></div>
                    </div>
                  </div>

                  <div class="phase-widget widget-p5">
                    <div class="ai-chat">
                      <div class="chat-row chat-user">
                        <div class="chat-avatar">U</div>
                        <div class="chat-bubble">Integrar soporte empresa</div>
                      </div>
                      <div class="chat-row chat-loader">
                        <div class="chat-avatar ai-avatar">AI</div>
                        <div class="chat-bubble dots-bubble"><span class="dot-pulse"></span><span class="dot-pulse"></span><span class="dot-pulse"></span></div>
                      </div>
                      <div class="chat-row chat-ai">
                        <div class="chat-avatar ai-avatar">AI</div>
                        <div class="chat-bubble result-bubble">
                          <div class="result-badge">4h → 8s</div>
                          <div class="result-text">Agente RAG Activo</div>
                        </div>
                      </div>
                    </div>
                  </div>
                </>
              )}

              <!-- S2 (Web Development) animations -->
              {index === 2 && (
                <>
                  {/* Phase 1: SEO & Planning Strategy */}
                  <div class="phase-widget widget-p1 active">
                    <div class="discovery-timeline">
                      <div class="timeline-step step-1"><span class="step-num">SEO</span><span class="step-lbl">Research</span></div>
                      <div class="timeline-step step-2"><span class="step-num">Map</span><span class="step-lbl">Structure</span></div>
                      <div class="timeline-step step-3"><span class="step-num">CRO</span><span class="step-lbl">Strategy</span></div>
                      <svg class="timeline-connector" viewBox="0 0 160 10" preserveAspectRatio="none">
                        <path d="M 10 5 L 115 5" stroke="rgba(0,0,0,0.05)" stroke-width="2" stroke-dasharray="3,3" />
                        <path d="M 10 5 L 115 5" stroke="var(--discovery-color-1)" stroke-width="2" class="connector-progress" />
                      </svg>
                    </div>
                  </div>

                  {/* Phase 2: Wireframe/Layout */}
                  <div class="phase-widget widget-p2">
                    <div class="wireframe-widget">
                      <div class="wire-grid-overlay"></div>
                      <div class="wire-box-header"></div>
                      <div class="wire-box-sidebar"></div>
                      <div class="wire-box-content">
                        <div class="wire-line-1"></div>
                        <div class="wire-line-2"></div>
                        <div class="wire-blocks">
                          <div class="wire-block-item"></div>
                          <div class="wire-block-item"></div>
                        </div>
                      </div>
                    </div>
                  </div>

                  {/* Phase 3: Terminal/Code typing */}
                  <div class="phase-widget widget-p3">
                    <div class="code-terminal-widget">
                      <div class="t-dots"><span class="tdtd r-td"></span><span class="tdtd y-td"></span><span class="tdtd g-td"></span></div>
                      <div class="terminal-body-code">
                        <div class="code-line c-l-1">> npm run build</div>
                        <div class="code-line c-l-2">> compiling packages...</div>
                        <div class="code-line c-l-3">> done in 452ms <span class="blinking-cursor">_</span></div>
                      </div>
                    </div>
                  </div>

                  {/* Phase 4: Speedometer/Gauge check */}
                  <div class="phase-widget widget-p4">
                    <div class="gauge-widget">
                      <div class="gauge-ring">
                        <svg viewBox="0 0 100 100" width="90" height="90">
                          <circle cx="50" cy="50" r="42" stroke="rgba(0,0,0,0.04)" stroke-width="6" fill="none" />
                          <circle cx="50" cy="50" r="42" stroke="var(--accent-color-1)" stroke-width="6" stroke-dasharray="264" stroke-dashoffset="264" class="gauge-progress" fill="none" />
                        </svg>
                        <div class="gauge-center"><span class="gauge-val">99%</span><span class="gauge-lbl">QA</span></div>
                      </div>
                    </div>
                  </div>

                  {/* Phase 5: Web Deployment & SSL */}
                  <div class="phase-widget widget-p5">
                    <div class="cloud-deploy-widget">
                      <div class="cloud-icon-wrapper">
                        <svg viewBox="0 0 24 24" width="36" height="36" fill="none" stroke="var(--accent-color-1)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
                          <circle cx="12" cy="12" r="10"></circle>
                          <line x1="2" y1="12" x2="22" y2="12"></line>
                          <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"></path>
                        </svg>
                        <div class="deploy-signal"></div>
                      </div>
                      <div class="server-node node-left">WWW</div>
                      <div class="server-node node-right">HTTPS</div>
                    </div>
                  </div>
                </>
              )}

              <!-- S3 (Business Digitalization) animations -->
              {index === 3 && (
                <>
                  {/* Phase 1: Process Audit Checklist */}
                  <div class="phase-widget widget-p1 active">
                    <div class="audit-checklist">
                      <div class="checklist-item item-1">
                        <svg class="check-box-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="var(--accent-color-1)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                        <span class="checklist-txt">Audit current workflows</span>
                      </div>
                      <div class="checklist-item item-2">
                        <svg class="check-box-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="var(--accent-color-1)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                        <span class="checklist-txt">Identify bottlenecks</span>
                      </div>
                      <div class="checklist-item item-3">
                        <svg class="check-box-icon" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="var(--accent-color-1)" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                          <polyline points="20 6 9 17 4 12"></polyline>
                        </svg>
                        <span class="checklist-txt">Design optimization plan</span>
                      </div>
                    </div>
                  </div>

                  {/* Phase 2: Architecture Schema */}
                  <div class="phase-widget widget-p2">
                    <div class="architecture-schema">
                      <div class="schema-node db-node">DB</div>
                      <div class="schema-lines">
                        <svg viewBox="0 0 100 60" class="schema-svg" preserveAspectRatio="none">
                          <path d="M 50 10 L 20 45" stroke="rgba(0,0,0,0.1)" stroke-width="1.5" />
                          <path d="M 50 10 L 80 45" stroke="rgba(0,0,0,0.1)" stroke-width="1.5" />
                          <circle cx="50" cy="10" r="3" fill="var(--accent-color-1)" class="schema-packet packet-1" />
                          <circle cx="50" cy="10" r="3" fill="var(--accent-color-1)" class="schema-packet packet-2" />
                        </svg>
                      </div>
                      <div class="schema-clients">
                        <div class="schema-node client-node-1">API</div>
                        <div class="schema-node client-node-2">Web</div>
                      </div>
                    </div>
                  </div>

                  {/* Phase 3: API Connector Widget */}
                  <div class="phase-widget widget-p3">
                    <div class="api-connector-widget">
                      <div class="api-client-box">Client</div>
                      <div class="api-pipe">
                        <div class="api-line"></div>
                        <div class="api-packet packet-req">GET</div>
                        <div class="api-packet packet-res">200</div>
                      </div>
                      <div class="api-server-box">Server</div>
                    </div>
                  </div>

                  {/* Phase 4: Training & Onboarding */}
                  <div class="phase-widget widget-p4">
                    <div class="training-team-widget">
                      <div class="member-row row-1">
                        <span class="member-label">Admin</span>
                        <div class="progress-bar-container"><div class="progress-bar bar-1"></div></div>
                      </div>
                      <div class="member-row row-2">
                        <span class="member-label">Manager</span>
                        <div class="progress-bar-container"><div class="progress-bar bar-2"></div></div>
                      </div>
                      <div class="member-row row-3">
                        <span class="member-label">Staff</span>
                        <div class="progress-bar-container"><div class="progress-bar bar-3"></div></div>
                      </div>
                    </div>
                  </div>

                  {/* Phase 5: System Monitor Uptime */}
                  <div class="phase-widget widget-p5">
                    <div class="system-monitor">
                      <div class="monitor-header">
                        <span class="monitor-pulse"></span>
                        <span class="monitor-status">SYSTEM ACTIVE</span>
                      </div>
                      <div class="monitor-stats">
                        <div class="stat-box">
                          <span class="stat-val">99.9%</span>
                          <span class="stat-lbl">Uptime</span>
                        </div>
                        <div class="stat-box">
                          <span class="stat-val">34ms</span>
                          <span class="stat-lbl">Latency</span>
                        </div>
                      </div>
                    </div>
                  </div>
                </>
              )}

              <!-- S4 (Online Stores) animations -->
              {index === 4 && (
                <>
                  {/* Phase 1: Catalog Architecture & Variants */}
                  <div class="phase-widget widget-p1 active">
                    <div class="catalog-card-widget">
                      <div class="catalog-product-preview">
                        <div class="product-image-skeleton"></div>
                        <div class="product-info-lines">
                          <span class="product-name-line"></span>
                          <span class="product-price-line"></span>
                        </div>
                      </div>
                      <div class="catalog-variants">
                        <div class="variant-sizes">
                          <span class="size-btn">S</span>
                          <span class="size-btn active">M</span>
                          <span class="size-btn">L</span>
                        </div>
                        <div class="variant-colors">
                          <span class="color-dot dot-active"></span>
                          <span class="color-dot"></span>
                        </div>
                      </div>
                    </div>
                  </div>

                  {/* Phase 2: Funnel Flow Conversion */}
                  <div class="phase-widget widget-p2">
                    <div class="funnel-flow-widget">
                      <svg viewBox="0 0 100 80" class="funnel-svg">
                        {/* Funnel shape outline */}
                        <path d="M 10 5 L 90 5 L 60 55 L 40 55 Z" fill="none" stroke="rgba(0,0,0,0.08)" stroke-width="1.5" />
                        <line x1="40" y1="55" x2="40" y2="75" stroke="rgba(0,0,0,0.08)" stroke-width="1.5" />
                        <line x1="60" y1="55" x2="60" y2="75" stroke="rgba(0,0,0,0.08)" stroke-width="1.5" />
                        
                        {/* Flowing dots representing conversions */}
                        <circle cx="50" cy="8" r="2.5" fill="var(--accent-color-1)" class="funnel-dot dot-1" />
                        <circle cx="35" cy="15" r="2.5" fill="var(--accent-color-1)" class="funnel-dot dot-2" />
                        <circle cx="65" cy="15" r="2.5" fill="var(--accent-color-1)" class="funnel-dot dot-3" />
                        <circle cx="50" cy="35" r="2.5" fill="var(--accent-color-1)" class="funnel-dot dot-4" />
                        <circle cx="50" cy="65" r="2.5" fill="var(--accent-color-2)" class="funnel-dot dot-success" />
                      </svg>
                      <div class="funnel-labels">
                        <span class="funnel-lbl-top">Add to Cart</span>
                        <span class="funnel-lbl-bot">Purchase</span>
                      </div>
                    </div>
                  </div>

                  {/* Phase 3: Payment & Shipping */}
                  <div class="phase-widget widget-p3">
                    <div class="payment-shipping-widget">
                      <div class="credit-card-mock">
                        <div class="card-chip"></div>
                        <div class="card-number">•••• •••• •••• 4242</div>
                        <div class="card-status-container">
                          <span class="card-status-spinner"></span>
                          <span class="card-status-text">Processing</span>
                        </div>
                      </div>
                      <div class="shipping-truck-box">
                        <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="var(--accent-color-1)" stroke-width="2">
                          <rect x="1" y="3" width="15" height="13"></rect>
                          <polygon points="16 8 20 8 23 11 23 16 16 16 16 8"></polygon>
                          <circle cx="5.5" cy="18.5" r="2.5"></circle>
                          <circle cx="18.5" cy="18.5" r="2.5"></circle>
                        </svg>
                        <span class="shipping-status">In Transit</span>
                      </div>
                    </div>
                  </div>

                  {/* Phase 4: Checkout Testing & QA Checklist */}
                  <div class="phase-widget widget-p4">
                    <div class="checkout-qa-widget">
                      <div class="qa-item item-1">
                        <span class="qa-indicator"></span>
                        <span class="qa-lbl">Payment Gateway</span>
                      </div>
                      <div class="qa-item item-2">
                        <span class="qa-indicator"></span>
                        <span class="qa-lbl">Stock Calculation</span>
                      </div>
                      <div class="qa-item item-3">
                        <span class="qa-indicator"></span>
                        <span class="qa-lbl">Email Confirmation</span>
                      </div>
                    </div>
                  </div>

                  {/* Phase 5: Launch & Conversion Live stats */}
                  <div class="phase-widget widget-p5">
                    <div class="conversion-live-widget">
                      <div class="conversion-card">
                        <span class="live-badge">LIVE SALES</span>
                        <span class="conversion-rate">+3.8%</span>
                        <span class="conversion-sub">Conversion Rate</span>
                      </div>
                      <div class="sales-chart-mini">
                        <svg viewBox="0 0 100 40" class="chart-mini-svg">
                          <path d="M 0 35 Q 25 30 50 15 T 100 5 L 100 40 L 0 40 Z" fill="rgba(var(--accent-rgb-1), 0.05)" />
                          <path d="M 0 35 Q 25 30 50 15 T 100 5" fill="none" stroke="var(--accent-color-1)" stroke-width="2" class="chart-line-draw" />
                        </svg>
                      </div>
                    </div>
                  </div>
                </>
              )}

              <!-- S5 (Custom Software) animations -->
              {index === 5 && (
                <>
                  {/* Phase 1: Kanban Board Sprint Scoping */}
                  <div class="phase-widget widget-p1 active">
                    <div class="kanban-board-widget">
                      <div class="kanban-col">
                        <span class="kanban-col-title">Todo</span>
                        <div class="kanban-card card-todo">User Auth</div>
                      </div>
                      <div class="kanban-col">
