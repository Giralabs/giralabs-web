---
import Layout from '../layouts/Layout.astro';
import Navbar from '../components/Navbar.astro';
import { translations } from '../i18n/translations';
import Footer from '../components/Footer.astro';

const acceptLang = Astro.request.headers.get('accept-language');
const langParam = Astro.url.searchParams.get('lang');
let lang = 'es';

if (langParam === 'es' || langParam === 'en') {
  lang = langParam;
} else if (acceptLang && !acceptLang.toLowerCase().startsWith('es')) {
  lang = 'en';
}

const T = translations[lang];
---

<Layout
  title={`${T.meta_title} | ${T.error_404_meta_title}`}
  description={T.error_404_meta_description}
  lang={lang}
>
  <!-- Global dot-grid background -->
  <div class="grid-bg" aria-hidden="true"></div>
  
  <!-- Ambient glowing blobs -->
  <div class="ambient-glow glow-top" aria-hidden="true"></div>
  <div class="ambient-glow glow-bottom" aria-hidden="true"></div>

  <!-- Navbar -->
  <Navbar lang={lang} />

  <!-- ==================== 404 ERROR CONTENT ==================== -->
  <main class="error-container">
    <section class="error-wrapper reveal">
      <div class="error-glass-card">
        <div class="card-border"></div>
        <div class="card-effects">
          <div class="card-spotlight"></div>
          <div class="card-sweep"></div>
        </div>

        <div class="card-inner">
          <!-- Widget: CSS Glitching 404 Graphic -->
          <div class="widget-container">
            <div class="glitch-widget">
              <span class="glitch-number shadow-text" aria-hidden="true">404</span>
              <span class="glitch-number main-text">404</span>
              <span class="glitch-number accent-text" aria-hidden="true">404</span>
            </div>
            <div class="radar-ping"></div>
          </div>

          <h1 class="error-subtitle" data-i18n="error_404_subtitle">{T.error_404_subtitle}</h1>
          <p class="error-desc" data-i18n="error_404_desc">{T.error_404_desc}</p>
          
          <div class="error-actions">
            <a href="/" class="cta-primary home-btn" data-i18n="error_404_btn">
              {T.error_404_btn}
            </a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer lang={lang} />

  <!-- ==================== I18N + INTERACTION SCRIPTS ==================== -->
  <script define:vars={{ translations: { es: translations['es'], en: translations['en'] } }}>
    let currentLang = document.documentElement.lang || 'es';

    function applyLang(lang) {
      currentLang = lang;
      const T = translations[lang];
      document.querySelectorAll('[data-i18n]').forEach(el => {
        const key = el.getAttribute('data-i18n');
        if (T[key] !== undefined) {
          if (key === 'how_title' || key === 'sd_title') {
            el.innerHTML = T[key].replace(/\n/g, '<br/>');
          } else if (T[key].includes('<') || key === 'hero_tagline') {
            el.innerHTML = T[key];
          } else {
            el.textContent = T[key];
          }
        }
      });
      document.documentElement.lang = lang;
      document.title = T.meta_title + " | " + T.error_404_meta_title;
    }

    // Detect and apply saved language on load, or browser settings if not saved
    let initialLang = 'es';
    const savedLang = localStorage.getItem('giralabs-lang');
    if (savedLang && (savedLang === 'es' || savedLang === 'en')) {
      initialLang = savedLang;
    } else {
      const browserLang = navigator.language || navigator.userLanguage;
      if (browserLang && !browserLang.toLowerCase().startsWith('es')) {
        initialLang = 'en';
      }
    }
    applyLang(initialLang);

    // Listen to navbar's language changes
    document.addEventListener('giralabs:lang', (e) => {
      applyLang(e.detail.lang);
    });

    // Spotlight mouse tracking for advanced glass card
    const glassCard = document.querySelector('.error-glass-card');
    if (glassCard) {
      glassCard.addEventListener('mousemove', (e) => {
        const rect = glassCard.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        glassCard.style.setProperty('--mx', x + 'px');
        glassCard.style.setProperty('--my', y + 'px');
      });
    }

    // Trigger visual scroll animations
    const revealEls = document.querySelectorAll('.reveal, .reveal-stagger');
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('visible');
        }
      });
    }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });
    revealEls.forEach(el => observer.observe(el));
  </script>
</Layout>

<style>
  /* ========================================
     GLOBAL STYLES & ACCENTS
     ======================================== */
  .grid-bg {
    position: fixed;
    inset: 0;
    background-image: radial-gradient(rgba(0,0,0,0.05) 1.2px, transparent 1.2px);
    background-size: 32px 32px;
    pointer-events: none;
    z-index: 0;
    opacity: 0.65;
  }

  /* Ambient glowing blobs */
  .ambient-glow {
    position: fixed;
    width: 600px;
    height: 600px;
    border-radius: 50%;
    filter: blur(120px);
    pointer-events: none;
    z-index: 0;
    opacity: 0.06;
  }

  .glow-top {
    top: -200px;
    right: -100px;
    background: radial-gradient(circle, rgba(255, 180, 100, 0.15) 0%, transparent 65%);
  }

  .glow-bottom {
    bottom: -250px;
    left: -150px;
    background: radial-gradient(circle, rgba(0, 200, 255, 0.1) 0%, transparent 70%);
  }

  /* ========================================
     CONTAINER LAYOUT
     ======================================== */
  .error-container {
    position: relative;
    z-index: 2;
    min-height: calc(100vh - 120px); /* Fill screen minus navbar/footer spaces */
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 8rem 2rem 5rem;
  }

  .error-wrapper {
    width: 100%;
    max-width: 580px;
  }

  .error-glass-card {
    position: relative;
    border-radius: 32px;
    background: rgba(255, 255, 255, 0.35);
    backdrop-filter: blur(24px) saturate(180%);
    -webkit-backdrop-filter: blur(24px) saturate(180%);
    overflow: hidden;
    box-shadow: 
      0 12px 40px rgba(0,0,0,0.03),
      0 0 0 0.5px rgba(0,0,0,0.02) inset,
      0 1px 0 rgba(255,255,255,0.7) inset;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), box-shadow 0.4s ease;
  }

  .error-glass-card:hover {
    transform: translateY(-4px);
    box-shadow: 
      0 18px 45px rgba(0,0,0,0.05),
      0 0 0 0.5px rgba(0,0,0,0.01) inset,
      0 1px 0 rgba(255,255,255,0.85) inset;
  }

  .card-border {
    position: absolute;
    inset: 0;
    pointer-events: none;
    border-radius: 32px;
    border: 1px solid rgba(255, 255, 255, 0.6);
    z-index: 2;
  }

  .card-effects {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    overflow: hidden;
    border-radius: 32px;
  }

  .card-spotlight {
    position: absolute;
    inset: 0;
    opacity: 0;
    background: radial-gradient(350px circle at var(--mx, 0px) var(--my, 0px), rgba(0,0,0,0.03) 0%, rgba(255,255,255,0.2) 60%, transparent 100%);
    transition: opacity 0.5s ease;
  }

  .error-glass-card:hover .card-spotlight {
    opacity: 1;
  }

  .card-sweep {
    position: absolute;
    top: 0;
    left: -150%;
    width: 50%;
    height: 100%;
    background: linear-gradient(
      to right,
      rgba(255, 255, 255, 0) 0%,
      rgba(255, 255, 255, 0.25) 50%,
      rgba(255, 255, 255, 0) 100%
    );
    transform: skewX(-25deg);
    pointer-events: none;
    transition: none;
    z-index: 1;
  }

  .error-glass-card:hover .card-sweep {
    animation: shine 1.2s cubic-bezier(0.25, 1, 0.5, 1);
  }

  @keyframes shine {
    100% {
      left: 150%;
    }
  }

  .card-inner {
    position: relative;
    z-index: 2;
    padding: 5rem 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  /* ========================================
     GLITCH 404 WIDGET
     ======================================== */
  .widget-container {
    position: relative;
    height: 100px;
    width: 100%;
    margin-bottom: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .glitch-widget {
    position: relative;
    font-size: 5.5rem;
    font-weight: 950;
    letter-spacing: -0.05em;
    line-height: 1;
    font-family: inherit;
    user-select: none;
  }

  .glitch-number {
    position: absolute;
    left: 50%;
    top: 50%;
    transform: translate(-50%, -50%);
  }

  .main-text {
    color: #000;
    z-index: 2;
  }

  .shadow-text {
    color: rgba(255, 138, 101, 0.65); /* Peach/Apricot shadow */
    z-index: 1;
    transform: translate(-53%, -48%);
    animation: glitch-left 3s infinite linear alternate-reverse;
  }

  .accent-text {
    color: rgba(107, 114, 128, 0.35); /* Grey shadow */
    z-index: 0;
    transform: translate(-47%, -52%);
    animation: glitch-right 3s infinite linear alternate-reverse;
  }

  @keyframes glitch-left {
    0%, 100% { transform: translate(-53%, -48%); }
    50% { transform: translate(-55%, -46%) skewX(-5deg); }
    80% { transform: translate(-52%, -50%); }
  }

  @keyframes glitch-right {
    0%, 100% { transform: translate(-47%, -52%); }
    50% { transform: translate(-45%, -54%) skewX(5deg); }
    80% { transform: translate(-48%, -48%); }
  }

  .radar-ping {
    position: absolute;
    width: 130px;
    height: 130px;
    border-radius: 50%;
    border: 1px solid rgba(0,0,0,0.02);
    animation: radar 4s infinite linear;
    pointer-events: none;
  }

  @keyframes radar {
    0% { transform: scale(0.6); opacity: 0; }
    30% { opacity: 0.8; }
    100% { transform: scale(1.4); opacity: 0; }
  }

  /* ========================================
     ERROR TEXTS
     ======================================== */
  .error-subtitle {
    font-size: clamp(1.4rem, 4vw, 1.8rem);
    font-weight: 800;
    color: #000;
    margin: 0 0 0.8rem;
    letter-spacing: -0.035em;
  }

  .error-desc {
    font-size: 0.95rem;
    color: rgba(0,0,0,0.55);
    line-height: 1.6;
    max-width: 440px;
    margin: 0 0 2.5rem;
  }

  .error-actions {
    display: flex;
    justify-content: center;
  }

  .home-btn {
    background: rgba(20, 20, 20, 0.82) !important;
    backdrop-filter: blur(24px) saturate(180%) !important;
    -webkit-backdrop-filter: blur(24px) saturate(180%) !important;
    border: 1px solid rgba(255, 255, 255, 0.08) !important;
    color: #fff !important;
    padding: 0.9rem 2.2rem !important;
    font-size: 0.8rem !important;
    font-weight: 600 !important;
    letter-spacing: 0.04em !important;
    border-radius: 100px !important;
    box-shadow:
      0 4px 20px rgba(0, 0, 0, 0.12),
      0 1px 0 rgba(255, 255, 255, 0.12) inset !important;
    transition: background 0.25s ease, border-color 0.25s, color 0.25s, transform 0.25s, box-shadow 0.25s !important;
  }

  .home-btn:hover {
    background: rgba(0, 0, 0, 0.95) !important;
    border-color: rgba(255, 255, 255, 0.2) !important;
    color: #fff !important;
    transform: translateY(-2px) !important;
    box-shadow:
      0 10px 28px rgba(0, 0, 0, 0.2),
      0 1px 0 rgba(255, 255, 255, 0.18) inset !important;
  }

  /* ========================================
     RESPONSIVE BREAKPOINTS
     ======================================== */
  @media (max-width: 600px) {
    .error-container { padding: 6rem 1.5rem 4rem; }
    .card-inner { padding: 4rem 2rem; }
    .glitch-widget { font-size: 4rem; }
  }
</style>
