---
export const prerender = false;
import { Image } from 'astro:assets';
import apricotLogo from '../assets/combination_marks/combinationmark_apricot_horizontal_nobackground.avif';

const token       = Astro.url.searchParams.get('token') ?? '';
const cancelledBy = (Astro.url.searchParams.get('from') ?? 'client') as 'client' | 'giralabs';
const isGiralabs  = cancelledBy === 'giralabs';

// Server-side fetch of booking info
let booking: {
  dateISO: string; time: string; name: string; email: string;
  company?: string; guests: string[]; dateFormatted: string;
} | null = null;

if (token) {
  try {
    const { getBookingByToken } = await import('../lib/bookings-store.js');
    const found = await getBookingByToken(token);
    if (found) {
      booking = {
        dateISO: found.dateISO,
        time: found.time,
        name: found.info.name,
        email: found.info.email,
        company: found.info.company,
        guests: found.info.guests,
        dateFormatted: found.info.dateFormatted ?? found.dateISO,
      };
    }
  } catch (e) {
    console.error('Cancel page lookup failed:', e);
  }
}
---
<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Cancelar reunión · Giralabs</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', -apple-system, sans-serif;
      background: #F0EFEA;
      color: #0a0a0a;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 24px 16px;
      -webkit-font-smoothing: antialiased;
    }

    /* Ambient glow */
    body::before {
      content: '';
      position: fixed;
      inset: 0;
      background: radial-gradient(ellipse 80% 50% at 50% -20%, rgba(255,255,255,0.7) 0%, transparent 70%);
      pointer-events: none;
    }

    .card {
      background: rgba(255, 255, 255, 0.4);
      border: 1px solid rgba(255, 255, 255, 0.8);
      border-radius: 24px;
      padding: 48px 44px;
      max-width: 480px;
      width: 100%;
      backdrop-filter: blur(32px);
      -webkit-backdrop-filter: blur(32px);
      position: relative;
      box-shadow: 0 10px 40px rgba(0,0,0,0.03);
    }

    .logo-img {
      width: 160px;
      height: auto;
      margin-bottom: 32px;
      display: block;
    }

    /* ── NOT FOUND state ── */
    .state-notfound .icon {
      width: 52px; height: 52px;
      background: rgba(0,0,0,0.03);
      border: 1px solid rgba(0,0,0,0.06);
      border-radius: 16px;
      display: flex; align-items: center; justify-content: center;
      color: #0a0a0a;
      margin-bottom: 24px;
    }
    .state-notfound h1 {
      font-size: 22px; font-weight: 700; letter-spacing: -0.03em;
      margin-bottom: 10px; color: #0a0a0a;
    }
    .state-notfound p { color: rgba(0,0,0,0.6); font-size: 14px; line-height: 1.65; }

    /* ── CONFIRM state ── */
    .badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      background: rgba(0,0,0,0.04);
      border: 1px solid rgba(0,0,0,0.08);
      border-radius: 100px;
      padding: 5px 14px;
      font-size: 11px; font-weight: 700;
      color: #0a0a0a;
      letter-spacing: 0.06em; text-transform: uppercase;
      margin-bottom: 24px;
    }

    .state-confirm h1 {
      font-size: 24px; font-weight: 700; letter-spacing: -0.03em;
      margin-bottom: 10px;
      color: #0a0a0a;
    }
    .state-confirm .subtitle {
      color: rgba(0,0,0,0.6); font-size: 14px; line-height: 1.65;
      margin-bottom: 28px;
    }

    .booking-details {
      background: rgba(255,255,255,0.6);
      border: 1px solid rgba(0,0,0,0.06);
      border-radius: 16px;
      padding: 20px 22px;
      margin-bottom: 28px;
    }
    .detail-row { display: flex; justify-content: space-between; padding: 8px 0; }
    .detail-row:not(:last-child) { border-bottom: 1px solid rgba(0,0,0,0.04); }
    .detail-label { font-size: 12px; color: rgba(0,0,0,0.55); font-weight: 500; }
    .detail-value { font-size: 13px; color: #0a0a0a; font-weight: 600; text-align: right; }

    .warning-box {
      display: flex;
      gap: 12px;
      align-items: flex-start;
      background: rgba(0,0,0,0.02);
      border: 1px solid rgba(0,0,0,0.08);
      border-radius: 12px;
      padding: 16px 18px;
      margin-bottom: 28px;
      font-size: 13px;
      color: rgba(0,0,0,0.65);
      line-height: 1.6;
    }
    .warning-box svg { flex-shrink: 0; color: rgba(0,0,0,0.7); margin-top: 2px; }
    .warning-box strong { color: #0a0a0a; }

    /* Web Normal Glassmorphism Button */
    .btn-action {
      width: 100%;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      background: rgba(20, 20, 20, 0.82);
      backdrop-filter: blur(24px) saturate(180%);
      -webkit-backdrop-filter: blur(24px) saturate(180%);
      color: #fff;
      border: 1px solid rgba(255, 255, 255, 0.08);
      border-radius: 12px;
      padding: 16px;
      font-size: 15px; font-weight: 700;
      cursor: pointer;
      letter-spacing: -0.01em;
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.08), 0 1px 0 rgba(255, 255, 255, 0.12) inset;
      transition: background 0.25s, transform 0.25s, box-shadow 0.25s, border-color 0.25s;
      font-family: inherit;
    }
    .btn-action:hover { 
      background: rgba(0, 0, 0, 0.95); 
      transform: translateY(-2.5px); 
      border-color: rgba(255, 255, 255, 0.2);
      box-shadow: 0 10px 28px rgba(0, 0, 0, 0.18), 0 1px 0 rgba(255, 255, 255, 0.18) inset;
    }
    .btn-action:active { transform: scale(0.98); }
    .btn-action:disabled { opacity: 0.5; cursor: not-allowed; }

    /* ── SUCCESS state ── */
    .state-success { display: none; text-align: center; }
    .state-success .check-icon {
      width: 64px; height: 64px;
      background: rgba(0,0,0,0.03);
      border: 1px solid rgba(0,0,0,0.06);
      border-radius: 20px;
      display: flex; align-items: center; justify-content: center;
      color: #0a0a0a;
      margin: 0 auto 24px;
    }
    .state-success h1 {
      font-size: 22px; font-weight: 700; letter-spacing: -0.03em;
      margin-bottom: 10px;
      color: #0a0a0a;
    }
    .state-success p { color: rgba(0,0,0,0.6); font-size: 14px; line-height: 1.65; margin-bottom: 28px; }

    /* ── ERROR state ── */
    .error-msg {
      display: none;
      background: rgba(0,0,0,0.05);
      border: 1px solid rgba(0,0,0,0.1);
      border-radius: 10px;
      padding: 12px 16px;
      font-size: 13px;
      color: #0a0a0a;
      margin-top: 12px;
    }
    .error-msg.show { display: block; }
  </style>
</head>
<body>

<div class="card">
  <Image src={apricotLogo} alt="Giralabs" class="logo-img" />

  {!token || !booking ? (
    <!-- NOT FOUND -->
    <div class="state-notfound">
      <div class="icon">
        <svg viewBox="0 0 24 24" width="24" height="24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
      </div>
      <h1>Reserva no encontrada</h1>
      <p>Este enlace de cancelación no es válido o la reunión ya fue cancelada previamente.</p>
    </div>
  ) : (
    <>
      <!-- CONFIRM -->
      <div class="state-confirm" id="state-confirm">
        <div class="badge">
          <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"></path><line x1="12" y1="9" x2="12" y2="13"></line><line x1="12" y1="17" x2="12.01" y2="17"></line></svg>
          Cancelar reunión
        </div>
        <h1>¿Seguro que quieres cancelar?</h1>
        <p class="subtitle">
          {isGiralabs
            ? `Estás a punto de cancelar la reunión con ${booking.name}. Se le notificará por correo.`
            : `Estás a punto de cancelar tu reunión con Giralabs. Recibirás un correo de confirmación.`}
        </p>

        <div class="booking-details">
          <div class="detail-row">
            <span class="detail-label">Fecha</span>
            <span class="detail-value">{booking.dateFormatted}</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">Hora</span>
            <span class="detail-value">{booking.time} CET</span>
          </div>
          <div class="detail-row">
            <span class="detail-label">{isGiralabs ? 'Cliente' : 'Con'}</span>
            <span class="detail-value">{isGiralabs ? booking.name : 'Giralabs'}</span>
          </div>
          {booking.company && (
            <div class="detail-row">
              <span class="detail-label">Empresa</span>
              <span class="detail-value">{booking.company}</span>
            </div>
          )}
        </div>

        <div class="warning-box">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><line x1="12" y1="8" x2="12" y2="12"></line><line x1="12" y1="16" x2="12.01" y2="16"></line></svg>
          <div>
            Al confirmar, el horario quedará <strong>libre de nuevo</strong> y
            {isGiralabs ? ` ${booking.name} recibirá un correo informándole de la cancelación.` : ' recibirás un correo de confirmación.'}
          </div>
        </div>

        <button class="btn-action" id="btn-confirm-cancel">
          Sí, cancelar reunión
        </button>

        <div class="error-msg" id="error-msg">
          Error al cancelar la reserva. Por favor inténtalo de nuevo o escríbenos a giralabs.contact@gmail.com
        </div>
      </div>

      <!-- SUCCESS -->
      <div class="state-success" id="state-success">
        <div class="check-icon">
          <svg viewBox="0 0 24 24" width="32" height="32" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg>
        </div>
        <h1>Reunión cancelada</h1>
        <p>
          {isGiralabs
            ? `Se ha cancelado la reunión con ${booking.name}. Se le ha notificado por correo.`
            : 'Tu reunión ha sido cancelada correctamente. Recibirás un correo de confirmación.'}
        </p>
        <a href="/" class="btn-action">Volver a Giralabs →</a>
      </div>
    </>
  )}
</div>

{token && booking && (
  <script define:vars={{ token, cancelledBy }}>
    const btnConfirm = document.getElementById('btn-confirm-cancel');
    const stateConfirm = document.getElementById('state-confirm');
    const stateSuccess = document.getElementById('state-success');
    const errorMsg = document.getElementById('error-msg');

    btnConfirm?.addEventListener('click', async () => {
      btnConfirm.disabled = true;
      btnConfirm.textContent = 'Cancelando...';
      errorMsg?.classList.remove('show');

      try {
        const res = await fetch('/api/cancel', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ token, cancelledBy }),
        });

        const data = await res.json();

        if (res.ok && data.ok) {
          stateConfirm.style.display = 'none';
          stateSuccess.style.display = 'block';
        } else if (data.error === 'not_found') {
          errorMsg.textContent = 'Esta reserva ya fue cancelada previamente o no existe.';
          errorMsg?.classList.add('show');
          btnConfirm.disabled = false;
          btnConfirm.textContent = 'Sí, cancelar reunión';
        } else {
          errorMsg?.classList.add('show');
          btnConfirm.disabled = false;
          btnConfirm.textContent = 'Sí, cancelar reunión';
        }
      } catch {
        errorMsg?.classList.add('show');
        btnConfirm.disabled = false;
        btnConfirm.textContent = 'Sí, cancelar reunión';
      }
    });
  </script>
)}

</body>
</html>
