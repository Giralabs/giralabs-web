---
import { translations } from "../i18n/translations";

interface Props {
  lang?: string;
  actionUrl?: string;
  bookingActionUrl?: string;
}

const { 
  lang = "es", 
  actionUrl = "https://formspree.io/f/placeholder",
  bookingActionUrl = "https://formspree.io/f/placeholder_booking"
} = Astro.props;
const T = translations[lang];

// Dropdown translated options and UI keys
const formTranslations = {
  es: {
    title: "Hablemos de tu proyecto",
    subtitle: "Rellena el formulario y nos pondremos en contacto contigo en menos de 24 horas.",
    name: "Nombre completo",
    name_placeholder: "Tu nombre...",
    email: "Correo electrónico",
    email_placeholder: "Tu correo electrónico...",
    company: "Nombre de la empresa (opcional)",
    company_placeholder: "Nombre de tu empresa...",
    how_heard: "¿Cómo has conocido a Giralabs?",
    service: "Servicio en el que estás interesado",
    project_details: "Cuéntanos más sobre el proyecto",
    project_details_placeholder: "Cuéntanos más sobre tu idea, alcance, plazos de entrega...",
    submit: "Enviar mensaje",
    sending: "Enviando...",
    success_title: "¡Mensaje enviado con éxito!",
    success_desc: "Gracias por ponerte en contacto. Nuestro equipo revisará los detalles y te responderá a la brevedad.",
    error_title: "Error al enviar el formulario",
    error_desc: "Hubo un problema. Por favor, revisa los campos e inténtalo de nuevo, o envíanos un correo directamente a support@giralabs.com.",
    select_how: "Selecciona una opción...",
    select_service: "Selecciona un servicio...",
    options_how: [
      "Recomendación / Contacto",
      "LinkedIn",
      "Twitter / X",
      "Búsqueda en Google",
      "Otro"
    ],
    options_services: [
      "Descubrimiento de Producto",
      "Diseño de Experiencia (UX/UI)",
      "Ingeniería Móvil & Backend",
      "Crecimiento Continuo",
      "Inteligencia Artificial Aplicada",
      "Digitalización de Empresas",
      "Otro / Consulta General"
    ],
    // Booking translations
    booking_title: "Agendar videollamada",
    booking_subtitle: "Elige un día y hora para reunirnos virtualmente y analizar los requisitos de tu producto (Google Meet).",
    booking_confirm: "Confirmar cita",
    booking_success_title: "¡Reunión Agendada!",
    booking_success_desc: "Excelente. Hemos enviado una invitación de Google Meet para el día ",
    booking_email_prompt: "Introduce tu correo para la invitación:",
    booking_email_placeholder: "tu@correo.com",
    booking_time_title: "Horas disponibles para el día",
    booking_nav_prev: "Anterior",
    booking_nav_next: "Siguiente",
    weekdays: ["L", "M", "X", "J", "V", "S", "D"],
    months: ["Enero", "Febrero", "Marzo", "Abril", "Mayo", "Junio", "Julio", "Agosto", "Septiembre", "Octubre", "Noviembre", "Diciembre"]
  },
  en: {
    title: "Let's talk about your project",
    subtitle: "Fill out the form and we will get back to you in less than 24 hours.",
    name: "Full name",
    name_placeholder: "Your name...",
    email: "Email address",
    email_placeholder: "Your email...",
    company: "Company name (optional)",
    company_placeholder: "Your company name...",
    how_heard: "How did you hear about Giralabs?",
    service: "Service you are interested in",
    project_details: "Tell us more about the project",
    project_details_placeholder: "Tell us more about your idea, scope, deadline...",
    submit: "Send message",
    sending: "Sending...",
    success_title: "Message sent successfully!",
    success_desc: "Thank you for getting in touch. Our team will review the details and get back to you shortly.",
    error_title: "Error sending form",
    error_desc: "Something went wrong. Please check the fields and try again, or email us directly at support@giralabs.com.",
    select_how: "Select an option...",
    select_service: "Select a service...",
    options_how: [
      "Recommendation / Referral",
      "LinkedIn",
      "Twitter / X",
      "Google Search",
      "Other"
    ],
    options_services: [
      "Product Discovery",
      "Experience Design (UX/UI)",
      "Mobile & Backend Engineering",
      "Continuous Growth",
      "Applied Artificial Intelligence",
      "Business Digitalization",
      "Other / General Inquiry"
    ],
    // Booking translations
    booking_title: "Schedule a video call",
    booking_subtitle: "Select a day and time to meet virtually and analyze your product requirements (Google Meet).",
    booking_confirm: "Confirm booking",
    booking_success_title: "Meeting Scheduled!",
    booking_success_desc: "Excellent. We have sent a Google Meet invitation for ",
    booking_email_prompt: "Enter your email for the invitation:",
    booking_email_placeholder: "you@example.com",
    booking_time_title: "Available slots for",
    booking_nav_prev: "Prev",
    booking_nav_next: "Next",
    weekdays: ["M", "T", "W", "T", "F", "S", "S"],
    months: ["January", "February", "March", "April", "May", "June", "July", "August", "September", "October", "November", "December"]
  }
};

const F = formTranslations[lang] || formTranslations.es;
---

<!-- ==================== CONTACT SECTION ==================== -->
<section class="contact-section reveal" id="contact" aria-label="Contact Form">
  <!-- Dynamic floating color glows behind the cards -->
  <div class="card-bg-glow glow-1"></div>
  <div class="card-bg-glow glow-2"></div>

  <div class="contact-container">
    
    <div class="contact-grid-layout">
      
      <!-- LEFT COLUMN: Contact Form -->
      <div class="form-glass-card">
        <!-- Mouse cursor light spotlight -->
        <div class="card-spotlight" id="contact-card-spotlight"></div>

        <!-- Success/Error Overlay -->
        <div class="form-overlay" id="form-success-overlay">
          <div class="success-icon-wrapper">
            <svg viewBox="0 0 24 24" width="32" height="32" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </div>
          <h3 class="overlay-title">{F.success_title}</h3>
          <p class="overlay-desc">{F.success_desc}</p>
        </div>

        <!-- Form (dynamic Formspree endpoint) -->
        <h2 class="contact-heading">{F.title}</h2>
        <p class="contact-subtitle">{F.subtitle}</p>

        <form id="ajax-contact-form" action={actionUrl} method="POST" class="form-grid">
          
          <!-- Name -->
          <div class="form-field">
            <label for="form-name" class="form-label">{F.name} *</label>
            <input 
              type="text" 
              id="form-name" 
              name="name" 
              required 
              placeholder={F.name_placeholder} 
              class="form-input"
            />
          </div>

          <!-- Email -->
          <div class="form-field">
            <label for="form-email" class="form-label">{F.email} *</label>
            <input 
              type="email" 
              id="form-email" 
              name="email" 
              required 
              placeholder={F.email_placeholder} 
              class="form-input"
            />
          </div>

          <!-- Company Name (Optional) -->
          <div class="form-field">
            <label for="form-company" class="form-label">{F.company}</label>
            <input 
              type="text" 
              id="form-company" 
              name="company" 
              placeholder={F.company_placeholder} 
              class="form-input"
            />
          </div>

          <!-- Referral Source dropdown -->
          <div class="form-field">
            <label for="form-how-heard" class="form-label">{F.how_heard} *</label>
            <div class="custom-select-container" id="container-how-heard">
              <select id="form-how-heard" name="how_heard" required class="native-hidden-select" tabIndex="-1">
                <option value="" disabled selected>{F.select_how}</option>
                {F.options_how.map((opt) => (
                  <option value={opt}>{opt}</option>
                ))}
              </select>
              <button type="button" class="custom-select-trigger" id="how-heard-trigger" aria-haspopup="listbox" aria-expanded="false">
                <span class="custom-select-value">{F.select_how}</span>
                <svg class="custom-select-chevron" viewBox="0 0 24 24" width="12" height="12" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </button>
              <div class="custom-select-dropdown" role="listbox" aria-label={F.how_heard}>
                {F.options_how.map((opt) => (
                  <div class="custom-select-option" role="option" data-value={opt}>{opt}</div>
                ))}
              </div>
            </div>
          </div>

          <!-- Service Category dropdown -->
          <div class="form-field full-width">
            <label for="form-service" class="form-label">{F.service} *</label>
            <div class="custom-select-container" id="container-service">
              <select id="form-service" name="service" required class="native-hidden-select" tabIndex="-1">
                <option value="" disabled selected>{F.select_service}</option>
                {F.options_services.map((opt) => (
                  <option value={opt}>{opt}</option>
                ))}
              </select>
              <button type="button" class="custom-select-trigger" id="service-trigger" aria-haspopup="listbox" aria-expanded="false">
                <span class="custom-select-value">{F.select_service}</span>
                <svg class="custom-select-chevron" viewBox="0 0 24 24" width="12" height="12" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="6 9 12 15 18 9"></polyline>
                </svg>
              </button>
              <div class="custom-select-dropdown" role="listbox" aria-label={F.service}>
                {F.options_services.map((opt) => (
                  <div class="custom-select-option" role="option" data-value={opt}>{opt}</div>
                ))}
              </div>
            </div>
          </div>

          <!-- Project Details Textarea -->
          <div class="form-field full-width">
            <label for="form-details" class="form-label">{F.project_details} *</label>
            <textarea 
              id="form-details" 
              name="project_details" 
              required 
              placeholder={F.project_details_placeholder}
              class="form-textarea"
            ></textarea>
          </div>

          <!-- Submit & Feedback wrapper -->
          <div class="form-field full-width" style="margin-top: 0.5rem;">
            <div class="submit-wrapper">
              <button type="submit" id="form-submit-btn" class="cta-primary contact-form-submit">
                <span id="btn-text-content">{F.submit}</span>
              </button>
            </div>
            <div class="feedback-msg" id="form-error-msg">{F.error_desc}</div>
          </div>

        </form>
      </div>

      <!-- RIGHT COLUMN: Booking Calendar Card (Black Glass Theme) -->
      <div class="booking-dark-card" data-action={bookingActionUrl}>
        <div class="card-spotlight" id="booking-card-spotlight"></div>

        <!-- Success Booking Overlay -->
        <div class="booking-overlay" id="booking-success-overlay">
          <div class="success-icon-wrapper booking-success-icon">
            <svg viewBox="0 0 24 24" width="36" height="36" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
              <line x1="16" y1="2" x2="16" y2="6"></line>
              <line x1="8" y1="2" x2="8" y2="6"></line>
              <line x1="3" y1="10" x2="21" y2="10"></line>
              <path d="M8 14h.01"></path>
              <path d="M12 14h.01"></path>
              <path d="M16 14h.01"></path>
              <path d="M8 18h.01"></path>
              <path d="M12 18h.01"></path>
              <path d="M16 18h.01"></path>
            </svg>
          </div>
          <h3 class="overlay-title booking-success-title">{F.booking_success_title}</h3>
          <p class="overlay-desc booking-success-desc" id="booking-success-desc-text">{F.booking_success_desc}</p>
        </div>

        <div class="booking-card-content">
          <h3 class="booking-heading">{F.booking_title}</h3>
          <p class="booking-subtitle">{F.booking_subtitle}</p>

          <!-- Calendar Widget -->
          <div class="calendar-container">
            <div class="calendar-header">
              <button type="button" class="calendar-nav-btn" id="calendar-prev-btn" aria-label="Previous Month">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
              </button>
              <span class="calendar-month-year" id="calendar-month-year-lbl">Junio 2026</span>
              <button type="button" class="calendar-nav-btn" id="calendar-next-btn" aria-label="Next Month">
                <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
              </button>
            </div>
            
            <div class="calendar-weekdays" id="calendar-weekdays-grid">
              <!-- Rendered dynamically -->
            </div>
            <div class="calendar-days" id="calendar-days-grid">
              <!-- Rendered dynamically -->
            </div>
          </div>

          <!-- Time slots section (Visible after selecting date) -->
          <div class="time-slots-section" id="time-slots-panel">
            <h4 class="time-slots-title" id="time-slots-title-lbl">{F.booking_time_title}</h4>
            <div class="time-slots-grid" id="time-slots-grid">
              <!-- Rendered dynamically -->
            </div>
          </div>

          <!-- Quick Confirmation email field (Visible after selecting date & time slot) -->
          <div class="booking-confirm-section" id="booking-confirm-panel">
            <label for="booking-email-input" class="booking-email-label">{F.booking_email_prompt}</label>
            <div class="booking-email-row">
              <input 
                type="email" 
                id="booking-email-input" 
                class="booking-email-input" 
                placeholder={F.booking_email_placeholder}
              />
              <button type="button" class="booking-submit-btn" id="booking-submit-btn">
                <span id="booking-btn-text-content">{F.booking_confirm}</span>
              </button>
            </div>
            <div class="booking-error-msg" id="booking-error-msg"></div>
          </div>

        </div>
      </div>

    </div>

  </div>
</section>

<style>
  /* ========================================
     CONTACT FORM STYLING (Split layout & Glassmorphism)
  ======================================== */
  .contact-section {
    position: relative;
    z-index: 2;
    padding: 8rem 2rem;
    background: transparent;
    overflow: hidden;
  }

  .contact-container {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 2;
  }

  /* Split Desktop Grid Layout */
  .contact-grid-layout {
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: 3.5rem;
    width: 100%;
    align-items: stretch;
  }

  .contact-header {
    text-align: left;
    margin-bottom: 0.5rem;
    grid-column: span 2;
  }

  .contact-heading {
    font-size: clamp(2rem, 5vw, 2.8rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: #000;
    margin: 0 0 1rem 0;
    line-height: 1.15;
  }

  .contact-subtitle {
    font-size: 1.05rem;
    color: rgba(0, 0, 0, 0.55);
    line-height: 1.6;
    margin: 0 0 1rem 0;
  }

  /* Decorative glowing ambient blobs behind cards */
  .card-bg-glow {
    position: absolute;
    width: 500px;
    height: 500px;
    border-radius: 50%;
    filter: blur(130px);
    z-index: 1;
    pointer-events: none;
    opacity: 0.12;
  }

  .glow-1 {
    background: radial-gradient(circle, rgba(255, 120, 50, 0.45) 0%, transparent 70%);
    top: 10%;
    left: 5%;
    animation: floatBlob1 25s infinite alternate ease-in-out;
  }

  .glow-2 {
    background: radial-gradient(circle, rgba(0, 240, 255, 0.3) 0%, transparent 70%);
    bottom: 5%;
    right: 5%;
    animation: floatBlob2 20s infinite alternate ease-in-out;
  }

  @keyframes floatBlob1 {
    0% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(80px, -50px) scale(1.15); }
    100% { transform: translate(-40px, 40px) scale(0.9); }
  }

  @keyframes floatBlob2 {
    0% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-60px, 60px) scale(0.85); }
    100% { transform: translate(50px, -30px) scale(1.1); }
  }

  /* ----------------------------------------
     COLUMN 1: Light Glass Frosted Card
  ---------------------------------------- */
  .form-glass-card {
    background: rgba(255, 255, 255, 0.28);
    backdrop-filter: blur(40px) saturate(200%);
    -webkit-backdrop-filter: blur(40px) saturate(200%);
    border: 1px solid rgba(255, 255, 255, 0.65);
    border-radius: 32px;
    padding: 3.5rem;
    box-shadow:
      0 32px 80px rgba(0, 0, 0, 0.03),
      0 1px 0 rgba(255, 255, 255, 0.9) inset;
    position: relative;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    justify-content: center;
  }

  /* Interactive spotlight overlay */
  .card-spotlight {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    background: radial-gradient(450px circle at var(--mx, 0px) var(--my, 0px), rgba(255, 255, 255, 0.4) 0%, transparent 60%);
    transition: opacity 0.4s ease;
  }

  .form-glass-card:hover .card-spotlight {
    opacity: 1;
  }

  /* Form Layout */
  .form-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.6rem;
    width: 100%;
  }

  /* Field Container micro-animation */
  .form-field {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    position: relative;
    transition: transform 0.25s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .form-field:focus-within {
    transform: translateY(-2px);
    z-index: 10;
  }

  .form-field.open {
    z-index: 20;
  }

  .form-field.full-width {
    grid-column: span 2;
  }

  /* Muted Elegant Labels */
  .form-label {
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: rgba(0, 0, 0, 0.45);
    margin-left: 0.2rem;
    transition: color 0.2s ease;
  }

  .form-field:focus-within .form-label {
    color: #000;
  }

  /* Highly Transparent Glass Inputs */
  .form-input, .form-select, .form-textarea {
    width: 100%;
    padding: 0.95rem 1.25rem;
    background: rgba(255, 255, 255, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 14px;
    font-family: inherit;
    font-size: 0.92rem;
    color: #000;
    outline: none;
    transition: all 0.25s cubic-bezier(0.25, 1, 0.5, 1);
    box-shadow: 
      0 2px 6px rgba(0, 0, 0, 0.005) inset,
      0 1px 0 rgba(255, 255, 255, 0.2) inset;
  }

  .form-input::placeholder, .form-textarea::placeholder {
    color: rgba(0, 0, 0, 0.3);
  }

  .form-input:hover, .form-select:hover, .form-textarea:hover {
    background: rgba(255, 255, 255, 0.4);
    border-color: rgba(255, 255, 255, 0.55);
  }

  .form-input:focus, .form-select:focus, .form-textarea:focus {
    background: rgba(255, 255, 255, 0.7);
    border-color: rgba(255, 255, 255, 0.9);
    box-shadow: 
      0 8px 24px rgba(0, 0, 0, 0.02),
      0 0 0 3px rgba(255, 255, 255, 0.4);
  }

  .form-textarea {
    min-height: 140px;
    resize: vertical;
  }

  /* Style select dropdown arrow and options background */
  .form-select {
    appearance: none;
    background-image: url("data:image/svg+xml;charset=UTF-8,%3csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 24 24' fill='none' stroke='rgba(0,0,0,0.5)' stroke-width='2.5' stroke-linecap='round' stroke-linejoin='round'%3e%3cpolyline points='6 9 12 15 18 9'%3e%3c/polyline%3e%3c/svg%3e");
    background-repeat: no-repeat;
    background-position: right 1.25rem center;
    background-size: 10px;
    padding-right: 2.5rem;
  }

  .form-select option {
    background-color: #F0EFEA;
    color: #000;
  }

  /* ========================================
     CUSTOM DROPDOWNS (Glassmorphism Effect)
     ======================================== */
  .custom-select-container {
    position: relative;
    width: 100%;
  }

  .native-hidden-select {
    position: absolute !important;
    opacity: 0 !important;
    pointer-events: none !important;
    width: 0 !important;
    height: 0 !important;
    margin: 0 !important;
    padding: 0 !important;
    border: none !important;
    bottom: 0;
    left: 50%;
  }

  .custom-select-trigger {
    width: 100%;
    padding: 0.95rem 1.25rem;
    background: rgba(255, 255, 255, 0.25);
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: 14px;
    font-family: inherit;
    font-size: 0.92rem;
    color: rgba(0, 0, 0, 0.3); /* Placeholder color */
    outline: none;
    transition: all 0.25s cubic-bezier(0.25, 1, 0.5, 1);
    box-shadow: 
      0 2px 6px rgba(0, 0, 0, 0.005) inset,
      0 1px 0 rgba(255, 255, 255, 0.2) inset;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: space-between;
    text-align: left;
  }

  .custom-select-trigger.has-value {
    color: #000;
  }

  .custom-select-trigger:hover {
    background: rgba(255, 255, 255, 0.4);
    border-color: rgba(255, 255, 255, 0.55);
  }

  .custom-select-trigger:focus,
  .custom-select-container.open .custom-select-trigger {
    background: rgba(255, 255, 255, 0.7);
    border-color: rgba(255, 255, 255, 0.9);
    box-shadow: 
      0 8px 24px rgba(0, 0, 0, 0.02),
      0 0 0 3px rgba(255, 255, 255, 0.4);
  }

  .custom-select-chevron {
    color: rgba(0, 0, 0, 0.5);
    transition: transform 0.35s cubic-bezier(0.25, 1, 0.5, 1);
    flex-shrink: 0;
    margin-left: 0.5rem;
  }

  .custom-select-container.open .custom-select-chevron {
    transform: rotate(180deg);
  }

  .custom-select-dropdown {
    position: absolute;
    top: calc(100% + 8px);
    left: 0;
    right: 0;
    background: rgba(240, 239, 234, 0.88);
    backdrop-filter: blur(28px) saturate(180%);
    -webkit-backdrop-filter: blur(28px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.7);
    border-radius: 16px;
    padding: 0.5rem 0.35rem 0.5rem 0.5rem;
    box-shadow: 
      0 12px 30px rgba(0, 0, 0, 0.08),
      0 0 0 0.5px rgba(0, 0, 0, 0.02) inset,
      0 1px 0 rgba(255, 255, 255, 0.8) inset;
    opacity: 0;
    visibility: hidden;
    transform: translateY(8px);
    transition: 
      opacity 0.25s ease, 
      transform 0.35s cubic-bezier(0.25, 1, 0.5, 1), 
      visibility 0.25s;
    z-index: 100;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
    max-height: 280px;
    overflow-y: auto;

    /* Firefox Scrollbar styling */
    scrollbar-width: thin;
    scrollbar-color: rgba(0, 0, 0, 0.12) transparent;
  }

  .custom-select-dropdown::-webkit-scrollbar {
    width: 8px;
