<!-- ==================== CLIENT SIDE FORM + CALENDAR INTERACTION ==================== -->
<script define:vars={{ formTranslations, defaultLang: lang }}>
  function initContactBooking() {
    // ----------------------------------------
    // 1. SELECTORS & STATE
    // ----------------------------------------
    const contactForm = document.getElementById("ajax-contact-form");
    const contactSubmitBtn = document.getElementById("form-submit-btn");
    const contactBtnText = document.getElementById("btn-text-content");
    const contactErrorMsg = document.getElementById("form-error-msg");
    const contactOverlay = document.getElementById("form-success-overlay");
    const contactCard = document.getElementById("contact-card-spotlight")?.parentElement;

    const bookingCard = document.getElementById("booking-card-spotlight")?.parentElement;
    const bookingOverlay = document.getElementById("booking-success-overlay");
    const bookingOverlayDescText = document.getElementById("booking-success-desc-text");
    const calendarPrevBtn = document.getElementById("calendar-prev-btn");
    const calendarNextBtn = document.getElementById("calendar-next-btn");
    const calendarMonthYearLbl = document.getElementById("calendar-month-year-lbl");
    const calendarWeekdaysGrid = document.getElementById("calendar-weekdays-grid");
    const calendarDaysGrid = document.getElementById("calendar-days-grid");

    const timeSlotsPanel = document.getElementById("time-slots-panel");
    const timeSlotsTitleLbl = document.getElementById("time-slots-title-lbl");
    const timeSlotsGrid = document.getElementById("time-slots-grid");

    const confirmPanel = document.getElementById("booking-confirm-panel");
    const bookingEmailInput = document.getElementById("booking-email-input");
    const bookingSubmitBtn = document.getElementById("booking-submit-btn");
    const bookingBtnText = document.getElementById("booking-btn-text-content");
    const bookingErrorMsg = document.getElementById("booking-error-msg");

    if (!contactForm || !contactSubmitBtn || !contactBtnText || !contactErrorMsg || !contactOverlay) return;

    // Interactive date state
    let currentDate = new Date();
    let calendarYear = currentDate.getFullYear();
    let calendarMonth = currentDate.getMonth();

    // Selectable times
    const defaultTimeSlots = ["09:30", "11:00", "15:00", "16:30"];
    let selectedDateString = "";
    let selectedDateObj = null;
    let selectedTimeSlot = "";

    // ----------------------------------------
    // 2. MOUSE SPOTLIGHT ACTIONS
    // ----------------------------------------
    const handleSpotlight = (cardEl, e) => {
      const rect = cardEl.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      cardEl.style.setProperty("--mx", `${x}px`);
      cardEl.style.setProperty("--my", `${y}px`);
    };

    if (contactCard) {
      contactCard.addEventListener("mousemove", (e) => handleSpotlight(contactCard, e));
    }
    if (bookingCard) {
      bookingCard.addEventListener("mousemove", (e) => handleSpotlight(bookingCard, e));
    }

    // ----------------------------------------
    // 3. CALENDAR GENERATION LOGIC
    // ----------------------------------------
    function getDaysInMonth(year, month) {
      return new Date(year, month + 1, 0).getDate();
    }

    function renderCalendarWidget(lang) {
      const activeF = formTranslations[lang] || formTranslations.es;

      // Render month year label
      if (calendarMonthYearLbl) {
        calendarMonthYearLbl.textContent = `${activeF.months[calendarMonth]} ${calendarYear}`;
      }

      // Render weekday titles
      if (calendarWeekdaysGrid) {
        calendarWeekdaysGrid.innerHTML = "";
        activeF.weekdays.forEach(day => {
          const lbl = document.createElement("span");
          lbl.className = "calendar-weekday-lbl";
          lbl.textContent = day;
          calendarWeekdaysGrid.appendChild(lbl);
        });
      }

      // Render days
      if (calendarDaysGrid) {
        calendarDaysGrid.innerHTML = "";

        // First day of month (Mon=0, Tue=1... Sun=6 based on local Giralabs mapping)
        const firstDayNative = new Date(calendarYear, calendarMonth, 1).getDay();
        const firstDayIdx = firstDayNative === 0 ? 6 : firstDayNative - 1;
        const totalDays = getDaysInMonth(calendarYear, calendarMonth);

        // Add spacing empty cells
        for (let i = 0; i < firstDayIdx; i++) {
          const emptyCell = document.createElement("div");
          emptyCell.className = "calendar-day-btn empty";
          calendarDaysGrid.appendChild(emptyCell);
        }

        // Today reference
        const systemToday = new Date();

        for (let day = 1; day <= totalDays; day++) {
          const dayBtn = document.createElement("button");
          dayBtn.type = "button";
          dayBtn.className = "calendar-day-btn";
          dayBtn.textContent = day;

          const thisDate = new Date(calendarYear, calendarMonth, day);

          const isPast = new Date(thisDate.getFullYear(), thisDate.getMonth(), thisDate.getDate()) < 
                         new Date(systemToday.getFullYear(), systemToday.getMonth(), systemToday.getDate());

          const nativeDayOfWeek = thisDate.getDay();
          const isWeekend = nativeDayOfWeek === 0 || nativeDayOfWeek === 6;

          if (isPast || isWeekend) {
            dayBtn.classList.add("disabled");
            dayBtn.disabled = true;
          } else {
            dayBtn.classList.add("available");
            
            if (selectedDateObj && 
                selectedDateObj.getDate() === day && 
                selectedDateObj.getMonth() === calendarMonth && 
                selectedDateObj.getFullYear() === calendarYear) {
              dayBtn.classList.add("selected");
            }

            dayBtn.addEventListener("click", () => {
              document.querySelectorAll(".calendar-day-btn.selected").forEach(el => el.classList.remove("selected"));
              dayBtn.classList.add("selected");

              selectedDateObj = thisDate;
              
              const formattedDate = lang === "es" 
                ? `${day} de ${activeF.months[calendarMonth]}` 
                : `${activeF.months[calendarMonth]} ${day}`;
              
              selectedDateString = `${formattedDate}, ${calendarYear}`;

              revealTimeSlots(selectedDateString, lang);
            });
          }

          calendarDaysGrid.appendChild(dayBtn);
        }
      }
    }

    function revealTimeSlots(dateText, lang) {
      if (!timeSlotsPanel || !timeSlotsGrid || !timeSlotsTitleLbl) return;

      const activeF = formTranslations[lang] || formTranslations.es;
      timeSlotsTitleLbl.textContent = `${activeF.booking_time_title} ${dateText.split(",")[0]}`;
      
      timeSlotsGrid.innerHTML = "";
      selectedTimeSlot = "";
      
      if (confirmPanel) confirmPanel.style.display = "none";

      defaultTimeSlots.forEach(time => {
        const slotBtn = document.createElement("button");
        slotBtn.type = "button";
        slotBtn.className = "time-slot-btn";
        slotBtn.textContent = time;

        slotBtn.addEventListener("click", () => {
          document.querySelectorAll(".time-slot-btn.selected").forEach(el => el.classList.remove("selected"));
          slotBtn.classList.add("selected");

          selectedTimeSlot = time;
          revealConfirmPanel(lang);
        });

        timeSlotsGrid.appendChild(slotBtn);
      });

      timeSlotsPanel.style.display = "flex";
    }

    function revealConfirmPanel(lang) {
      if (!confirmPanel || !bookingEmailInput) return;

      const contactFormEmail = document.getElementById("form-email")?.value;
      if (contactFormEmail && !bookingEmailInput.value) {
        bookingEmailInput.value = contactFormEmail;
      }

      confirmPanel.style.display = "flex";
      bookingErrorMsg.classList.remove("show");
    }

    // Nav Calendar buttons
    if (calendarPrevBtn && calendarNextBtn) {
      calendarPrevBtn.addEventListener("click", () => {
        calendarMonth--;
        if (calendarMonth < 0) {
          calendarMonth = 11;
          calendarYear--;
        }
        const currentLang = document.documentElement.lang || "es";
        renderCalendarWidget(currentLang);
      });

      calendarNextBtn.addEventListener("click", () => {
        calendarMonth++;
        if (calendarMonth > 11) {
          calendarMonth = 0;
          calendarYear++;
        }
        const currentLang = document.documentElement.lang || "es";
        renderCalendarWidget(currentLang);
      });
    }

    // ----------------------------------------
    // 4. TRANSLATIONS GLOBAL EVENT LISTENER
    // ----------------------------------------
    function updateFormTranslations(lang) {
      const activeF = formTranslations[lang] || formTranslations.es;

      // Form Header
      const titleEl = document.querySelector(".contact-heading");
      if (titleEl) titleEl.textContent = activeF.title;
      const subtitleEl = document.querySelector(".contact-subtitle");
      if (subtitleEl) subtitleEl.textContent = activeF.subtitle;

      // Form Labels
      const labelName = document.querySelector('label[for="form-name"]');
      if (labelName) labelName.textContent = activeF.name + " *";
      const labelEmail = document.querySelector('label[for="form-email"]');
      if (labelEmail) labelEmail.textContent = activeF.email + " *";
      const labelCompany = document.querySelector('label[for="form-company"]');
      if (labelCompany) labelCompany.textContent = activeF.company;
      const labelHowHeard = document.querySelector('label[for="form-how-heard"]');
      if (labelHowHeard) labelHowHeard.textContent = activeF.how_heard + " *";
      const labelService = document.querySelector('label[for="form-service"]');
      if (labelService) labelService.textContent = activeF.service + " *";
      const labelDetails = document.querySelector('label[for="form-details"]');
      if (labelDetails) labelDetails.textContent = activeF.project_details + " *";

      // Form Placeholders
      const inputName = document.getElementById("form-name");
      if (inputName) inputName.placeholder = activeF.name_placeholder;
      const inputEmail = document.getElementById("form-email");
      if (inputEmail) inputEmail.placeholder = activeF.email_placeholder;
      const inputCompany = document.getElementById("form-company");
      if (inputCompany) inputCompany.placeholder = activeF.company_placeholder;
      const inputDetails = document.getElementById("form-details");
      if (inputDetails) inputDetails.placeholder = activeF.project_details_placeholder;

      // Select elements option 0
      const selectHow = document.getElementById("form-how-heard");
      if (selectHow && selectHow.options[0]) selectHow.options[0].textContent = activeF.select_how;
      const selectService = document.getElementById("form-service");
      if (selectService && selectService.options[0]) selectService.options[0].textContent = activeF.select_service;

      // Update select values option text
      if (selectHow) {
        activeF.options_how.forEach((opt, idx) => {
          if (selectHow.options[idx + 1]) {
            selectHow.options[idx + 1].textContent = opt;
            selectHow.options[idx + 1].value = opt;
          }
        });
      }
      if (selectService) {
        activeF.options_services.forEach((opt, idx) => {
          if (selectService.options[idx + 1]) {
            selectService.options[idx + 1].textContent = opt;
            selectService.options[idx + 1].value = opt;
          }
        });
      }

      // Update custom select options and triggers
      const containerHow = document.getElementById("container-how-heard");
      if (containerHow) {
        const trigger = containerHow.querySelector(".custom-select-trigger");
        const valSpan = trigger.querySelector(".custom-select-value");
        const nativeSelect = containerHow.querySelector(".native-hidden-select");
        const customOptions = containerHow.querySelectorAll(".custom-select-option");

        customOptions.forEach((optEl, idx) => {
          const optText = activeF.options_how[idx];
          if (optText) {
            optEl.textContent = optText;
            optEl.setAttribute("data-value", optText);
          }
        });

        if (!trigger.classList.contains("has-value")) {
          valSpan.textContent = activeF.select_how;
        } else {
          const selectedIdx = nativeSelect.selectedIndex - 1;
          if (selectedIdx >= 0 && activeF.options_how[selectedIdx]) {
            valSpan.textContent = activeF.options_how[selectedIdx];
          }
        }
      }

      const containerService = document.getElementById("container-service");
      if (containerService) {
        const trigger = containerService.querySelector(".custom-select-trigger");
        const valSpan = trigger.querySelector(".custom-select-value");
        const nativeSelect = containerService.querySelector(".native-hidden-select");
        const customOptions = containerService.querySelectorAll(".custom-select-option");

        customOptions.forEach((optEl, idx) => {
          const optText = activeF.options_services[idx];
          if (optText) {
            optEl.textContent = optText;
            optEl.setAttribute("data-value", optText);
          }
        });

        if (!trigger.classList.contains("has-value")) {
          valSpan.textContent = activeF.select_service;
        } else {
          const selectedIdx = nativeSelect.selectedIndex - 1;
          if (selectedIdx >= 0 && activeF.options_services[selectedIdx]) {
            valSpan.textContent = activeF.options_services[selectedIdx];
          }
        }
      }

      // Submit Contact Button text
      if (contactBtnText && !contactSubmitBtn.disabled) {
        contactBtnText.textContent = activeF.submit;
      }

      // Form overlay
      const overlayTitle = document.querySelector(".overlay-title");
      if (overlayTitle) overlayTitle.textContent = activeF.success_title;
      const overlayDesc = document.querySelector(".overlay-desc");
      if (overlayDesc) overlayDesc.textContent = activeF.success_desc;
      if (contactErrorMsg) contactErrorMsg.textContent = activeF.error_desc;

      // ----------------- BOOKING LABELS -----------------
      const bookingTitleEl = document.querySelector(".booking-heading");
      if (bookingTitleEl) bookingTitleEl.textContent = activeF.booking_title;
      const bookingSubtitleEl = document.querySelector(".booking-subtitle");
      if (bookingSubtitleEl) bookingSubtitleEl.textContent = activeF.booking_subtitle;

      const bookingEmailConfirmLbl = document.querySelector(".booking-email-label");
      if (bookingEmailConfirmLbl && !selectedTimeSlot) {
        bookingEmailConfirmLbl.textContent = activeF.booking_email_prompt;
      }
      const bookingEmailInputEl = document.getElementById("booking-email-input");
      if (bookingEmailInputEl) bookingEmailInputEl.placeholder = activeF.booking_email_placeholder;
      
      const bookingSubmitBtnLbl = document.getElementById("booking-btn-text-content");
      if (bookingSubmitBtnLbl && !bookingSubmitBtn.disabled) {
        bookingSubmitBtnLbl.textContent = activeF.booking_confirm;
      }

      const bookingOverlayTitleEl = document.querySelector(".booking-success-title");
      if (bookingOverlayTitleEl) bookingOverlayTitleEl.textContent = activeF.booking_success_title;

      renderCalendarWidget(lang);
      if (selectedDateString) {
        revealTimeSlots(selectedDateString, lang);
      }
    }

    const initialLang = localStorage.getItem("giralabs-lang") || document.documentElement.lang || defaultLang || "es";
    updateFormTranslations(initialLang);

    if (window.__giralabsContactListenerAttached) {
      document.removeEventListener("giralabs:lang", window.__giralabsContactListenerAttached);
    }
    window.__giralabsContactListenerAttached = (e) => {
      updateFormTranslations(e.detail.lang);
    };
    document.addEventListener("giralabs:lang", window.__giralabsContactListenerAttached);

    // ----------------------------------------
    // 5. CONTACT FORM SUBMISSION (AJAX)
    // ----------------------------------------
    contactForm.addEventListener("submit", async (event) => {
      event.preventDefault();
      
      const currentLang = document.documentElement.lang || "es";
      const activeF = formTranslations[currentLang] || formTranslations.es;

      // Reset state
      contactErrorMsg.classList.remove("error");
      contactSubmitBtn.disabled = true;
      contactBtnText.textContent = activeF.sending;

      const data = new FormData(contactForm);
      const actionUrl = contactForm.getAttribute("action");

      try {
        const response = await fetch(actionUrl, {
          method: "POST",
          body: data,
          headers: {
            "Accept": "application/json"
          }
        });

        if (response.ok || response.status === 200) {
          contactForm.reset();
          contactOverlay.classList.add("show");
        } else {
          const result = await response.json();
          throw new Error(result.error || "Formspree submission failed");
        }
      } catch (error) {
        console.error("Submission error:", error);
        contactErrorMsg.classList.add("error");
        contactSubmitBtn.disabled = false;
        contactBtnText.textContent = activeF.submit;
      }
    });

    // ----------------------------------------
    // 6. CALENDAR BOOKING SUBMISSION (AJAX)
    // ----------------------------------------
    if (bookingSubmitBtn) {
      bookingSubmitBtn.addEventListener("click", async () => {
        const currentLang = document.documentElement.lang || "es";
        const activeF = formTranslations[currentLang] || formTranslations.es;

        const email = bookingEmailInput.value.trim();
        if (!email) {
          bookingErrorMsg.textContent = activeF.error_desc.split(".")[0];
          bookingErrorMsg.classList.add("show");
          return;
        }

        bookingErrorMsg.classList.remove("show");
        bookingSubmitBtn.disabled = true;
        bookingBtnText.textContent = activeF.sending;

        const actionUrl = bookingCard.getAttribute("data-action");
        const payload = {
          email: email,
          type: "Videollamada Google Meet (Giralabs)",
          date: selectedDateString,
          time: selectedTimeSlot
        };

        try {
          const response = await fetch(actionUrl, {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
              "Accept": "application/json"
            },
            body: JSON.stringify(payload)
          });

          if (response.ok || response.status === 200) {
            bookingOverlayDescText.innerHTML = `${activeF.booking_success_desc} <strong>${selectedDateString.split(",")[0]} a las ${selectedTimeSlot}</strong>.`;
            bookingOverlay.classList.add("show");
          } else {
            const result = await response.json();
            throw new Error(result.error || "Booking submission failed");
          }
        } catch (error) {
          console.error("Booking error:", error);
          bookingErrorMsg.textContent = activeF.error_desc.split(".")[0];
          bookingErrorMsg.classList.add("show");
          
          bookingSubmitBtn.disabled = false;
          bookingBtnText.textContent = activeF.booking_confirm;
        }
      });
    }

    // ----------------------------------------
    // Custom Dropdown Handling & Initialization
    // ----------------------------------------
    const customSelects = document.querySelectorAll(".custom-select-container");
    customSelects.forEach(container => {
      const trigger = container.querySelector(".custom-select-trigger");
      const valSpan = trigger.querySelector(".custom-select-value");
      const nativeSelect = container.querySelector(".native-hidden-select");
      const options = container.querySelectorAll(".custom-select-option");

      // Toggle dropdown open
      trigger.addEventListener("click", (e) => {
        e.stopPropagation();
        
        // Close other custom selects first
        customSelects.forEach(other => {
          if (other !== container) {
            other.classList.remove("open");
            other.parentElement.classList.remove("open");
            other.querySelector(".custom-select-trigger").setAttribute("aria-expanded", "false");
          }
        });

        const isOpen = container.classList.contains("open");
        container.classList.toggle("open", !isOpen);
        container.parentElement.classList.toggle("open", !isOpen);
        trigger.setAttribute("aria-expanded", String(!isOpen));
      });

      // Handle option click
      options.forEach(option => {
        option.addEventListener("click", (e) => {
          e.stopPropagation();
          const val = option.getAttribute("data-value");
          
          // Set native select value
          nativeSelect.value = val;
          nativeSelect.dispatchEvent(new Event("change"));

          // Update trigger visual state
          valSpan.textContent = option.textContent;
          trigger.classList.add("has-value");

          // Update selected visual state on options
          options.forEach(opt => opt.classList.remove("selected"));
          option.classList.add("selected");

          // Close dropdown
          container.classList.remove("open");
          container.parentElement.classList.remove("open");
          trigger.setAttribute("aria-expanded", "false");
        });
      });
    });

    // Close dropdowns on click outside
    document.addEventListener("click", () => {
      customSelects.forEach(container => {
        container.classList.remove("open");
        container.parentElement.classList.remove("open");
        container.querySelector(".custom-select-trigger").setAttribute("aria-expanded", "false");
      });
    });

    // Handle form reset
    contactForm.addEventListener("reset", () => {
      customSelects.forEach(container => {
        const trigger = container.querySelector(".custom-select-trigger");
        const valSpan = trigger.querySelector(".custom-select-value");
        const nativeSelect = container.querySelector(".native-hidden-select");
        const options = container.querySelectorAll(".custom-select-option");

        trigger.classList.remove("has-value");
        container.classList.remove("open");
        container.parentElement.classList.remove("open");
        options.forEach(opt => opt.classList.remove("selected"));

        const currentLang = document.documentElement.lang || "es";
        const activeF = formTranslations[currentLang] || formTranslations.es;
        if (nativeSelect.id === "form-how-heard") {
          valSpan.textContent = activeF.select_how;
        } else if (nativeSelect.id === "form-service") {
          valSpan.textContent = activeF.select_service;
        }
      });
    });
  }

  // Support both standard page loads and View Transitions (astro:page-load)
  if (document.readyState === "loading") {
    document.addEventListener("DOMContentLoaded", initContactBooking);
  } else {
    initContactBooking();
  }
  document.addEventListener("astro:page-load", initContactBooking);
</script>
