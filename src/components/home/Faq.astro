---
import { translations } from '../../i18n/translations';

interface Props {
  lang?: string;
}

const { lang = 'es' } = Astro.props;
const T = translations[lang] as any;

// FAQ items mapping
const faqItems = [
  {
    q: T.faq_q1,
    a: T.faq_a1,
    key: "faq_q1"
  },
  {
    q: T.faq_q2,
    a: T.faq_a2,
    key: "faq_q2"
  },
  {
    q: T.faq_q3,
    a: T.faq_a3,
    key: "faq_q3"
  },
  {
    q: T.faq_q4,
    a: T.faq_a4,
    key: "faq_q4"
  },
  {
    q: T.faq_q5,
    a: T.faq_a5,
    key: "faq_q5"
  }
];

// Schema JSON-LD data
const schemaData = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.q,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.a
    }
  }))
};
---

<section class="faq-section" id="faq" aria-label="Preguntas Frecuentes">
  <div class="faq-inner reveal">
    
    <!-- Header -->
    <header class="faq-header">
      <span class="faq-eyebrow" data-i18n="faq_label">{T.faq_label}</span>
      <h2 class="faq-title" data-i18n="faq_title">{T.faq_title}</h2>
      <p class="faq-subtitle" data-i18n="faq_sub">{T.faq_sub}</p>
    </header>

    <!-- Accordion List -->
    <div class="faq-list">
      {faqItems.map((item, index) => (
        <div class="faq-item" id={`faq-item-${index + 1}`}>
          <button 
            type="button" 
            class="faq-trigger" 
            aria-expanded="false" 
            aria-controls={`faq-answer-${index + 1}`}
          >
            <span class="faq-question-text" data-i18n={item.key}>{item.q}</span>
            <span class="faq-icon-wrap" aria-hidden="true">
              <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
              </svg>
            </span>
          </button>
          <div 
            class="faq-answer-panel" 
            id={`faq-answer-${index + 1}`}
            role="region"
            aria-labelledby={`faq-item-${index + 1}`}
          >
            <div class="faq-answer-content">
              <p data-i18n={`faq_a${index + 1}`}>{item.a}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

  </div>
</section>

<!-- JSON-LD Schema Markup directly injected for SEO -->
<script type="application/ld+json" set:html={JSON.stringify(schemaData)} />

<!-- Client-side Accordion Script -->
<script>
  function initFaq() {
    const faqItems = document.querySelectorAll('.faq-item');
    
    faqItems.forEach(item => {
      const trigger = item.querySelector('.faq-trigger');
      const panel = item.querySelector('.faq-answer-panel') as HTMLElement;
      
      trigger?.addEventListener('click', () => {
        const isExpanded = trigger.getAttribute('aria-expanded') === 'true';
        
        // Close other items
        faqItems.forEach(otherItem => {
          if (otherItem !== item) {
            const otherTrigger = otherItem.querySelector('.faq-trigger');
            const otherPanel = otherItem.querySelector('.faq-answer-panel') as HTMLElement;
            otherTrigger?.setAttribute('aria-expanded', 'false');
            if (otherPanel) {
              otherPanel.style.maxHeight = '0px';
            }
          }
        });

        // Toggle current item
        if (isExpanded) {
          trigger.setAttribute('aria-expanded', 'false');
          if (panel) panel.style.maxHeight = '0px';
        } else {
          trigger.setAttribute('aria-expanded', 'true');
          if (panel) {
            panel.style.maxHeight = panel.scrollHeight + 'px';
          }
        }
      });
    });
  }

  // Init on load
  initFaq();
  // Support Astro view transitions / swaps
  document.addEventListener('astro:after-swap', initFaq);
</script>

<style>
  .faq-section {
    position: relative;
    z-index: 1;
    padding: 8rem 2rem;
    background: transparent;
    border-top: 1px solid rgba(0, 0, 0, 0.05);
  }

  .faq-inner {
    max-width: 800px;
    margin: 0 auto;
    width: 100%;
  }

  .faq-header {
    text-align: center;
    margin-bottom: 4.5rem;
  }

  .faq-eyebrow {
    font-size: 0.72rem;
    font-weight: 600;
    letter-spacing: 0.2em;
    color: rgba(0, 0, 0, 0.4);
    text-transform: uppercase;
    display: inline-block;
    margin-bottom: 0.8rem;
  }

  .faq-title {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 800;
    letter-spacing: -0.04em;
    color: #000;
    margin: 0 0 1.2rem;
    line-height: 1.15;
  }

  .faq-subtitle {
    font-size: clamp(1rem, 2.5vw, 1.15rem);
    color: rgba(0, 0, 0, 0.55);
    line-height: 1.6;
    margin: 0;
    max-width: 580px;
    margin-inline: auto;
  }

  /* --- ACCORDION ACCENT --- */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    width: 100%;
  }

  .faq-item {
    position: relative;
    border-radius: 20px;
    background: rgba(255, 255, 255, 0.35);
    backdrop-filter: blur(20px) saturate(180%);
    -webkit-backdrop-filter: blur(20px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.65);
    box-shadow: 
      0 4px 20px rgba(0, 0, 0, 0.015),
      0 1px 0 rgba(255, 255, 255, 0.7) inset;
    overflow: hidden;
    transition: transform 0.4s cubic-bezier(0.25, 1, 0.5, 1), 
                box-shadow 0.4s ease, 
                border-color 0.4s ease, 
                background-color 0.4s ease;
  }

  .faq-item:hover {
    background: rgba(255, 255, 255, 0.65);
    border-color: rgba(255, 255, 255, 0.95);
    box-shadow: 
      0 10px 30px rgba(0, 0, 0, 0.04),
      0 1px 0 rgba(255, 255, 255, 0.85) inset;
  }

  .faq-trigger {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1.5rem;
    padding: 1.8rem 2.2rem;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    outline: none;
    font-family: inherit;
    color: #000;
  }

  .faq-question-text {
    font-size: clamp(1rem, 2vw, 1.15rem);
    font-weight: 700;
    letter-spacing: -0.025em;
    line-height: 1.4;
    transition: color 0.3s ease;
  }

  .faq-icon-wrap {
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(0, 0, 0, 0.03);
    border: 1px solid rgba(0, 0, 0, 0.05);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
                background 0.3s ease,
                color 0.3s ease;
    color: rgba(0, 0, 0, 0.6);
  }

  .faq-trigger:hover .faq-icon-wrap {
    background: rgba(0, 0, 0, 0.08);
    color: #000;
  }

  /* Expand actions */
  .faq-trigger[aria-expanded="true"] .faq-icon-wrap {
    transform: rotate(45deg);
    background: #000;
    color: #fff;
    border-color: #000;
  }

  .faq-trigger[aria-expanded="true"] .faq-question-text {
    color: #000;
  }

  /* Answer panel slide transition */
  .faq-answer-panel {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .faq-answer-content {
    padding: 0 2.2rem 2.2rem;
  }

  .faq-answer-content p {
    font-size: 0.95rem;
    line-height: 1.7;
    color: rgba(0, 0, 0, 0.65);
    margin: 0;
  }

  @media (max-width: 600px) {
    .faq-section {
      padding: 5rem 1.5rem;
    }
    .faq-header {
      margin-bottom: 3rem;
    }
    .faq-trigger {
      padding: 1.4rem 1.6rem;
    }
    .faq-answer-content {
      padding: 0 1.6rem 1.6rem;
    }
    .faq-icon-wrap {
      width: 28px;
      height: 28px;
    }
  }
</style>
