---
import { translations } from '../../i18n/translations';

interface Props {
  lang?: string;
}

const { lang = 'es' } = Astro.props;
const T = translations[lang];
---

<!-- ==================== SERVICES BENTO GRID ==================== -->
<section class="sd-section" id="services" aria-label="Services">
  <div class="sd-inner">

    <!-- Header -->
    <div class="sd-header reveal">
      <p class="sd-eyebrow" data-i18n="sd_eyebrow">{T.sd_eyebrow}</p>
      <h2 class="sd-title" data-i18n="sd_title" set:html={T.sd_title.replace('\n','<br>')}></h2>
    </div>

    <!-- Bento Grid (12 Columns) -->
    <div class="sd-grid reveal-stagger">

      <!-- CARD 01: Product Discovery (Wide Left, Span 7) -->
