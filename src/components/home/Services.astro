<!-- Scroll Reveal Activation & Spotlight tracking -->
<script>
  function initScrollReveal() {
    const cards = document.querySelectorAll('.sd-card');
    
    // Spotlight mouse tracking
    cards.forEach(card => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        card.style.setProperty('--mx', x + 'px');
        card.style.setProperty('--my', y + 'px');
      });
    });

    // IntersectionObserver to activate cards and sweep animations on scroll
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-active');
          // Once animated, keep it active so users can hover, and stop observing
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.15,
      rootMargin: '0px 0px -80px 0px'
    });

    cards.forEach(card => observer.observe(card));
  }

  initScrollReveal();
  document.addEventListener('astro:after-swap', initScrollReveal);
</script>

<style>
  /* ========================================
     SERVICES SECTION GLOBAL & THEME SETUP
  ======================================== */
  .sd-section {
    position: relative;
    z-index: 2;
    background-color: #070709;
    padding: 8rem 2rem;
    margin-top: -2px;
    overflow: hidden;
    --accent-discovery: #ff914d;
    --accent-design: #00f0ff;
    --accent-engineering: #3d8bff;
    --accent-growth: #10b981;
    --accent-ai: #a855f7;
    --accent-team: #eab308;
  }

  /* Soft glowing radial gradient behind the section header */
  .sd-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 300px;
    background: radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.035) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .sd-inner {
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .sd-header {
    margin-bottom: 4rem;
    text-align: left;
  }

  .sd-eyebrow {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    margin: 0 0 1.2rem;
  }

  .sd-title {
    font-size: clamp(1.8rem, 4.5vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: rgba(255, 255, 255, 0.95);
    margin: 0;
    line-height: 1.25;
  }

  /* ========================================
     BENTO GRID SYSTEM (Desktop default)
  ======================================== */
  .sd-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 18px;
    width: 100%;
  }

  /* Robust layout selectors + Accent bindings */
  .sd-card[data-card="1"] {
    grid-column: span 7;
    --accent-color-1: #ff7d3b;
    --accent-rgb-1: 255, 125, 59;
    --accent-color-2: #ff2a85;
    --accent-rgb-2: 255, 42, 133;
  }
  .sd-card[data-card="2"] {
    grid-column: span 5;
    --accent-color-1: #00f0ff;
    --accent-rgb-1: 0, 240, 255;
    --accent-color-2: #7000ff;
    --accent-rgb-2: 112, 0, 255;
  }
  .sd-card[data-card="3"] {
    grid-column: span 5;
    --accent-color-1: #3d8bff;
    --accent-rgb-1: 61, 139, 255;
    --accent-color-2: #00f5a0;
    --accent-rgb-2: 0, 245, 160;
  }
  .sd-card[data-card="4"] {
    grid-column: span 7;
    --accent-color-1: #00e676;
    --accent-rgb-1: 0, 230, 118;
    --accent-color-2: #baff00;
    --accent-rgb-2: 186, 255, 0;
  }
  .sd-card[data-card="5"] {
    grid-column: span 6;
    --accent-color-1: #a855f7;
    --accent-rgb-1: 168, 85, 247;
    --accent-color-2: #ff007f;
    --accent-rgb-2: 255, 0, 127;
  }
  .sd-card[data-card="6"] {
    grid-column: span 6;
    --accent-color-1: #eab308;
    --accent-rgb-1: 234, 179, 8;
    --accent-color-2: #ff5722;
    --accent-rgb-2: 255, 87, 34;
  }

  /* ========================================
     CARD BASE STRUCTURE
  ======================================== */
  .sd-card {
    position: relative;
    background-color: #0c0c0e; /* Strong dark base */
    border-radius: 24px;
    overflow: hidden;
    transition: 
      background-color 0.4s ease, 
      transform 0.4s cubic-bezier(0.25, 1, 0.5, 1);
    display: flex;
    text-decoration: none; /* Prevent underlines inside links */
  }

  .sd-card.is-active:hover {
    transform: translateY(-2px);
    background-color: #111114;
  }

  /* Minimalist Link Arrow */
  .sd-card-arrow {
    position: absolute;
    top: 1.8rem;
    right: 1.8rem;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 5;
    transition: 
      background-color 0.3s ease, 
      border-color 0.3s ease, 
      color 0.3s ease,
      transform 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .sd-card:hover .sd-card-arrow {
    background: rgba(var(--accent-rgb-1), 0.1);
    border-color: rgba(var(--accent-rgb-1), 0.3);
    color: var(--accent-color-1);
    transform: translate(2px, -2px) scale(1.05);
  }

  .sd-card--vert {
    flex-direction: column;
    min-height: 440px; /* Increased slightly to accommodate larger visuals */
  }

  .sd-card--horiz {
    flex-direction: row;
    min-height: 310px;
  }

  .sd-card-content {
    display: flex;
    width: 100%;
    height: 100%;
    min-height: inherit;
    padding: 2.2rem;
    position: relative;
    z-index: 2;
  }

  .sd-card--vert .sd-card-content {
    flex-direction: column;
    justify-content: space-between;
    align-items: stretch;
  }

  .sd-card--horiz .sd-card-content {
    flex-direction: row;
    align-items: center;
    gap: 2rem;
  }

  /* ----------------------------------------
     NEON GRADIENT BORDERS (Webkit composite mask)
  ---------------------------------------- */
  .sd-card-border {
    position: absolute;
    inset: 0;
    border-radius: 24px;
    border: 1.5px solid transparent;
    background: linear-gradient(135deg, rgba(255,255,255,0.08) 0%, rgba(255,255,255,0.03) 100%) border-box;
    -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
    -webkit-mask-composite: destination-out;
    mask-composite: exclude;
    pointer-events: none;
    z-index: 3;
    transition: background 0.8s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .sd-card.is-active .sd-card-border {
    background: linear-gradient(135deg, var(--accent-color-1) 0%, rgba(var(--accent-rgb-2), 0.25) 60%, rgba(255,255,255,0.04) 100%) border-box;
  }

  .sd-card.is-active:hover .sd-card-border {
    background: linear-gradient(135deg, var(--accent-color-1) 0%, rgba(var(--accent-rgb-2), 0.6) 50%, rgba(255,255,255,0.08) 100%) border-box;
  }

  /* ----------------------------------------
     NEON HALO SHADOWS (Dropshadow glow)
  ---------------------------------------- */
  .sd-card-shadow {
    position: absolute;
    inset: 2px;
    border-radius: 24px;
    background: transparent;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    transition: box-shadow 0.8s cubic-bezier(0.25, 1, 0.5, 1);
    pointer-events: none;
    z-index: -1;
  }

  .sd-card.is-active .sd-card-shadow {
    box-shadow: 
      0 12px 30px rgba(0, 0, 0, 0.6),
      0 0 25px rgba(var(--accent-rgb-1), 0.04),
      0 0 25px rgba(var(--accent-rgb-2), 0.04); /* Soft duo-glow outline */
  }

  .sd-card.is-active:hover .sd-card-shadow {
    box-shadow: 
      0 16px 40px rgba(0, 0, 0, 0.7),
      0 0 35px rgba(var(--accent-rgb-1), 0.12),
      0 0 35px rgba(var(--accent-rgb-2), 0.12); /* Intense duo-glow outline on hover */
  }

  /* ----------------------------------------
     SPOTLIGHTS & LASER SWEEPS
  ---------------------------------------- */
  /* Spotlight effect (Mouse Hover state) */
  .sd-spotlight {
    position: absolute;
    inset: 0;
    pointer-events: none;
    opacity: 0;
    z-index: 1;
    background: radial-gradient(400px circle at var(--mx, 0px) var(--my, 0px), rgba(var(--accent-rgb-1), 0.08) 0%, rgba(var(--accent-rgb-2), 0.08) 40%, transparent 80%);
    transition: opacity 0.5s ease;
  }

  .sd-card:hover .sd-spotlight {
    animation: none !important; /* disable sweep on hover */
    opacity: 1 !important;
  }

  /* Spotlight Sweep (Laser scroll-reveal animation) */
  .sd-sweep {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 1;
    opacity: 0;
    background: radial-gradient(350px circle at 0% 50%, rgba(var(--accent-rgb-1), 0.15) 0%, rgba(var(--accent-rgb-2), 0.1) 50%, transparent 100%);
  }

  .sd-card.is-active .sd-sweep {
    animation: spotlightSweep 1.6s cubic-bezier(0.25, 1, 0.5, 1) forwards;
  }

  .sd-card:hover .sd-sweep {
    animation: none !important;
    opacity: 0 !important;
  }

  @keyframes spotlightSweep {
    0% {
      opacity: 0;
      transform: translateX(-60%);
      background: radial-gradient(350px circle at 0% 50%, rgba(var(--accent-rgb-1), 0.15) 0%, rgba(var(--accent-rgb-2), 0.1) 50%, transparent 100%);
    }
    30%, 70% {
      opacity: 1;
    }
    100% {
      opacity: 0;
      transform: translateX(60%);
      background: radial-gradient(350px circle at 100% 50%, rgba(var(--accent-rgb-1), 0.15) 0%, rgba(var(--accent-rgb-2), 0.1) 50%, transparent 100%);
    }
  }

  /* ----------------------------------------
     DUAL FLUID LAVA GLOW BLOBS
  ---------------------------------------- */
  .sd-card-glow {
    position: absolute;
    width: 170px;
    height: 170px;
    border-radius: 50%;
    filter: blur(55px);
    pointer-events: none;
    z-index: 0;
    opacity: 0;
    transition: opacity 1.5s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .sd-card.is-active .sd-card-glow {
    opacity: 0.22; /* High color presence when scroll-activated */
  }

  .sd-card.is-active:hover .sd-card-glow {
    opacity: 0.38; /* Extra color presence on hover */
  }

  .sd-card-glow-1 {
    background: var(--accent-color-1);
    top: -40px;
    right: -40px;
    animation: floatBlob1 12s infinite alternate ease-in-out;
  }

  .sd-card-glow-2 {
    background: var(--accent-color-2);
    bottom: -50px;
    left: -20px;
    animation: floatBlob2 10s infinite alternate ease-in-out;
  }

  @keyframes floatBlob1 {
    0% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-25px, 35px) scale(1.2); }
    100% { transform: translate(-45px, 20px) scale(0.9); }
  }

  @keyframes floatBlob2 {
    0% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(35px, -25px) scale(0.8); }
    100% { transform: translate(20px, -45px) scale(1.15); }
  }

  /* ========================================
     CARD DETAILS & TEXT
  ======================================== */
  .sd-card-text {
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 2;
  }

  .sd-card--horiz .sd-card-text {
    width: 55%;
    flex-shrink: 0;
  }

  .sd-card-top {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1.5rem;
  }

  .sd-num {
    font-size: 0.75rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.35);
    font-family: monospace;
    letter-spacing: 0.05em;
  }

  /* Colored Tag Badge */
  .sd-tag {
    display: inline-block;
    padding: 0.35rem 0.85rem;
    background: linear-gradient(135deg, rgba(var(--accent-rgb-1), 0.08), rgba(var(--accent-rgb-2), 0.08));
    border: 1px solid rgba(var(--accent-rgb-1), 0.25);
    border-radius: 100px;
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--accent-color-1);
    letter-spacing: 0.02em;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .sd-card-main {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .sd-card-title {
    font-size: clamp(1.25rem, 2.5vw, 1.45rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #fff;
    margin: 0;
    line-height: 1.25;
  }

  .sd-card-desc {
    font-size: 0.82rem;
    color: rgba(255, 255, 255, 0.55);
    line-height: 1.6;
    margin: 0;
    font-weight: 400;
  }

  /* ========================================
     CARD VISUAL WRAPPERS (WIDGETS)
  ======================================== */
  .sd-card-visual {
    position: relative;
    z-index: 2;
    display: flex;
    align-items: center;
    justify-content: center;
    /* Removed overflow: hidden so elements don't get clipped at container borders */
  }

  .sd-card--vert .sd-card-visual {
    width: 100%;
    margin-bottom: 2rem;
    height: 170px; /* Increased to 170px for extra visual height & breathing room */
  }

  .sd-card--horiz .sd-card-visual {
    width: 45%;
    height: 150px;
    justify-content: center;
  }

  /* ----------------------------------------
     WIDGET 1: DISCOVERY TIMELINE (Infinite Loop Animation)
  ---------------------------------------- */
  .discovery-timeline {
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: center;
    width: 100%;
    max-width: 250px;
    height: 90px;
  }

  .timeline-step {
    position: relative;
    z-index: 2;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 4px;
    background: #070709;
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 0.6rem 0.7rem;
    border-radius: 12px;
    min-width: 68px;
  }

  .step-num {
    font-size: 0.68rem;
    font-weight: 700;
    color: rgba(255,255,255,0.4);
    font-family: monospace;
  }

  .step-lbl {
    font-size: 0.6rem;
    color: rgba(255,255,255,0.65);
    font-weight: 500;
  }

  .timeline-connector {
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 100%;
    height: 10px;
    z-index: 1;
  }

  .connector-progress {
    stroke-dasharray: 140;
    stroke-dashoffset: 140;
  }

  /* Widget 1 Loop Animations */
  .sd-card.is-active .timeline-step.step-1 { animation: step1Pulse 4s infinite ease-in-out; }
  .sd-card.is-active .timeline-step.step-2 { animation: step2Pulse 4s infinite ease-in-out; }
  .sd-card.is-active .timeline-step.step-3 { animation: step3Pulse 4s infinite ease-in-out; }
  .sd-card.is-active .connector-progress { animation: lineProgress 4s infinite ease-in-out; }

  @keyframes step1Pulse {
    0%, 100% { border-color: rgba(255, 255, 255, 0.1); transform: translateY(0); }
    12%, 40% { border-color: rgba(255, 255, 255, 0.35); transform: translateY(-4px); }
  }

  @keyframes step2Pulse {
    0%, 12%, 100% { border-color: rgba(255, 255, 255, 0.1); transform: translateY(0); }
    24%, 52% { border-color: rgba(255, 255, 255, 0.35); transform: translateY(-4px); }
  }

  @keyframes step3Pulse {
    0%, 24%, 100% {
      border-color: rgba(255, 255, 255, 0.1);
      transform: translateY(0);
      box-shadow: none;
      background: #070709;
    }
    36%, 76% {
      border-color: var(--accent-color-1);
      transform: translateY(-4px);
      box-shadow: 0 0 12px rgba(var(--accent-rgb-1), 0.2);
      background: rgba(var(--accent-rgb-1), 0.05);
    }
  }

  @keyframes lineProgress {
    0%, 8% { stroke-dashoffset: 140; }
    52%, 80% { stroke-dashoffset: 0; }
    90%, 100% { stroke-dashoffset: 140; }
  }

  /* ----------------------------------------
     WIDGET 2: DESIGN WORKSPACE (Infinite Loop Animation)
  ---------------------------------------- */
  .design-workspace {
    position: relative;
    width: 180px;
    height: 120px;
    background: rgba(255, 255, 255, 0.005);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 16px;
    overflow: hidden;
  }

  .grid-overlay {
    position: absolute;
    inset: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 10px 10px;
  }

  .mock-device {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 110px;
    height: 70px;
    background: rgba(7, 7, 9, 0.9);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: 6px;
  }

  .mock-button {
    position: relative;
    padding: 4px 10px;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 4px;
    font-size: 0.55rem;
    color: rgba(255, 255, 255, 0.6);
    font-weight: 500;
  }

  .mock-elements {
    display: flex;
    gap: 4px;
    margin-top: 6px;
    width: 100%;
  }

  .mock-el {
    height: 6px;
    background: rgba(255, 255, 255, 0.04);
    border-radius: 2px;
    opacity: 0;
  }

  .mock-el.el-1 { flex: 2; }
  .mock-el.el-2 { flex: 1; }

  .design-cursor {
    position: absolute;
    top: 0;
    left: 0;
    transform: translate(140px, 90px);
    pointer-events: none;
    filter: drop-shadow(0 2px 4px rgba(0,0,0,0.5));
  }

  /* Design Animations on Scroll/Hover */
  .sd-card.is-active .design-cursor {
    animation: cursorClick 1.8s infinite cubic-bezier(0.25, 1, 0.5, 1);
  }

  .sd-card.is-active .mock-button {
    animation: btnPress 1.8s infinite cubic-bezier(0.25, 1, 0.5, 1);
  }

  .sd-card.is-active .mock-el {
    animation: elSlide 1.8s infinite cubic-bezier(0.25, 1, 0.5, 1);
  }

  @keyframes cursorClick {
    0% { transform: translate(140px, 90px); }
    55% { transform: translate(75px, 45px); }
    63% { transform: translate(75px, 45px) scale(0.8); }
    70% { transform: translate(75px, 45px) scale(1); }
    100% { transform: translate(140px, 90px); }
  }

  @keyframes btnPress {
    0%, 58% {
      background: rgba(255, 255, 255, 0.03);
      color: rgba(255, 255, 255, 0.6);
      border-color: rgba(255, 255, 255, 0.1);
      box-shadow: none;
    }
    63%, 90% {
      background: linear-gradient(135deg, rgba(var(--accent-rgb-1), 0.15), rgba(var(--accent-rgb-2), 0.15));
      color: var(--accent-color-1);
      border-color: var(--accent-color-1);
      box-shadow: 0 0 12px rgba(var(--accent-rgb-1), 0.25);
    }
  }

  @keyframes elSlide {
    0%, 65% {
      opacity: 0;
      transform: translateY(4px);
    }
    75%, 95% {
      opacity: 1;
      transform: translateY(0);
      background: rgba(255, 255, 255, 0.08);
    }
  }

  /* ----------------------------------------
     WIDGET 3: ENGINEERING CONSOLE (Infinite Loop Animation)
  ---------------------------------------- */
  .engineering-console {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    width: 100%;
    max-width: 230px;
  }

  .speed-dial {
    position: relative;
    width: 80px;
    height: 80px;
    flex-shrink: 0;
  }

  .dial-progress {
    transform: rotate(-90deg);
    transform-origin: 50px 50px;
  }

  .dial-label {
    position: absolute;
    inset: 0;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .dial-val {
    font-size: 0.8rem;
    font-weight: 700;
    color: #fff;
    line-height: 1;
  }

  .dial-sub {
    font-size: 0.5rem;
    color: rgba(255, 255, 255, 0.4);
    text-transform: uppercase;
    font-weight: 500;
    letter-spacing: 0.05em;
    margin-top: 1px;
  }

  .console-terminal {
    flex: 1;
    background: rgba(0, 0, 0, 0.35);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 8px;
    padding: 8px 10px;
    font-family: monospace;
    font-size: 0.55rem;
    text-align: left;
    height: 64px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .terminal-dots {
    display: flex;
    gap: 3px;
    margin-bottom: 4px;
  }

  .t-dot {
    width: 4px;
    height: 4px;
    border-radius: 50%;
  }
  .t-dot-r { background: #ff5f56; }
  .t-dot-y { background: #ffbd2e; }
  .t-dot-g { background: #27c93f; }

  .terminal-lines {
    display: flex;
    flex-direction: column;
    gap: 2px;
  }

  .term-l {
    color: rgba(255, 255, 255, 0.35);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    opacity: 0.2;
    transform: translateX(-2px);
  }

  /* Engineering Loop Animations */
  .sd-card.is-active .dial-progress { animation: dialFluctuate 4s infinite ease-in-out; }
  .sd-card.is-active .term-l.l-1 { animation: termLine1 4s infinite ease-in-out; }
  .sd-card.is-active .term-l.l-2 { animation: termLine2 4s infinite ease-in-out; }
  .sd-card.is-active .term-l.l-3 { animation: termLine3 4s infinite ease-in-out; }

  @keyframes dialFluctuate {
    0%, 100% { stroke-dashoffset: 251.2; }
    45%, 85% { stroke-dashoffset: 75.3; } /* Gauge peaks at 70% fill */
  }

  @keyframes termLine1 {
    0%, 100% { opacity: 0.2; transform: translateX(-2px); }
    12%, 80% { opacity: 1; transform: translateX(0); color: rgba(255,255,255,0.85); }
  }

  @keyframes termLine2 {
    0%, 12%, 100% { opacity: 0.2; transform: translateX(-2px); }
    24%, 80% { opacity: 1; transform: translateX(0); color: rgba(255,255,255,0.85); }
  }

  @keyframes termLine3 {
    0%, 24%, 100% { opacity: 0.2; transform: translateX(-2px); }
    36%, 80% { opacity: 1; transform: translateX(0); color: var(--accent-color-1); }
  }

  /* ----------------------------------------
     WIDGET 4: GROWTH CHART (Infinite Loop Animation)
  ---------------------------------------- */
  .growth-chart {
    position: relative;
    width: 200px;
    height: 100px;
    background: rgba(255, 255, 255, 0.005);
    border: 1px solid rgba(255, 255, 255, 0.04);
    border-radius: 16px;
    padding: 10px;
    overflow: hidden;
  }

  .chart-bg-grid {
    position: absolute;
    inset: 0;
    background-image: 
      linear-gradient(rgba(255, 255, 255, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255, 255, 255, 0.03) 1px, transparent 1px);
    background-size: 20px 20px;
    background-position: center;
  }

  .chart-svg {
    position: relative;
    width: 100%;
    height: 100%;
    z-index: 2;
  }

  .chart-line {
    stroke-dasharray: 240;
    stroke-dashoffset: 240;
  }

  .chart-area {
    opacity: 0;
  }

  .chart-dot {
    transform: scale(0);
    transform-origin: 170px 15px;
  }

  .chart-labels {
    position: absolute;
    bottom: 6px;
    left: 10px;
    right: 10px;
    display: flex;
    justify-content: space-between;
    font-size: 0.5rem;
    color: rgba(255, 255, 255, 0.3);
    font-weight: 500;
    z-index: 2;
  }

  /* Growth Loop Animations */
  .sd-card.is-active .chart-line { animation: drawLine 3.8s infinite ease-in-out; }
  .sd-card.is-active .chart-area { animation: fillArea 3.8s infinite ease-in-out; }
  .sd-card.is-active .chart-dot { animation: chartDotPulse 3.8s infinite ease-in-out; }

  @keyframes drawLine {
    0% { stroke-dashoffset: 240; }
    45%, 80% { stroke-dashoffset: 0; }
    90%, 100% { stroke-dashoffset: 240; }
  }

  @keyframes fillArea {
    0%, 15% { opacity: 0; }
    45%, 80% { opacity: 1; }
    90%, 100% { opacity: 0; }
  }

  @keyframes chartDotPulse {
    0%, 40% { transform: scale(0); }
    45%, 80% { transform: scale(1); }
    90%, 100% { transform: scale(0); }
  }

  /* ----------------------------------------
     WIDGET 5: AI CHAT SUPPORT (Infinite Loop Animation)
  ---------------------------------------- */
  .ai-chat {
    display: flex;
    flex-direction: column;
    gap: 8px;
    width: 100%;
    max-width: 200px;
    margin: 0 auto;
  }

  .chat-row {
    display: flex;
    align-items: center;
    gap: 6px;
    width: 100%;
    opacity: 0;
    transform: translateY(4px);
  }

  .chat-avatar {
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    font-size: 0.5rem;
    font-weight: 700;
    color: rgba(255,255,255,0.8);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .ai-avatar {
    background: linear-gradient(135deg, var(--accent-color-1), var(--accent-color-2));
    color: #000;
  }

  .chat-bubble {
    padding: 6px 10px;
    border-radius: 10px;
    font-size: 0.58rem;
    line-height: 1.2;
    max-width: 85%;
  }

  .chat-user .chat-bubble {
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.85);
    border-top-left-radius: 2px;
  }

  .dots-bubble {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.04);
    display: flex;
    gap: 3px;
    align-items: center;
    padding: 6px 8px;
  }

  .dot-pulse {
    width: 3px;
    height: 3px;
    background: rgba(255, 255, 255, 0.6);
    border-radius: 50%;
    animation: aiDots 0.8s infinite alternate;
  }

  .dot-pulse:nth-child(2) { animation-delay: 0.15s; }
  .dot-pulse:nth-child(3) { animation-delay: 0.3s; }

  @keyframes aiDots {
    0% { transform: scale(0.7); opacity: 0.2; }
    100% { transform: scale(1.3); opacity: 1; }
  }

  .result-bubble {
    background: rgba(var(--accent-rgb-1), 0.08);
    border: 1px solid rgba(var(--accent-rgb-1), 0.2);
    color: #fff;
    border-top-left-radius: 2px;
    text-align: left;
  }

  .result-badge {
    font-size: 0.55rem;
    font-weight: 700;
    color: var(--accent-color-1);
    margin-bottom: 2px;
  }

  .result-text {
    font-size: 0.5rem;
    color: rgba(255, 255, 255, 0.7);
  }

  /* AI Chat Loop Animations (Staggered 6-second timeline) */
  .sd-card.is-active .chat-user { animation: chatUserSeq 6s infinite ease-in-out; }
  .sd-card.is-active .chat-loader { animation: chatLoaderSeq 6s infinite ease-in-out; }
  .sd-card.is-active .chat-ai { animation: chatAISeq 6s infinite ease-in-out; }

  @keyframes chatUserSeq {
    0%, 100% { opacity: 0; transform: translateY(4px); }
    5%, 85% { opacity: 1; transform: translateY(0); }
  }

  @keyframes chatLoaderSeq {
    0%, 10%, 48%, 100% { opacity: 0; transform: translateY(4px); }
    16%, 42% { opacity: 1; transform: translateY(0); }
  }

  @keyframes chatAISeq {
    0%, 46%, 100% { opacity: 0; transform: translateY(4px); }
    52%, 85% { opacity: 1; transform: translateY(0); }
  }

  /* ----------------------------------------
     WIDGET 6: TEAM MESH (Infinite Loop Animation - Unclipped)
  ---------------------------------------- */
  .team-mesh {
    position: relative;
    width: 130px;
    height: 130px;
    margin: 0 auto;
  }

  .mesh-hub {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 32px;
    height: 32px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 3;
    transition: all 0.4s ease;
  }

  .hub-label {
    font-size: 0.45rem;
    font-weight: 700;
    color: rgba(255,255,255,0.7);
