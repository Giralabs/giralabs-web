---
import { translations } from '../../i18n/translations';

interface Props {
  lang?: string;
}

const { lang = 'es' } = Astro.props;
const T = translations[lang];
---

<!-- ==================== SERVICES BENTO GRID ==================== -->
<section class="sd-section" id="services" aria-label="Services">
  <div class="sd-inner">

    <!-- Header -->
    <div class="sd-header reveal">
      <p class="sd-eyebrow" data-i18n="sd_eyebrow">{T.sd_eyebrow}</p>
      <h2 class="sd-title" data-i18n="sd_title" set:html={T.sd_title.replace('\n','<br>')}></h2>
    </div>

    <!-- Bento Grid (12 Columns) -->
    <div class="sd-grid reveal-stagger">

      <!-- CARD 01: Creación de aplicaciones móviles (Wide Left, Span 7) -->
      <a href="/service/mobile-apps" class="sd-card sd-card--horiz" data-card="1">
        <div class="sd-card-border"></div>
        <div class="sd-card-content">
          <div class="sd-card-arrow">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="7" y1="17" x2="17" y2="7"></line>
              <polyline points="7 7 17 7 17 17"></polyline>
            </svg>
          </div>
          <div class="sd-card-text">
            <div class="sd-card-top">
              <span class="sd-tag" data-i18n="service_1_tag">{T.service_1_tag}</span>
            </div>
            <div class="sd-card-main">
              <h3 class="sd-card-title" data-i18n="service_1_title">{T.service_1_title}</h3>
              <p class="sd-card-desc" data-i18n="service_1_desc">{T.service_1_desc}</p>
            </div>
          </div>
          <div class="sd-card-visual visual-mobile-apps">
            <!-- Widget: App Mockup -->
            <div class="app-mockup">
              <div class="mockup-screen">
                <div class="mockup-header">
                  <div class="mockup-avatar"></div>
                  <div class="mockup-title-bar"></div>
                </div>
                <div class="mockup-card active-card">
                  <div class="mockup-card-img"></div>
                  <div class="mockup-card-text"></div>
                </div>
                <div class="mockup-card">
                  <div class="mockup-card-text-short"></div>
                </div>
              </div>
              <div class="floating-badge">99%</div>
            </div>
          </div>
        </div>
      </a>

      <!-- CARD 02: Creación de páginas web (Narrow Right, Span 5) -->
      <a href="/service/web-development" class="sd-card sd-card--vert" data-card="2">
        <div class="sd-card-border"></div>
        <div class="sd-card-content">
          <div class="sd-card-arrow">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="7" y1="17" x2="17" y2="7"></line>
              <polyline points="7 7 17 7 17 17"></polyline>
            </svg>
          </div>
          <div class="sd-card-visual visual-web-dev">
            <!-- Widget: Viewport Resizer -->
            <div class="viewport-resizer">
              <div class="resizer-browser">
                <div class="browser-header">
                  <span class="browser-dot"></span>
                  <span class="browser-dot"></span>
                  <span class="browser-dot"></span>
                </div>
                <div class="browser-body">
                  <div class="browser-hero"></div>
                  <div class="browser-grid">
                    <div class="grid-box"></div>
                    <div class="grid-box"></div>
                    <div class="grid-box"></div>
                  </div>
                </div>
              </div>
              <div class="resizer-handle">
                <svg viewBox="0 0 24 24" width="8" height="8" fill="currentColor">
                  <path d="M8 5h2v14H8V5zm6 0h2v14h-2V5z"/>
                </svg>
              </div>
            </div>
          </div>
          <div class="sd-card-text">
            <div class="sd-card-top">
              <span class="sd-tag" data-i18n="service_2_tag">{T.service_2_tag}</span>
            </div>
            <div class="sd-card-main">
              <h3 class="sd-card-title" data-i18n="service_2_title">{T.service_2_title}</h3>
              <p class="sd-card-desc" data-i18n="service_2_desc">{T.service_2_desc}</p>
            </div>
          </div>
        </div>
      </a>

      <!-- CARD 03: Digitalización de empresas y software a medida (Narrow Left, Span 5) -->
      <a href="/service/business-digitalization" class="sd-card sd-card--vert" data-card="3">
        <div class="sd-card-border"></div>
        <div class="sd-card-content">
          <div class="sd-card-arrow">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="7" y1="17" x2="17" y2="7"></line>
              <polyline points="7 7 17 7 17 17"></polyline>
            </svg>
          </div>
          <div class="sd-card-visual visual-digitalization">
            <!-- Widget: Data Pipeline -->
            <div class="data-pipeline">
              <div class="pipeline-source">
                <span class="pipeline-file">CSV</span>
                <span class="pipeline-file">XLS</span>
              </div>
              <div class="pipeline-flow">
                <div class="flow-dot"></div>
                <div class="flow-dot"></div>
                <div class="flow-dot"></div>
              </div>
              <div class="pipeline-target">
                <div class="dashboard-bar bar-1"></div>
                <div class="dashboard-bar bar-2"></div>
                <div class="dashboard-bar bar-3"></div>
              </div>
            </div>
          </div>
          <div class="sd-card-text">
            <div class="sd-card-top">
              <span class="sd-tag" data-i18n="service_3_tag">{T.service_3_tag}</span>
            </div>
            <div class="sd-card-main">
              <h3 class="sd-card-title" data-i18n="service_3_title">{T.service_3_title}</h3>
              <p class="sd-card-desc" data-i18n="service_3_desc">{T.service_3_desc}</p>
            </div>
          </div>
        </div>
      </a>

      <!-- CARD 04: Creación de tiendas online (Wide Right, Span 7) -->
      <a href="/service/online-stores" class="sd-card sd-card--horiz" data-card="4">
        <div class="sd-card-border"></div>
        <div class="sd-card-content">
          <div class="sd-card-arrow">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="7" y1="17" x2="17" y2="7"></line>
              <polyline points="7 7 17 7 17 17"></polyline>
            </svg>
          </div>
          <div class="sd-card-text">
            <div class="sd-card-top">
              <span class="sd-tag" data-i18n="service_4_tag">{T.service_4_tag}</span>
            </div>
            <div class="sd-card-main">
              <h3 class="sd-card-title" data-i18n="service_4_title">{T.service_4_title}</h3>
              <p class="sd-card-desc" data-i18n="service_4_desc">{T.service_4_desc}</p>
            </div>
          </div>
          <div class="sd-card-visual visual-stores">
            <!-- Widget: Store Checkout -->
            <div class="store-checkout">
              <div class="product-card-preview">
                <div class="product-img"></div>
                <div class="product-info">
                  <div class="product-price">€49</div>
                  <div class="add-to-cart-btn">
                    <span class="btn-icon">+</span>
                  </div>
                </div>
              </div>
              <div class="cart-pill">
                <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2">
                  <circle cx="9" cy="21" r="1"></circle>
                  <circle cx="20" cy="21" r="1"></circle>
                  <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"></path>
                </svg>
                <span class="cart-count">
                  <span class="count-zero">0</span>
                  <span class="count-one">1</span>
                </span>
              </div>
            </div>
          </div>
        </div>
      </a>

      <!-- CARD 05: Creación de software personalizado (Equal Left, Span 6) -->
      <a href="/service/custom-software" class="sd-card sd-card--vert" data-card="5">
        <div class="sd-card-border"></div>
        <div class="sd-card-content">
          <div class="sd-card-arrow">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="7" y1="17" x2="17" y2="7"></line>
              <polyline points="7 7 17 7 17 17"></polyline>
            </svg>
          </div>
          <div class="sd-card-visual visual-software">
            <!-- Widget: API Blocks -->
            <div class="api-blocks">
              <div class="api-card">
                <div class="api-header">
                  <span class="api-method">GET</span>
                  <span class="api-path">/v1/users</span>
                </div>
                <div class="api-payload">{`{ "active": true }`}</div>
              </div>
              <div class="api-logs">
                <span class="log-line">200 OK - 12ms</span>
                <span class="log-line">200 OK - 8ms</span>
              </div>
            </div>
          </div>
          <div class="sd-card-text">
            <div class="sd-card-top">
              <span class="sd-tag" data-i18n="service_5_tag">{T.service_5_tag}</span>
            </div>
            <div class="sd-card-main">
              <h3 class="sd-card-title" data-i18n="service_5_title">{T.service_5_title}</h3>
              <p class="sd-card-desc" data-i18n="service_5_desc">{T.service_5_desc}</p>
            </div>
          </div>
        </div>
      </a>

      <!-- CARD 06: Implementación de IA en las aplicaciones (Equal Right, Span 6) -->
      <a href="/service/ai-integration" class="sd-card sd-card--vert" data-card="6">
        <div class="sd-card-border"></div>
        <div class="sd-card-content">
          <div class="sd-card-arrow">
            <svg viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <line x1="7" y1="17" x2="17" y2="7"></line>
              <polyline points="7 7 17 7 17 17"></polyline>
            </svg>
          </div>
          <div class="sd-card-visual visual-ai">
            <!-- Widget: Neural Net -->
            <div class="neural-net">
              <svg viewBox="0 0 140 100" class="neural-svg">
                <!-- Layer 1 -->
                <circle cx="20" cy="30" r="4" class="node input-node"></circle>
                <circle cx="20" cy="50" r="4" class="node input-node"></circle>
                <circle cx="20" cy="70" r="4" class="node input-node"></circle>
                
                <!-- Layer 2 -->
                <circle cx="70" cy="20" r="4" class="node hidden-node"></circle>
                <circle cx="70" cy="40" r="4" class="node hidden-node"></circle>
                <circle cx="70" cy="60" r="4" class="node hidden-node"></circle>
                <circle cx="70" cy="80" r="4" class="node hidden-node"></circle>
                
                <!-- Layer 3 -->
                <circle cx="120" cy="40" r="4" class="node output-node"></circle>
                <circle cx="120" cy="60" r="4" class="node output-node"></circle>
                
                <!-- Connections -->
                <path d="M 20 30 L 70 20 M 20 30 L 70 40 M 20 30 L 70 60" class="conn-line"></path>
                <path d="M 20 50 L 70 20 M 20 50 L 70 40 M 20 50 L 70 60 M 20 50 L 70 80" class="conn-line"></path>
                <path d="M 20 70 L 70 40 M 20 70 L 70 60 M 20 70 L 70 80" class="conn-line"></path>
                <path d="M 70 20 L 120 40 M 70 20 L 120 60" class="conn-line"></path>
                <path d="M 70 40 L 120 40 M 70 40 L 120 60" class="conn-line"></path>
                <path d="M 70 60 L 120 40 M 70 60 L 120 60" class="conn-line"></path>
                <path d="M 70 80 L 120 40 M 70 80 L 120 60" class="conn-line"></path>

                <!-- Signal paths -->
                <path d="M 20 50 L 70 40 L 120 40" class="signal-line"></path>
              </svg>
            </div>
          </div>
          <div class="sd-card-text">
            <div class="sd-card-top">
              <span class="sd-tag" data-i18n="service_6_tag">{T.service_6_tag}</span>
            </div>
            <div class="sd-card-main">
              <h3 class="sd-card-title" data-i18n="service_6_title">{T.service_6_title}</h3>
              <p class="sd-card-desc" data-i18n="service_6_desc">{T.service_6_desc}</p>
            </div>
          </div>
        </div>
      </a>

    </div>

    <!-- Carousel hint: dot indicators + scroll arrows -->
    <div class="sd-carousel-controls" aria-hidden="true">
      <button class="sd-scroll-arrow sd-arrow-left" id="sd-arrow-left" aria-label="Anterior">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <div class="sd-dot-indicators" id="sd-dot-indicators">
        <button class="sd-dot active" data-index="0" aria-label="Servicio 1"></button>
        <button class="sd-dot" data-index="1" aria-label="Servicio 2"></button>
        <button class="sd-dot" data-index="2" aria-label="Servicio 3"></button>
        <button class="sd-dot" data-index="3" aria-label="Servicio 4"></button>
        <button class="sd-dot" data-index="4" aria-label="Servicio 5"></button>
        <button class="sd-dot" data-index="5" aria-label="Servicio 6"></button>
      </div>
      <button class="sd-scroll-arrow sd-arrow-right" id="sd-arrow-right" aria-label="Siguiente">
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
    </div>
  </div>
</section>

<!-- Scroll Reveal Activation, Spotlight tracking & Carousel Indicator -->
<script>
  function initScrollReveal() {
    const cards = document.querySelectorAll('.sd-card');
    
    // Spotlight mouse tracking
    cards.forEach(card => {
      card.addEventListener('mousemove', (e) => {
        const rect = card.getBoundingClientRect();
        const x = e.clientX - rect.left;
        const y = e.clientY - rect.top;
        card.style.setProperty('--mx', x + 'px');
        card.style.setProperty('--my', y + 'px');
      });
    });

    // IntersectionObserver to activate cards and sweep animations on scroll
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-active');
          observer.unobserve(entry.target);
        }
      });
    }, {
      threshold: 0.15,
      rootMargin: '0px 0px -80px 0px'
    });

    cards.forEach(card => observer.observe(card));

    // Carousel dot indicators & arrow buttons
    const grid = document.querySelector('.sd-grid');
    const dots = document.querySelectorAll('.sd-dot');
    const arrowLeft = document.getElementById('sd-arrow-left');
    const arrowRight = document.getElementById('sd-arrow-right');

    function getActiveDotIndex() {
      if (!grid) return 0;
      const isMobile = window.innerWidth <= 768;
      if (isMobile) {
        // In mobile carousel mode: snap scroll, cards are visible one at a time
        const cardWidth = grid.scrollWidth / cards.length;
        return Math.round(grid.scrollLeft / cardWidth);
      } else {
        // Desktop bento grid: highlight based on which section is closest to center-left
        const gridRect = grid.getBoundingClientRect();
        let closestIdx = 0;
        let closestDist = Infinity;
        cards.forEach((card, i) => {
          const rect = card.getBoundingClientRect();
          const dist = Math.abs(rect.left - gridRect.left);
          if (dist < closestDist) { closestDist = dist; closestIdx = i; }
        });
        return closestIdx;
      }
    }

    function updateDots() {
      const activeIdx = getActiveDotIndex();
      dots.forEach((dot, i) => {
        dot.classList.toggle('active', i === activeIdx);
      });
    }

    function scrollToCard(index) {
      if (!grid) return;
      const isMobile = window.innerWidth <= 768;
      if (isMobile) {
        const cardWidth = grid.scrollWidth / cards.length;
        grid.scrollTo({ left: cardWidth * index, behavior: 'smooth' });
      }
    }

    dots.forEach((dot, i) => {
      dot.addEventListener('click', () => scrollToCard(i));
    });

    if (arrowLeft && arrowRight && grid) {
      arrowLeft.addEventListener('click', () => {
        const isMobile = window.innerWidth <= 768;
        if (isMobile) {
          const cur = getActiveDotIndex();
          scrollToCard(Math.max(0, cur - 1));
        } else {
          grid.scrollBy({ left: -300, behavior: 'smooth' });
        }
      });
      arrowRight.addEventListener('click', () => {
        const isMobile = window.innerWidth <= 768;
        if (isMobile) {
          const cur = getActiveDotIndex();
          scrollToCard(Math.min(cards.length - 1, cur + 1));
        } else {
          grid.scrollBy({ left: 300, behavior: 'smooth' });
        }
      });
      grid.addEventListener('scroll', updateDots, { passive: true });
      window.addEventListener('resize', updateDots, { passive: true });
      updateDots();
    }
  }

  initScrollReveal();
  document.addEventListener('astro:after-swap', initScrollReveal);
</script>

<style>
  /* ========================================
     SERVICES SECTION GLOBAL & THEME SETUP
  ======================================== */
  .sd-section {
    position: relative;
    z-index: 2;
    background-color: #070709;
    padding: 8rem 2rem;
    margin-top: -2px;
    overflow: hidden;
  }

  /* Soft glowing radial gradient behind the section header */
  .sd-section::before {
    content: '';
    position: absolute;
    top: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 600px;
    height: 300px;
    background: radial-gradient(circle at 50% 0%, rgba(255, 255, 255, 0.035) 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  .sd-inner {
    max-width: 1100px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  .sd-header {
    margin-bottom: 4rem;
    text-align: left;
  }

  .sd-eyebrow {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.35);
    margin: 0 0 1.2rem;
  }

  .sd-title {
    font-size: clamp(1.8rem, 4.5vw, 2.5rem);
    font-weight: 700;
    letter-spacing: -0.04em;
    color: rgba(255, 255, 255, 0.95);
    margin: 0;
    line-height: 1.25;
  }

  /* ========================================
     BENTO GRID SYSTEM (Desktop default)
  ======================================== */
  .sd-grid {
    display: grid;
    grid-template-columns: repeat(12, 1fr);
    gap: 18px;
    width: 100%;
  }

  /* Layout columns for cards */
  .sd-card[data-card="1"] { grid-column: span 7; }
  .sd-card[data-card="2"] { grid-column: span 5; }
  .sd-card[data-card="3"] { grid-column: span 5; }
  .sd-card[data-card="4"] { grid-column: span 7; }
  .sd-card[data-card="5"] { grid-column: span 6; }
  .sd-card[data-card="6"] { grid-column: span 6; }

  /* ========================================
     CARD BASE STRUCTURE
  ======================================== */
  .sd-card {
    position: relative;
    background-color: #0c0c0e; /* Strong dark base */
    border-radius: 24px;
    overflow: hidden;
    transition: 
      background-color 0.4s ease, 
      transform 0.4s cubic-bezier(0.25, 1, 0.5, 1),
      box-shadow 0.4s ease;
    display: flex;
    text-decoration: none; /* Prevent underlines inside links */
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    --accent-color-1: #F0EFEA;
    --accent-rgb-1: 240, 239, 234;
    --accent-color-2: #8e8e93;
    --accent-rgb-2: 142, 142, 147;
  }

  .sd-card.is-active:hover {
    transform: translateY(-2px);
    background-color: #121215;
    box-shadow: 0 15px 35px rgba(0, 0, 0, 0.6);
  }

  /* Minimalist Link Arrow */
  .sd-card-arrow {
    position: absolute;
    top: 1.8rem;
    right: 1.8rem;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    color: rgba(255, 255, 255, 0.35);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 5;
    transition: 
      background-color 0.3s ease, 
      border-color 0.3s ease, 
      color 0.3s ease,
      transform 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .sd-card:hover .sd-card-arrow {
    background: rgba(var(--accent-rgb-1), 0.1);
    border-color: rgba(var(--accent-rgb-1), 0.3);
    color: var(--accent-color-1);
    transform: translate(2px, -2px) scale(1.05);
  }

  .sd-card--vert {
    flex-direction: column;
    min-height: 440px; /* Increased slightly to accommodate larger visuals */
  }

  .sd-card--horiz {
    flex-direction: row;
    min-height: 310px;
  }

  .sd-card-content {
    display: flex;
    width: 100%;
    height: 100%;
    min-height: inherit;
    padding: 2.2rem;
    position: relative;
    z-index: 2;
  }

  .sd-card--vert .sd-card-content {
    flex-direction: column;
    justify-content: space-between;
    align-items: stretch;
  }

  .sd-card--horiz .sd-card-content {
    flex-direction: row;
    align-items: center;
    gap: 2rem;
  }

  /* ----------------------------------------
     MINIMALIST BORDERS
  ---------------------------------------- */
  .sd-card-border {
    position: absolute;
    inset: 0;
    border-radius: 24px;
    border: 1px solid rgba(255, 255, 255, 0.06);
    pointer-events: none;
    z-index: 3;
    transition: border-color 0.4s ease;
  }

  .sd-card:hover .sd-card-border {
    border-color: rgba(255, 255, 255, 0.15);
  }

  /* ========================================
     CARD DETAILS & TEXT
  ======================================== */
  .sd-card-text {
    display: flex;
    flex-direction: column;
    position: relative;
    z-index: 2;
  }

  .sd-card--horiz .sd-card-text {
    width: 55%;
    flex-shrink: 0;
  }

  .sd-card-top {
    display: flex;
    align-items: center;
    gap: 0.8rem;
    margin-bottom: 1.5rem;
  }

  /* Colored Tag Badge */
  .sd-tag {
    display: inline-block;
    padding: 0.35rem 0.85rem;
    background: linear-gradient(135deg, rgba(var(--accent-rgb-1), 0.08), rgba(var(--accent-rgb-2), 0.08));
    border: 1px solid rgba(var(--accent-rgb-1), 0.25);
    border-radius: 100px;
    font-size: 0.65rem;
    font-weight: 600;
    color: var(--accent-color-1);
    letter-spacing: 0.02em;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.2);
  }

  .sd-card-main {
    display: flex;
    flex-direction: column;
    gap: 0.8rem;
  }

  .sd-card-title {
