---
import apricotSymbol from '../assets/brand_marks/apricot_symbol_nobackground.avif';
import { translations } from '../i18n/translations';

interface Props {
  lang?: string;
}
const { lang = 'es' } = Astro.props;
const T = translations[lang];
---

<nav id="navbar" role="navigation" aria-label="Main navigation">
  <!-- Top bar: visible before scroll -->
  <div class="nav-top-bar" id="nav-top-bar">
    <div class="nav-inner">
      <!-- Logo -->
      <a href="/" class="nav-logo" aria-label="Giralabs home" id="nav-logo-link">
        <div class="nav-logo-wrapper">
          <div class="nav-logo-entrance">
            <img src={apricotSymbol.src} alt="Giralabs" class="nav-logo-img" width="34" height="34" />
          </div>
        </div>
        <span class="nav-brand-name" aria-label="GIRALABS">
          <span class="nb-char" style="--d:0.05s">G</span><span class="nb-char" style="--d:0.09s">I</span><span class="nb-char" style="--d:0.13s">R</span><span class="nb-char" style="--d:0.17s">A</span><span class="nb-char" style="--d:0.21s">L</span><span class="nb-char" style="--d:0.25s">A</span><span class="nb-char" style="--d:0.29s">B</span><span class="nb-char" style="--d:0.33s">S</span>
        </span>
      </a>

      <!-- Center nav links -->
      <ul class="nav-links" role="list">
        <li><a href="/" class="nav-link" data-i18n="nav_home">{T.nav_home}</a></li>
        <li class="nav-dropdown-wrapper">
          <a href="/services" class="nav-link dropdown-toggle">
            <span data-i18n="nav_services">Servicios</span>
            <svg class="chevron-icon" viewBox="0 0 24 24" width="10" height="10" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </a>
          <div class="nav-dropdown-menu">
            <a href="/services" class="dropdown-item main-item" data-i18n="nav_services_all">{T.nav_services_all}</a>
            <div class="dropdown-divider"></div>
            <a href="/service/mobile-apps" class="dropdown-item" data-i18n="service_1_title">{T.service_1_title}</a>
            <a href="/service/web-development" class="dropdown-item" data-i18n="service_2_title">{T.service_2_title}</a>
            <a href="/service/business-digitalization" class="dropdown-item" data-i18n="service_3_title">{T.service_3_title}</a>
            <a href="/service/online-stores" class="dropdown-item" data-i18n="service_4_title">{T.service_4_title}</a>
            <a href="/service/custom-software" class="dropdown-item" data-i18n="service_5_title">{T.service_5_title}</a>
            <a href="/service/ai-integration" class="dropdown-item" data-i18n="service_6_title">{T.service_6_title}</a>
          </div>
        </li>
        <li><a href="/projects" class="nav-link" data-i18n="nav_projects">Proyectos</a></li>
        <li><a href="/about" class="nav-link" data-i18n="nav_about">Nosotros</a></li>
        <li><a href="/blog" class="nav-link" data-i18n="nav_blog">Blog</a></li>
      </ul>

      <!-- Right -->
      <div class="nav-right">
        <button id="lang-toggle" class="lang-toggle" aria-label="Toggle language" type="button">
          <span id="lang-es" class="lang-opt active">ES</span>
          <span class="lang-sep">/</span>
          <span id="lang-en" class="lang-opt">EN</span>
        </button>
        <a href="/contact" class="nav-cta" id="nav-cta-btn" data-i18n="nav_cta">Hablemos</a>
        <button class="hamburger" id="hamburger-btn" aria-label="Open menu" aria-expanded="false" type="button">
          <span></span><span></span>
        </button>
      </div>
    </div>
  </div>

  <!-- Floating glass pill: appears on scroll -->
  <div class="nav-pill" id="nav-pill" aria-hidden="true">
    <div class="pill-inner">
      <a href="/" class="pill-logo" aria-label="Giralabs home">
        <img src={apricotSymbol.src} alt="Giralabs" width="24" height="24" />
      </a>
      <ul class="pill-links" role="list">
        <li><a href="/" class="pill-link" data-i18n="nav_home">{T.nav_home}</a></li>
        <li class="pill-dropdown-wrapper">
          <a href="/services" class="pill-link dropdown-toggle">
            <span data-i18n="nav_services">Servicios</span>
            <svg class="chevron-icon" viewBox="0 0 24 24" width="10" height="10" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="6 9 12 15 18 9"></polyline>
            </svg>
          </a>
          <div class="pill-dropdown-menu">
            <a href="/services" class="dropdown-item main-item" data-i18n="nav_services_all">{T.nav_services_all}</a>
            <div class="dropdown-divider"></div>
            <a href="/service/mobile-apps" class="dropdown-item" data-i18n="service_1_title">{T.service_1_title}</a>
            <a href="/service/web-development" class="dropdown-item" data-i18n="service_2_title">{T.service_2_title}</a>
            <a href="/service/business-digitalization" class="dropdown-item" data-i18n="service_3_title">{T.service_3_title}</a>
            <a href="/service/online-stores" class="dropdown-item" data-i18n="service_4_title">{T.service_4_title}</a>
            <a href="/service/custom-software" class="dropdown-item" data-i18n="service_5_title">{T.service_5_title}</a>
            <a href="/service/ai-integration" class="dropdown-item" data-i18n="service_6_title">{T.service_6_title}</a>
          </div>
        </li>
        <li><a href="/projects" class="pill-link" data-i18n="nav_projects">Proyectos</a></li>
        <li><a href="/about" class="pill-link" data-i18n="nav_about">Nosotros</a></li>
        <li><a href="/blog" class="pill-link" data-i18n="nav_blog">Blog</a></li>
      </ul>
      <div class="pill-right">
        <button id="pill-lang-toggle" class="lang-toggle pill-lang" aria-label="Toggle language" type="button">
          <span id="pill-lang-es" class="lang-opt active">ES</span>
          <span class="lang-sep">/</span>
          <span id="pill-lang-en" class="lang-opt">EN</span>
        </button>
        <a href="/contact" class="pill-cta" data-i18n="nav_cta">Hablemos</a>
      </div>
    </div>
  </div>

  <!-- Mobile drawer -->
  <div class="mobile-drawer" id="mobile-drawer" aria-hidden="true">
    <ul class="mobile-links" role="list">
      <li><a href="/" class="mobile-link" data-i18n="nav_home">{T.nav_home}</a></li>
      <li class="mobile-dropdown-wrapper">
        <button class="mobile-link mobile-dropdown-toggle" type="button">
          <span data-i18n="nav_services">Servicios</span>
          <svg class="mobile-chevron-icon" viewBox="0 0 24 24" width="12" height="12" stroke="currentColor" stroke-width="2.5" fill="none" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </button>
        <div class="mobile-dropdown-menu">
          <a href="/services" class="mobile-sublink main-item" data-i18n="nav_services_all">{T.nav_services_all}</a>
          <a href="/service/mobile-apps" class="mobile-sublink" data-i18n="service_1_title">{T.service_1_title}</a>
          <a href="/service/web-development" class="mobile-sublink" data-i18n="service_2_title">{T.service_2_title}</a>
          <a href="/service/business-digitalization" class="mobile-sublink" data-i18n="service_3_title">{T.service_3_title}</a>
          <a href="/service/online-stores" class="mobile-sublink" data-i18n="service_4_title">{T.service_4_title}</a>
          <a href="/service/custom-software" class="mobile-sublink" data-i18n="service_5_title">{T.service_5_title}</a>
          <a href="/service/ai-integration" class="mobile-sublink" data-i18n="service_6_title">{T.service_6_title}</a>
        </div>
      </li>
      <li><a href="/projects" class="mobile-link" data-i18n="nav_projects">Proyectos</a></li>
      <li><a href="/about" class="mobile-link" data-i18n="nav_about">Nosotros</a></li>
      <li><a href="/blog" class="mobile-link" data-i18n="nav_blog">Blog</a></li>
      <li><a href="/contact" class="mobile-link mobile-cta" data-i18n="nav_cta">Hablemos</a></li>
    </ul>
  </div>
</nav>

<style>
  /* =============================================
     NAVBAR WRAPPER
  ============================================= */
  #navbar {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
  }

  /* =============================================
     TOP BAR (visible when at top)
  ============================================= */
  .nav-top-bar {
    padding: 0 2rem;
    transition: opacity 0.35s ease, transform 0.35s ease;
  }

  .nav-top-bar.hidden {
    opacity: 0;
    transform: translateY(-8px);
    pointer-events: none;
  }

  .nav-inner {
    max-width: 1200px;
    margin: 0 auto;
    height: 68px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
  }

  /* Logo */
  .nav-logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    text-decoration: none;
    color: inherit;
    flex-shrink: 0;
  }

  .nav-logo-wrapper {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    perspective: 600px;
  }

  /* 3D entrance animation container */
  .nav-logo-entrance {
    opacity: 0;
    animation: navLogoFlip 1.4s cubic-bezier(0.25, 1, 0.3, 1) 0.1s forwards;
    transform-style: preserve-3d;
    transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .nav-logo:hover .nav-logo-entrance {
    transform: rotateY(180deg);
  }

  .nav-logo-img {
    width: 32px;
    height: auto;
    display: block;
    filter: drop-shadow(0 2px 6px rgba(0,0,0,0.06));
  }

  .nav-brand-name {
    font-size: 0.9rem;
    font-weight: 700;
    letter-spacing: -0.04em;
    color: #000;
    display: flex;
    overflow: hidden;
  }

  /* Individual letter spans */
  .nb-char {
    display: inline-block;
    opacity: 0;
    transform: translateY(100%);
    animation: navCharReveal 0.6s cubic-bezier(0.25, 1, 0.5, 1) forwards;
    animation-delay: var(--d);
  }

  @keyframes navLogoFlip {
    0%   { opacity: 0; transform: rotateY(-300deg) scale(0.7); }
    100% { opacity: 1; transform: rotateY(0deg) scale(1); }
  }

  @keyframes navCharReveal {
    to { opacity: 1; transform: translateY(0); }
  }

  /* Nav links */
  .nav-links {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 2rem;
    flex: 1;
    justify-content: center;
  }

  .nav-link {
    font-size: 0.85rem;
    font-weight: 400;
    color: #555;
    text-decoration: none;
    position: relative;
    transition: color 0.2s ease;
    letter-spacing: -0.005em;
    display: inline-flex;
    align-items: center;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -3px;
    left: 0;
    width: 100%;
    height: 1px;
    background: #000;
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.3s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .nav-link:hover { color: #000; }
  .nav-link:hover::after { transform: scaleX(1); transform-origin: left; }

  /* =============================================
     NAVBAR DROPDOWN (Hover triggers)
  ============================================= */
  .nav-dropdown-wrapper {
    position: relative;
  }

  .nav-dropdown-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(12px);
    width: 250px;
    background: rgba(240, 239, 234, 0.85);
    backdrop-filter: blur(28px) saturate(180%);
    -webkit-backdrop-filter: blur(28px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.7);
    border-radius: 16px;
    padding: 0.6rem 0.5rem;
    box-shadow: 
      0 10px 30px rgba(0,0,0,0.06),
      0 0 0 0.5px rgba(0,0,0,0.02) inset,
      0 1px 0 rgba(255,255,255,0.8) inset;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: 
      opacity 0.25s ease, 
      transform 0.35s cubic-bezier(0.25, 1, 0.5, 1), 
      visibility 0.25s;
    transition-delay: 0.12s; /* 120ms delay when closing to prevent slip-offs */
    z-index: 1000;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .nav-dropdown-menu::before {
    content: '';
    position: absolute;
    top: -24px;
    left: 0;
    right: 0;
    height: 24px;
    background: transparent;
  }

  .nav-dropdown-wrapper:hover .nav-dropdown-menu {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(4px);
    transition-delay: 0s; /* Open instantly on hover */
  }

  .chevron-icon {
    display: inline-block;
    margin-left: 4px;
    vertical-align: middle;
    position: relative;
    top: 1px;
    transition: transform 0.35s cubic-bezier(0.25, 1, 0.5, 1);
  }

  .nav-dropdown-wrapper:hover .chevron-icon,
  .pill-dropdown-wrapper:hover .chevron-icon {
    transform: rotate(180deg);
  }

  /* =============================================
     PILL DROPDOWN
  ============================================= */
  .pill-dropdown-wrapper {
    position: relative;
  }

  .pill-link {
    display: inline-flex;
    align-items: center;
  }

  .pill-dropdown-menu {
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%) translateY(16px);
    width: 240px;
    background: rgba(240, 239, 234, 0.85);
    backdrop-filter: blur(28px) saturate(180%);
    -webkit-backdrop-filter: blur(28px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.7);
    border-radius: 16px;
    padding: 0.6rem 0.5rem;
    box-shadow: 
      0 10px 30px rgba(0,0,0,0.06),
      0 0 0 0.5px rgba(0,0,0,0.02) inset,
      0 1px 0 rgba(255,255,255,0.8) inset;
    opacity: 0;
    visibility: hidden;
    pointer-events: none;
    transition: 
      opacity 0.25s ease, 
      transform 0.35s cubic-bezier(0.25, 1, 0.5, 1), 
      visibility 0.25s;
    transition-delay: 0.12s; /* 120ms delay when closing to prevent slip-offs */
    z-index: 1000;
    display: flex;
    flex-direction: column;
    gap: 0.15rem;
  }

  .pill-dropdown-menu::before {
    content: '';
    position: absolute;
    top: -24px;
    left: 0;
    right: 0;
    height: 24px;
    background: transparent;
  }

  .pill-dropdown-wrapper:hover .pill-dropdown-menu {
    opacity: 1;
    visibility: visible;
    pointer-events: auto;
    transform: translateX(-50%) translateY(8px);
    transition-delay: 0s; /* Open instantly on hover */
  }

  /* =============================================
     DROPDOWN SHARED ITEMS
  ============================================= */
  .dropdown-item {
    display: block;
    padding: 0.55rem 0.75rem;
    border-radius: 10px;
    font-size: 0.78rem;
    color: #555;
    text-decoration: none;
    text-align: left;
    transition: background-color 0.2s, color 0.2s, transform 0.2s;
  }

  .dropdown-item:hover {
    background: rgba(0, 0, 0, 0.04);
    color: #000;
    transform: translateX(3px);
  }

  .dropdown-item.main-item {
    font-weight: 600;
    color: #000;
  }

  .dropdown-divider {
    height: 1px;
    background: rgba(0, 0, 0, 0.06);
    margin: 0.25rem 0.5rem;
  }

  /* =============================================
     MOBILE ACCORDION DROPDOWN
  ============================================= */
  .mobile-dropdown-wrapper {
    width: 100%;
  }

  .mobile-dropdown-toggle {
    width: 100%;
    background: none;
    border: none;
    text-align: left;
    display: flex;
    align-items: center;
    justify-content: space-between;
    cursor: pointer;
    font-family: inherit;
    outline: none;
    padding: 0.75rem 0;
    font-size: 1.1rem;
    font-weight: 400;
    color: #333;
    border-bottom: 1px solid rgba(0,0,0,0.05);
  }

  .mobile-chevron-icon {
    transition: transform 0.3s ease;
    color: #888;
  }

  .mobile-dropdown-menu {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.35s cubic-bezier(0.25, 1, 0.5, 1);
    display: flex;
    flex-direction: column;
    padding-left: 0.8rem;
  }

  .mobile-dropdown-wrapper.open .mobile-dropdown-menu {
    max-height: 380px;
  }

  .mobile-dropdown-wrapper.open .mobile-chevron-icon {
    transform: rotate(180deg);
  }

  .mobile-sublink {
    display: block;
    padding: 0.65rem 0;
    font-size: 0.88rem;
    color: #666;
    text-decoration: none;
    border-bottom: 1px solid rgba(0,0,0,0.03);
    transition: color 0.2s;
  }

  .mobile-sublink:hover {
    color: #000;
  }

  .mobile-sublink.main-item {
    font-weight: 600;
    color: #333;
  }

  /* Right cluster */
  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.2rem;
    flex-shrink: 0;
  }

  /* Lang toggle */
  .lang-toggle {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
    font-family: inherit;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: #888;
    transition: color 0.2s;
  }

  .lang-toggle:hover { color: #000; }

  .lang-opt {
    transition: color 0.2s, opacity 0.2s;
    opacity: 0.4;
  }

  .lang-opt.active { opacity: 1; color: #000; }
  .lang-sep { opacity: 0.25; font-weight: 300; }

  /* CTA top bar */
  .nav-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.45rem 1rem;
    background: #000;
    color: #F0EFEA;
    font-size: 0.82rem;
    font-weight: 500;
    text-decoration: none;
    border-radius: 100px;
    letter-spacing: -0.01em;
    transition: background 0.2s ease, transform 0.2s ease, box-shadow 0.2s ease;
  }

  .nav-cta:hover {
    background: #222;
    transform: translateY(-1px);
    box-shadow: 0 4px 14px rgba(0,0,0,0.12);
  }

  /* Hamburger */
  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    width: 28px;
    height: 28px;
  }

  .hamburger span {
    display: block;
    width: 20px;
    height: 1.5px;
    background: #000;
    transition: transform 0.3s ease, opacity 0.3s ease;
    transform-origin: center;
  }

  .hamburger.open span:first-child { transform: translateY(3.25px) rotate(45deg); }
  .hamburger.open span:last-child  { transform: translateY(-3.25px) rotate(-45deg); }

  /* Applied by inline head script before first paint — no transition on initial load */
  :global([data-scrolled]) .nav-top-bar {
    opacity: 0;
    transform: translateY(-8px);
    pointer-events: none;
    transition: none;
  }

  :global([data-scrolled]) .nav-pill {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
    pointer-events: auto;
    transition: none;
  }
  .nav-pill {
    position: fixed;
    top: 16px;
    left: 50%;
    transform: translateX(-50%) translateY(-80px);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.5s cubic-bezier(0.34, 1.2, 0.64, 1), opacity 0.4s ease;
    z-index: 101;
  }

  .nav-pill.visible {
    transform: translateX(-50%) translateY(0);
    opacity: 1;
    pointer-events: auto;
  }

  .pill-inner {
    display: flex;
    align-items: center;
    gap: 0;
    padding: 0.6rem 1rem 0.6rem 1rem;
    border-radius: 100px;
    min-width: 740px;

    /* iOS 26 Liquid Glass */
    background: rgba(240, 239, 234, 0.45);
    backdrop-filter: blur(32px) saturate(180%);
    -webkit-backdrop-filter: blur(32px) saturate(180%);
    border: 1px solid rgba(255, 255, 255, 0.7);
    box-shadow:
      0 2px 24px rgba(0,0,0,0.08),
      0 0 0 0.5px rgba(0,0,0,0.04) inset,
      0 1px 0 rgba(255,255,255,0.9) inset;
  }

  .pill-logo {
    display: flex;
    align-items: center;
    flex-shrink: 0;
    text-decoration: none;
    margin-right: 1.6rem;
  }

  .pill-logo img {
    width: 24px;
    height: auto;
    display: block;
  }

  .pill-links {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 1.8rem;
    flex: 1;
    justify-content: center;
  }

  .pill-link {
    font-size: 0.82rem;
    font-weight: 400;
    color: #444;
    text-decoration: none;
    transition: color 0.2s ease;
    white-space: nowrap;
    letter-spacing: -0.005em;
  }

  .pill-link:hover { color: #000; }

  .pill-right {
    display: flex;
    align-items: center;
    gap: 0.9rem;
    margin-left: 1.6rem;
    flex-shrink: 0;
  }

  .pill-lang {
    font-size: 0.72rem;
  }

  /* CTA inside pill */
  .pill-cta {
    display: inline-flex;
    align-items: center;
    padding: 0.38rem 0.9rem;
    border-radius: 100px;
    font-size: 0.78rem;
    font-weight: 500;
    text-decoration: none;
    letter-spacing: -0.01em;
    white-space: nowrap;

    /* glass button inside glass pill */
    background: rgba(0, 0, 0, 0.82);
    color: rgba(240, 239, 234, 0.95);
    border: 1px solid rgba(255,255,255,0.12);
    box-shadow: 0 1px 4px rgba(0,0,0,0.2) inset;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .pill-cta:hover {
    background: rgba(30,30,30,0.92);
    transform: scale(1.02);
  }

  /* Separator inside pill */
  .pill-sep {
    width: 1px;
    height: 16px;
    background: rgba(0,0,0,0.1);
    flex-shrink: 0;
  }

  /* =============================================
     MOBILE DRAWER
  ============================================= */
  .mobile-drawer {
    display: none;
    flex-direction: column;
    background: rgba(240, 239, 234, 0.97);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    padding: 1rem 2rem 2rem;
    border-top: 1px solid rgba(0,0,0,0.06);
    opacity: 0;
    transform: translateY(-8px);
    transition: opacity 0.3s ease, transform 0.3s ease;
    pointer-events: none;
  }

  .mobile-drawer.open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .mobile-links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .mobile-link {
    display: block;
    padding: 0.75rem 0;
    font-size: 1.1rem;
    font-weight: 400;
    color: #333;
    text-decoration: none;
    border-bottom: 1px solid rgba(0,0,0,0.05);
    transition: color 0.2s;
  }

  .mobile-link:hover { color: #000; }
  .mobile-link.mobile-cta { border-bottom: none; margin-top: 0.5rem; color: #000; font-weight: 600; }

  /* =============================================
     RESPONSIVE
  ============================================= */
  @media (max-width: 768px) {
    .nav-links { display: none; }
    .nav-cta { display: none; }
    .hamburger { display: flex; }
    .mobile-drawer { display: flex; }
    .nav-pill { display: none; }
  }
</style>

<script>
  // ---- Scroll: show pill, hide top bar ----
  const topBar = document.getElementById('nav-top-bar');
  const pill = document.getElementById('nav-pill');
  const THRESHOLD = 80;

  function updateNav() {
    const scrolled = window.scrollY > THRESHOLD;
    topBar.classList.toggle('hidden', scrolled);
    pill.classList.toggle('visible', scrolled);
    pill.setAttribute('aria-hidden', String(!scrolled));
  }

  // Sync class state with the scroll position established by the head script,
  // then remove data-scrolled so CSS transitions work normally from here on
  updateNav();
  requestAnimationFrame(() => {
    document.documentElement.removeAttribute('data-scrolled');
  });

  window.addEventListener('scroll', updateNav, { passive: true });

  // ---- Mobile hamburger ----
  const hamburgerBtn = document.getElementById('hamburger-btn');
  const mobileDrawer = document.getElementById('mobile-drawer');
  if (hamburgerBtn && mobileDrawer) {
    hamburgerBtn.addEventListener('click', () => {
      const isOpen = hamburgerBtn.getAttribute('aria-expanded') === 'true';
      hamburgerBtn.setAttribute('aria-expanded', String(!isOpen));
      hamburgerBtn.classList.toggle('open', !isOpen);
      mobileDrawer.classList.toggle('open', !isOpen);
      mobileDrawer.setAttribute('aria-hidden', String(isOpen));
    });
    document.querySelectorAll('.mobile-link, .mobile-sublink').forEach(link => {
      link.addEventListener('click', () => {
        hamburgerBtn.setAttribute('aria-expanded', 'false');
        hamburgerBtn.classList.remove('open');
        mobileDrawer.classList.remove('open');
        mobileDrawer.setAttribute('aria-hidden', 'true');
      });
    });
  }

  // ---- Language toggle (top bar) ----
  function syncLangUI(lang) {
    ['lang-es', 'lang-en', 'pill-lang-es', 'pill-lang-en'].forEach(id => {
      const el = document.getElementById(id);
      if (el) {
        const isActive = id.includes(lang === 'es' ? 'es' : 'en');
        el.classList.toggle('active', isActive);
      }
    });
  }

  function handleLangToggle() {
    const currentLang = document.documentElement.lang || 'es';
    const newLang = currentLang === 'es' ? 'en' : 'es';
    localStorage.setItem('giralabs-lang', newLang);
    // Fire custom event so index.astro's i18n script can respond
    document.dispatchEvent(new CustomEvent('giralabs:lang', { detail: { lang: newLang } }));
    syncLangUI(newLang);
  }

  document.getElementById('lang-toggle')?.addEventListener('click', handleLangToggle);
  document.getElementById('pill-lang-toggle')?.addEventListener('click', handleLangToggle);

  // Sync lang UI and document lang on load from localStorage
  const savedLang = localStorage.getItem('giralabs-lang');
  if (savedLang && (savedLang === 'es' || savedLang === 'en')) {
    document.documentElement.lang = savedLang;
    syncLangUI(savedLang);
  }

  // ---- Dropdown cards smooth scroll & Sub-page Navigation ----
  function initDropdownScroll() {
    const isHomepage = window.location.pathname === '/' || window.location.pathname.endsWith('/index.html') || window.location.pathname === '';

    // Fix other header anchor links when not on homepage
    if (!isHomepage) {
      document.querySelectorAll('a[href^="#"]:not([href="#"])').forEach(link => {
        const href = link.getAttribute('href');
        if (href) {
          if (href === '#services') {
            link.setAttribute('href', '/services');
          } else if (href === '#contact') {
            link.setAttribute('href', '/contact');
          } else {
            link.setAttribute('href', '/' + href);
          }
        }
      });
    }

    // Mobile dropdown accordion toggle
    const mobileToggle = document.querySelector('.mobile-dropdown-toggle');
    const mobileWrapper = document.querySelector('.mobile-dropdown-wrapper');
    if (mobileToggle && mobileWrapper) {
      const newToggle = mobileToggle.cloneNode(true);
      mobileToggle.parentNode.replaceChild(newToggle, mobileToggle);
      
      newToggle.addEventListener('click', (e) => {
        e.preventDefault();
        e.stopPropagation();
        mobileWrapper.classList.toggle('open');
      });
    }
  }

  initDropdownScroll();
  document.addEventListener('astro:after-swap', initDropdownScroll);
</script>